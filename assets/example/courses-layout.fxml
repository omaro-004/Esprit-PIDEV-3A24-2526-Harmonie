<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<?import java.net.URL?>
<BorderPane fx:id="root"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.LibraryControllers.CoursesLayoutController"
            prefWidth="1200" prefHeight="700"
            styleClass="front-root">
    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>


    <center>
        <BorderPane fx:id="contentPane" style="-fx-background-color: transparent;">
            <top>
                <VBox>
                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="library-header">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <ImageView fx:id="coursesHeaderIcon" fitWidth="28" fitHeight="28" preserveRatio="true" styleClass="header-icon"/>
                            <Label text="My Courses" styleClass="section-title"/>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addCourseButton" text="Add Course" styleClass="action-button"/>
                        <Button fx:id="libraryBtn" text="Library" styleClass="action-button"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 0 20 8 20;">
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="gridViewBtn" styleClass="view-toggle-btn" contentDisplay="GRAPHIC_ONLY">
                            <graphic>
                                <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                    <image>
                                        <Image url="@/grid-view-svgrepo-com.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="listViewBtn" styleClass="view-toggle-btn" contentDisplay="GRAPHIC_ONLY">
                            <graphic>
                                <ImageView fitWidth="18" fitHeight="18" preserveRatio="true">
                                    <image>
                                        <Image url="@/list-view-svgrepo-com.png"/>
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                    </HBox>
                </VBox>
            </top>

            <center>
                <ScrollPane fx:id="coursesScrollPane"
                            fitToWidth="true"
                            styleClass="library-content"
                            style="-fx-background-color: transparent; -fx-control-inner-background: transparent;">
                    <TilePane fx:id="coursesContainer" hgap="18" vgap="18" prefColumns="3">
                        <padding>
                            <Insets top="24" right="24" bottom="24" left="24"/>
                        </padding>
                    </TilePane>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>



</BorderPane>
