// ══════════════════════════════════════════════════════
// LOG FORM
// ══════════════════════════════════════════════════════
async function handleLogSubmit(e) {
  e.preventDefault();
  let valid = true;
  const exId = document.getElementById('exerciseId').value;
  const errEx = document.getElementById('err-exercice');
  if (!exId) { errEx.classList.add('show'); valid=false; } else errEx.classList.remove('show');
  const dureeEl = document.getElementById('duree');
  const duree   = parseInt(dureeEl.value);
  const errDur  = document.getElementById('err-duree');
  if (!duree||duree<1||duree>300) { dureeEl.classList.add('error'); errDur.classList.add('show'); valid=false; }
  else { dureeEl.classList.remove('error'); errDur.classList.remove('show'); }
  const dateEl = document.getElementById('dateSeance');
  const date   = dateEl.value;
  const errDt  = document.getElementById('err-date');
  if (!date) { dateEl.classList.add('error'); errDt.classList.add('show'); valid=false; }
  else { dateEl.classList.remove('error'); errDt.classList.remove('show'); }
  if (!valid) return;
  const btn = document.getElementById('submitBtn');
  btn.disabled=true; btn.innerHTML='⏳ Enregistrement...';
  const payload = {
    exercice_id:exId, duree_minutes:duree, date_activite:date,
    calories_brulees:parseInt(document.getElementById('calories').value)||null,
    poids:parseFloat(document.getElementById('poids').value)||null,
    nb_series:parseInt(document.getElementById('series').value)||null,
    nb_repetitions:parseInt(document.getElementById('reps').value)||null,
    notes:document.getElementById('notes').value.trim()||null,
  };
  try {
    const res = await fetch(API.add,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data = await res.json();
    if (data.success) { showToast('success','✅ Exercice ajouté !'); updateStats(data.stats); setTimeout(()=>location.reload(),800); }
    else {
      if (data.errors) Object.entries(data.errors).forEach(([k,msg])=>{ const el=document.getElementById('err-'+k); if(el){el.textContent='⚠ '+msg;el.classList.add('show');} });
      showToast('error','⚠ Erreur enregistrement.');
    }
  } catch { showToast('error','⚠ Erreur réseau.'); }
  finally { btn.disabled=false; btn.innerHTML='<span>💾</span> Enregistrer dans la séance'; }
}

