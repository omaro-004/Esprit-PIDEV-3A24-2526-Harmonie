// ══════════════════════════════════════════════════════
// FIX YOUTUBE — Conversion URL → embed
// YouTube bloque les iframes sur des URLs normales (watch?v=…).
// Il faut utiliser https://www.youtube.com/embed/VIDEO_ID
// Cette fonction extrait l'ID et construit l'URL embed correcte.
// ══════════════════════════════════════════════════════

/**
 * extractYouTubeId(url)
 * Extrait l'ID d'une vidéo YouTube depuis n'importe quel format :
 *   - https://www.youtube.com/watch?v=ID
 *   - https://youtu.be/ID
 *   - https://www.youtube.com/embed/ID
 *   - https://youtube.com/shorts/ID
 * Retourne null si l'URL n'est pas une URL YouTube reconnue.
 */
function extractYouTubeId(url) {
  if (!url) return null;
  // Patterns possibles
  const patterns = [
    /[?&]v=([a-zA-Z0-9_-]{11})/,          // watch?v=ID
    /youtu\.be\/([a-zA-Z0-9_-]{11})/,      // youtu.be/ID
    /embed\/([a-zA-Z0-9_-]{11})/,          // embed/ID
    /shorts\/([a-zA-Z0-9_-]{11})/,         // shorts/ID
    /\/v\/([a-zA-Z0-9_-]{11})/,            // /v/ID
  ];
  for (const pattern of patterns) {
    const match = url.match(pattern);
    if (match && match[1]) return match[1];
  }
  return null;
}

/**
 * openVideo(url, name)
 * Ouvre la modale vidéo.
 * - Si c'est une URL YouTube : affiche un iframe embed (contourne le blocage)
 * - Sinon : affiche un iframe normal (Vimeo, etc.)
 * - Si l'embed échoue : affiche un bouton pour ouvrir dans un nouvel onglet
 */
function openVideo(url, name) {
  const wrap = document.getElementById('videoWrap');
  document.getElementById('videoTitle').textContent = name;
  openModal('videoModal');

  const ytId = extractYouTubeId(url);

  if (ytId) {
    // URL embed YouTube avec paramètres optimaux
    const embedUrl = `https://www.youtube.com/embed/${ytId}?autoplay=1&rel=0&modestbranding=1&playsinline=1`;
    wrap.innerHTML = `
      <iframe
        src="${embedUrl}"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
        title="${name}"
        style="position:absolute;inset:0;width:100%;height:100%;border:none;">
      </iframe>`;
  } else if (url && url.startsWith('http')) {
    // Autre plateforme vidéo (Vimeo, etc.)
    wrap.innerHTML = `
      <iframe
        src="${url}"
        frameborder="0"
        allow="autoplay; fullscreen; picture-in-picture"
        allowfullscreen
        title="${name}"
        style="position:absolute;inset:0;width:100%;height:100%;border:none;">
      </iframe>`;
  } else {
    // Pas d'URL valide — fallback avec bouton
    wrap.innerHTML = `
      <div class="video-fallback">
        <div style="font-size:52px">🎥</div>
        <h3>${name}</h3>
        <p>La vidéo ne peut pas être lue directement ici.<br>Cliquez pour l'ouvrir sur YouTube.</p>
        <a class="btn-open-youtube" href="${url || '#'}" target="_blank" rel="noopener">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="white">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Ouvrir sur YouTube
        </a>
      </div>`;
  }
}

// ══════════════════════════════════════════════════════
// SECTION TABS
// ══════════════════════════════════════════════════════
function switchSection(section, btn) {
  currentSection = section;
  document.querySelectorAll('.section-tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const labels = { all: 'Tous les exercices', homme: 'Exercices Homme ♂', femme: 'Exercices Femme ♀' };
  const lbl = document.getElementById('libSectionLabel');
  if (lbl) lbl.textContent = labels[section] || 'Tous les exercices';
  currentFilter = 'all';
  document.querySelectorAll('.cat-btn').forEach(b =>
    b.classList.remove('active','all','cardio','force','souplesse','endurance','perte'));
  const allBtn = document.querySelector('.cat-btn[data-cat="all"]');
  if (allBtn) allBtn.classList.add('active','all');
  applyFilters();
}

function applyFilters() {
  const search = (document.getElementById('searchInput').value || '').toLowerCase().trim();
  document.querySelectorAll('.ex-card').forEach(card => {
    const cardSection = card.dataset.section || 'neutre';
    const cardCat     = (card.dataset.cat || '').toLowerCase();
    const cardName    = (card.dataset.name || '').toLowerCase();
    let sectionOk = true;
    if (currentSection === 'homme') sectionOk = (cardSection === 'homme');
    else if (currentSection === 'femme') sectionOk = (cardSection === 'femme');
    const catOk  = (currentFilter === 'all') || cardCat.includes(currentFilter.toLowerCase());
    const nameOk = !search || cardName.includes(search);
    card.style.display = (sectionOk && catOk && nameOk) ? '' : 'none';
  });
  updateTabCounts(search);
}

function updateTabCounts(search) {
  search = (search || '').toLowerCase().trim();
  let cAll = 0, cH = 0, cF = 0;
  document.querySelectorAll('.ex-card').forEach(card => {
    const s = card.dataset.section || 'neutre';
    const n = (card.dataset.name || '').toLowerCase();
    if (search && !n.includes(search)) return;
    cAll++;
    if (s === 'homme') cH++;
    else if (s === 'femme') cF++;
  });
  const ta = document.getElementById('tabCountAll');
  const th = document.getElementById('tabCountHomme');
  const tf = document.getElementById('tabCountFemme');
  if (ta) ta.textContent = cAll;
  if (th) th.textContent = cH;
  if (tf) tf.textContent = cF;
}

function liveSearch(val) { applyFilters(); }


// ══════════════════════════════════════════════════════
// ANIMATED COUNTERS
// ══════════════════════════════════════════════════════
function animateCounters() {
  ['statSeances','statMinutes','statCalories','sideSeances','sideMin','sideCal'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const target = parseInt(el.textContent) || 0;
    if (!target) return;
    let start = 0;
    const step = Math.ceil(target/40);
    const iv = setInterval(() => { start = Math.min(start+step,target); el.textContent=start; if(start>=target) clearInterval(iv); }, 25);
  });
}

// ══════════════════════════════════════════════════════
// WEEKLY BARS — 7 derniers jours
// ══════════════════════════════════════════════════════
function buildWeeklyBars() {
  const wrap = document.getElementById('weeklyBars');
  if (!wrap) return;
  // On lit les sessions depuis le DOM (ex-row dans les session-blocks)
  const sessionBlocks = document.querySelectorAll('.session-block');
  const counts = {};
  sessionBlocks.forEach(block => {
    const dateEl = block.querySelector('.session-date-big');
    if (!dateEl) return;
    const text = dateEl.textContent.replace('📅','').trim();
    // format dd/mm/yyyy
    const parts = text.split('/');
    if (parts.length===3) {
      const key = `${parts[2]}-${parts[1]}-${parts[0]}`;
      counts[key] = (counts[key]||0) + (block.querySelectorAll('.ex-row').length);
    }
  });
  const days = ['Lu','Ma','Me','Je','Ve','Sa','Di'];
  const today = new Date();
  const maxVal = Math.max(...Object.values(counts), 1);
  wrap.innerHTML = '';
  for (let i=6; i>=0; i--) {
    const d = new Date(today); d.setDate(today.getDate()-i);
    const key = d.toISOString().split('T')[0];
    const dayLbl = days[d.getDay()===0?6:d.getDay()-1];
    const val = counts[key]||0;
    const pct = Math.round((val/maxVal)*100);
    const isToday = (i===0);
    const barDiv = document.createElement('div');
    barDiv.className = 'weekly-bar-wrap';
    barDiv.title = `${key} : ${val} exercice${val!==1?'s':''}`;
    barDiv.innerHTML = `
      <div class="weekly-bar-inner${isToday?' today':''}" style="height:${Math.max(pct,5)}%"></div>
      <span class="weekly-bar-label">${dayLbl}</span>`;
    wrap.appendChild(barDiv);
  }
}

// ══════════════════════════════════════════════════════
// CHART DONUT
// ══════════════════════════════════════════════════════
function initChart() {
  const cats = { Cardio:0, Force:0, Souplesse:0, Endurance:0, Perte:0 };
  document.querySelectorAll('.ex-row').forEach(row => {
    const dot = row.querySelector('.ex-row-dot');
    if (!dot) return;
    if (dot.classList.contains('cardio'))       cats.Cardio++;
    else if (dot.classList.contains('force'))     cats.Force++;
    else if (dot.classList.contains('souplesse')) cats.Souplesse++;
    else if (dot.classList.contains('endurance')) cats.Endurance++;
    else if (dot.classList.contains('perte'))     cats.Perte++;
  });
  const colors  = ['#FF4D6D','#3B82F6','#10B981','#F59E0B','#EF4444'];
  const labels  = Object.keys(cats);
  const data    = Object.values(cats);
  const total   = data.reduce((a,b)=>a+b,0);

  // Centre label
  const cval = document.getElementById('chartTotalEx');
  if (cval) cval.textContent = total;

  const ctx = document.getElementById('catChart')?.getContext('2d');
  if (!ctx) return;
  _catChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels,
      datasets: [{ data, backgroundColor:colors, borderColor:'#fff', borderWidth:3, hoverOffset:10 }]
    },
    options: {
      responsive:false, cutout:'70%',
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label: c => ` ${c.label}: ${c.raw}` } } },
      animation:{ animateRotate:true, duration:800 }
    }
  });

  const legend = document.getElementById('chartLegend');
  if (!legend) return;
  legend.innerHTML = '';
  const maxD = Math.max(...data,1);
  labels.forEach((lbl,i) => {
    const pct = total ? Math.round(data[i]/total*100) : 0;
    const row = document.createElement('div');
    row.className = 'legend-row';
    row.innerHTML = `
      <div class="legend-swatch" style="background:${colors[i]}"></div>
      <span class="legend-label">${lbl}</span>
      <span class="legend-val">${data[i]}</span>`;
    // Bar de progression sous le row
    const barTrack = document.createElement('div');
    barTrack.style.cssText = 'grid-column:1/-1;';
    row.appendChild(barTrack);
    legend.appendChild(row);
  });
}

