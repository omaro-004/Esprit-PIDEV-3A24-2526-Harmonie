  document.getElementById('editPoids').value=poids||'';
  document.getElementById('editNotes').value=notes||'';
  openModal('editModal');
}

async function handleEditSubmit(e) {
  e.preventDefault();
  const dureeEl=document.getElementById('editDuree');
  const duree=parseInt(dureeEl.value);
  const errEl=document.getElementById('err-edit-duree');
  if (!duree||duree<1||duree>300) { dureeEl.classList.add('error'); errEl.classList.add('show'); return; }
  dureeEl.classList.remove('error'); errEl.classList.remove('show');
  const payload = {
    duree_minutes:duree,
    calories_brulees:document.getElementById('editCalories').value||null,
    nb_series:document.getElementById('editSeries').value||null,
    nb_repetitions:document.getElementById('editReps').value||null,
    poids:document.getElementById('editPoids').value||null,
    notes:document.getElementById('editNotes').value.trim()||null,
  };
  try {
    const res=await fetch(API.update(editingId),{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
    const data=await res.json();
    if (data.success) { showToast('success','✏️ Modifié !'); updateStats(data.stats); closeModal('editModal'); setTimeout(()=>location.reload(),600); }
    else showToast('error','⚠ Erreur modification.');
  } catch { showToast('error','⚠ Erreur réseau.'); }
}

// ══════════════════════════════════════════════════════
// DELETE EXERCISE
// ══════════════════════════════════════════════════════
function openDeleteModal(id,name) {
  _deleteTargetId=id;
  document.getElementById('deleteExName').textContent=name;
  openModal('deleteModal');
}

async function confirmDelete() {
  if (!_deleteTargetId) return;
  const btn=document.getElementById('deleteConfirmBtn');
  btn.innerHTML='⏳ Suppression...'; btn.disabled=true;
  try {
    const res=await fetch(API.delete(_deleteTargetId),{method:'POST'});
    const data=await res.json();
    if (data.success) { closeModal('deleteModal'); showToast('error','🗑 Exercice supprimé'); updateStats(data.stats); setTimeout(()=>location.reload(),500); }
    else showToast('error','⚠ Erreur suppression.');
  } catch { showToast('error','⚠ Erreur réseau.'); }
  finally { btn.innerHTML='🗑 Supprimer'; btn.disabled=false; _deleteTargetId=null; }
}

// ══════════════════════════════════════════════════════
// DELETE SESSION
// ══════════════════════════════════════════════════════
async function deleteSession(date) {
  if (!confirm('Supprimer toute la séance du '+formatDate(date)+' ?')) return;
  try {
    const res=await fetch(API.list);
    const all=await res.json();
    const session=all.sessions.find(s=>s.date===date);
    if (!session) { showToast('error','Séance introuvable.'); return; }
    for (const ex of session.exercises) await fetch(API.delete(ex.id),{method:'POST'});
    showToast('error','🗑 Séance supprimée');
    setTimeout(()=>location.reload(),600);
  } catch { showToast('error','⚠ Erreur réseau.'); }
}

// ══════════════════════════════════════════════════════
// SESSION ACCORDION
// ══════════════════════════════════════════════════════
function toggleSession(headEl) {
  const block=headEl.closest('.session-block');
  block.querySelector('.session-exercises').classList.toggle('open');
  block.querySelector('.session-chevron').classList.toggle('open');
}

// ══════════════════════════════════════════════════════
// STATS UPDATE
// ══════════════════════════════════════════════════════
function updateStats(stats) {
  if (!stats) return;
  ['statSeances','sideSeances'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=stats.sessions;});
  ['statMinutes','sideMin'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=stats.minutes;});
  ['statCalories','sideCal'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent=stats.calories;});
}

function updateSideTotal() {
  const el=document.getElementById('sideTotal');
  if (el) el.textContent=document.querySelectorAll('.ex-row').length;
}

// ══════════════════════════════════════════════════════
// MODALS
// ══════════════════════════════════════════════════════
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  // Nettoie l'iframe vidéo pour stopper la lecture
  if (id==='videoModal') {
    const wrap=document.getElementById('videoWrap');
    if (wrap) wrap.innerHTML='';
  }
}

// ══════════════════════════════════════════════════════
// FAVOURITES — version améliorée avec sélection rapide
// ══════════════════════════════════════════════════════
const FAV_KEY = 'harmony_favs_v2';
function loadFavs() { try { return JSON.parse(localStorage.getItem(FAV_KEY))||{}; } catch { return {}; } }
function saveFavs(favs) { localStorage.setItem(FAV_KEY,JSON.stringify(favs)); }

function toggleFav(btn) {
  const { id, name, type, icon, cls } = btn.dataset;
  const favs = loadFavs();
  if (favs[id]) {
    delete favs[id];
    btn.classList.remove('active'); btn.innerHTML='⭐ Fav';
    showToast('info','Retiré des favoris');
  } else {
    favs[id] = { id, name, type, icon, cls:cls||'force' };
    btn.classList.add('active'); btn.innerHTML='★ Favori';
    showToast('success','⭐ '+name+' ajouté aux favoris !');
  }
  saveFavs(favs);
  renderFavList(favs);
}

function removeFav(id) {
  const favs=loadFavs();
  delete favs[id]; saveFavs(favs);
  const btn=document.querySelector(`.fav-btn[data-id="${id}"]`);
  if (btn) { btn.classList.remove('active'); btn.innerHTML='⭐ Fav'; }
  renderFavList(favs);
}

/**
 * selectFromFav(id)
 * Sélectionne un exercice depuis les favoris — simule un clic sur la carte.
 */
function selectFromFav(id) {
  const card = document.querySelector(`.ex-card[data-id="${id}"]`);
  if (card) {
    // Affiche l'exercice dans la grille et le sélectionne
    card.style.display = '';
    selectExercise(card);
    card.scrollIntoView({ behavior:'smooth', block:'center' });
    showToast('info', '📌 Exercice sélectionné depuis les favoris');
  } else {
    showToast('info','⚠ Exercice non visible. Choisissez "Tous" puis réessayez.');
  }
}

function renderFavList(favs) {
  const list  = document.getElementById('favList');
  const empty = document.getElementById('favEmpty');
  const badge = document.getElementById('favCount');
  const keys  = Object.keys(favs);
  if (badge) badge.textContent = keys.length;
  if (keys.length===0) {
    list.innerHTML=''; list.appendChild(empty); empty.style.display=''; return;
  }
  list.innerHTML='';
  keys.forEach(id => {
    const f    = favs[id];
    const cls  = f.cls||getCls(f.type||'');
    const item = document.createElement('div');
    item.className = `fav-item ${cls}`;
    item.innerHTML = `
      <div class="fav-emoji">${f.icon||'💪'}</div>
      <div class="fav-info">
        <div class="fav-name" title="${f.name}">${f.name}</div>
        <div class="fav-meta">
          <span class="fav-cat-pill ${cls}">${(f.type||'').replace(/_homme/i,'').replace(/_femme/i,'').replace(/_/g,' ').trim().split(' ')[0]||'Sport'}</span>
        </div>
      </div>
      <div class="fav-actions">
        <button class="btn-fav-select" onclick="selectFromFav('${id}')" title="Sélectionner">+ Ajouter</button>
        <button class="btn-fav-remove" onclick="removeFav('${id}')" title="Retirer">✕</button>
      </div>`;
    list.appendChild(item);
  });
}

function getCls(type) {
  const t=(type||'').toLowerCase();
  if (t.includes('cardio'))     return 'cardio';
  if (t.includes('souplesse'))  return 'souplesse';
  if (t.includes('endurance'))  return 'endurance';
  if (t.includes('perte'))      return 'perte';
  return 'force';
}

function initFavs() {
  const favs=loadFavs();
  document.querySelectorAll('.fav-btn').forEach(btn=>{
    if (favs[btn.dataset.id]) { btn.classList.add('active'); btn.innerHTML='★ Favori'; }
  });
  renderFavList(favs);
}

// ══════════════════════════════════════════════════════
// QR CODE
// ══════════════════════════════════════════════════════
async function openQR(date) {
  const wrap=document.getElementById('qrImgWrap');
  const waLink=document.getElementById('qrWaLink');
  document.getElementById('qrDate').textContent='—';
  document.getElementById('qrMeta').textContent='—';
  wrap.innerHTML='<span class="qr-placeholder">Chargement…</span>';
  waLink.href='#';
  openModal('qrModal');
  let res;
  try {
    res=await fetch(API.qr(date),{method:'GET',credentials:'include',headers:{'Accept':'application/json','X-Requested-With':'XMLHttpRequest'}});
  } catch {
    wrap.innerHTML='<div style="color:#EF4444;font-size:13px;text-align:center;padding:20px">⚠ Serveur injoignable.</div>';
    showToast('error','⚠ Serveur injoignable.'); return;
  }
  if (res.status===401) { wrap.innerHTML='<div style="color:#EF4444;padding:20px;text-align:center">⚠ Session expirée.<br><a href="/login" style="color:var(--pu)">Reconnexion</a></div>'; return; }
  if (res.status===404) { wrap.innerHTML='<div style="color:#F59E0B;padding:20px;text-align:center">📭 Aucune activité pour cette date.</div>'; return; }
  const ct=res.headers.get('Content-Type')||'';
  if (!ct.includes('application/json')) { wrap.innerHTML='<div style="color:#EF4444;padding:20px;text-align:center">⚠ Erreur serveur ('+res.status+').</div>'; return; }
  let data;
  try { data=await res.json(); } catch { wrap.innerHTML='<div style="color:#EF4444;padding:20px;text-align:center">⚠ Réponse invalide.</div>'; return; }
  if (!data.success) { wrap.innerHTML='<div style="color:#EF4444;padding:20px;text-align:center">⚠ '+(data.message||'Erreur')+'</div>'; return; }
  wrap.innerHTML=`<img src="${data.qr}" alt="QR Code ${data.dateLabel}" style="width:100%;height:100%;object-fit:contain">`;
  document.getElementById('qrDate').textContent='📅 '+data.dateLabel;
  document.getElementById('qrMeta').textContent=data.nbEx+' exercice'+(data.nbEx!==1?'s':'')+' · '+data.totalMin+' min'+(data.totalCal>0?' · '+data.totalCal+' kcal':'');
  waLink.href=data.waUrl;
  showToast('success','📲 QR Code généré !');
}

// ══════════════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════════════
function formatDate(d) {
  if (!d) return '';
  return new Date(d+'T00:00:00').toLocaleDateString('fr-FR',{day:'numeric',month:'long',year:'numeric'});
}

function showToast(type,msg) {
  const t=document.getElementById('toast');
  t.className='toast '+type; t.textContent=msg; t.classList.add('show');
  clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('show'),3500);
}
</script>
{% endblock %}
