<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Rapport de bien-être — {{ user.firstName }} {{ user.lastName }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Helvetica, Arial, sans-serif; font-size: 12px; color: #1C1733; background: #fff; }

        .header { background: #6A5ACD; color: white; padding: 30px 40px; margin-bottom: 30px; }
        .header h1 { font-size: 26px; font-weight: bold; letter-spacing: 2px; }
        .header .subtitle { font-size: 13px; opacity: 0.85; margin-top: 4px; }

        .section { padding: 0 40px; margin-bottom: 24px; }
        .section-title { font-size: 15px; font-weight: bold; color: #6A5ACD; border-bottom: 2px solid #EDE8FA; padding-bottom: 6px; margin-bottom: 14px; }

        .info-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
        .info-table td { padding: 8px 12px; font-size: 12px; border-bottom: 1px solid #EDE8FA; }
        .info-table td:first-child { color: #9590B8; width: 40%; }
        .info-table td:last-child { font-weight: 600; }

        .entries-table { width: 100%; border-collapse: collapse; }
        .entries-table th { background: #6A5ACD; color: white; padding: 8px 10px; font-size: 11px; text-align: left; }
        .entries-table td { padding: 7px 10px; font-size: 11px; border-bottom: 1px solid #EDE8FA; }
        .entries-table tr:nth-child(even) td { background: #F7F5FD; }

        .ai-box { background: #F7F5FD; border-left: 4px solid #6A5ACD; padding: 20px; font-size: 12px; line-height: 1.7; white-space: pre-wrap; }

        .footer { margin-top: 40px; padding: 16px 40px; border-top: 1px solid #EDE8FA; font-size: 10px; color: #9590B8; text-align: center; }
    </style>
</head>
<body>
    <div class="header">
        <h1>HARMONIE</h1>
        <div class="subtitle">Rapport de bien-être étudiant — Confidentiel</div>
    </div>

    <div class="section">
        <div class="section-title">Informations étudiant</div>
        <table class="info-table">
            <tr><td>Nom complet</td><td>{{ user.firstName }} {{ user.lastName }}</td></tr>
            <tr><td>Email</td><td>{{ user.email }}</td></tr>
            <tr><td>Date du rapport</td><td>{{ generatedAt|date('d/m/Y à H:i') }}</td></tr>
            <tr><td>Entrées analysées</td><td>{{ stats.total }}</td></tr>
            <tr><td>Score moyen d'humeur</td><td>{{ stats.avgScore }}/5</td></tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Historique des humeurs</div>
        <table class="entries-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Humeur</th>
                    <th>Score</th>
                </tr>
            </thead>
            <tbody>
                {% for e in entries %}
                <tr>
                    <td>{{ e.dateJournal|date('d/m/Y') }}</td>
                    <td>{{ e.humeur.emoji }} {{ e.humeur.label }}</td>
                    <td>{{ e.score }}/5</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Analyse IA — Évaluation du bien-être</div>
        <div class="ai-box">{{ aiText }}</div>
    </div>

    <div class="footer">
        Rapport généré automatiquement par Harmonie le {{ generatedAt|date('d/m/Y à H:i') }} — Document confidentiel
    </div>
</body>
</html>
