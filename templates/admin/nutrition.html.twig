            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
        <div class="empty-table">
            <div style="font-size:36px;opacity:.4;margin-bottom:10px">🔍</div>
            <strong>Aucun aliment trouvé</strong><br>
            <span style="font-size:13px">Modifiez ou effacez vos filtres.</span>
        </div>
    {% endif %}

    {# ── PAGINATION MANUELLE ── #}
    <div class="n-pagination-wrap">
        <div class="n-pagination-info">
            Page <strong>{{ pagination.currentPageNumber }}</strong> /
            <strong>{{ pagination.pageCount }}</strong>
            — <strong>{{ pagination.totalItemCount }}</strong> résultat(s)
        </div>
        <nav aria-label="Pagination">
            <ul class="pagination">
                {% if pagination.currentPageNumber > 1 %}
                    <li class="page-item">
                        <a class="page-link" href="{{ path('admin_nutrition_index', filters|merge({'page': pagination.currentPageNumber - 1, 'limit': pagination.numItemsPerPage})) }}">Précédent</a>
                    </li>
                {% endif %}

                {% for i in max(1, pagination.currentPageNumber - 2)..min(pagination.pageCount, pagination.currentPageNumber + 2) %}
                    <li class="page-item {% if i == pagination.currentPageNumber %}active{% endif %}">
