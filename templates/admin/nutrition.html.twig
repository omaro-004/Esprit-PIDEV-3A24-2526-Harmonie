                        orderby:'nomAliment',
                        orderdir:(filters.sort=='nomAliment' and filters.direction=='ASC') ? 'DESC' : 'ASC',
                        page:1
                    })) }}">
                        Aliment
                        <span>{{ filters.sort=='nomAliment' ? (filters.direction=='ASC' ? '↑' : '↓') : '↕' }}</span>
                    </a>
                </th>
                <th id="th-cal" class="{% if filters.sort=='caloriesPour100g' %}sorted{% endif %}">
                    <a href="{{ path('admin_nutrition_index', filters|merge({
                        orderby:'caloriesPour100g',
                        orderdir:(filters.sort=='caloriesPour100g' and filters.direction=='ASC') ? 'DESC' : 'ASC',
                        page:1
                    })) }}">
                        Calories / 100g
                        <span>{{ filters.sort=='caloriesPour100g' ? (filters.direction=='ASC' ? '↑' : '↓') : '↕' }}</span>
                    </a>
                </th>
                <th id="th-prot" class="{% if filters.sort=='proteines' %}sorted{% endif %}">
                    <a href="{{ path('admin_nutrition_index', filters|merge({
                        orderby:'proteines',
                        orderdir:(filters.sort=='proteines' and filters.direction=='ASC') ? 'DESC' : 'ASC',
                        page:1
                    })) }}">
                        Protéines
                        <span>{{ filters.sort=='proteines' ? (filters.direction=='ASC' ? '↑' : '↓') : '↕' }}</span>
                    </a>
                </th>
                <th id="th-lip" class="{% if filters.sort=='lipides' %}sorted{% endif %}">
                    <a href="{{ path('admin_nutrition_index', filters|merge({
                        orderby:'lipides',
                        orderdir:(filters.sort=='lipides' and filters.direction=='ASC') ? 'DESC' : 'ASC',
                        page:1
                    })) }}">
                        Lipides
                        <span>{{ filters.sort=='lipides' ? (filters.direction=='ASC' ? '↑' : '↓') : '↕' }}</span>
                    </a>
                </th>
                <th id="th-gluc" class="{% if filters.sort=='glucides' %}sorted{% endif %}">
                    <a href="{{ path('admin_nutrition_index', filters|merge({
                        orderby:'glucides',
                        orderdir:(filters.sort=='glucides' and filters.direction=='ASC') ? 'DESC' : 'ASC',
                        page:1
                    })) }}">
                        Glucides
                        <span>{{ filters.sort=='glucides' ? (filters.direction=='ASC' ? '↑' : '↓') : '↕' }}</span>
                    </a>
                </th>
                <th>Actions</th>
            </tr>
            </thead>
            <tbody>
            {% set maxProt = stats.protMax > 0 ? stats.protMax : 1 %}
            {% set maxCal  = stats.calMax  > 0 ? stats.calMax  : 1 %}
            {% for aliment in pagination.items %}
            <tr class="row-anim" style="animation-delay:{{ loop.index0 * 0.02 }}s" id="row-{{ aliment.id }}">
                <td>
                    <span class="food-name-text">{{ aliment.nomAliment }}</span>
                    <span class="id-badge">&nbsp;#{{ aliment.id }}</span>
                </td>
                <td><span class="cal-badge">{{ aliment.caloriesPour100g }} kcal</span></td>
                <td>
                    <div class="macro-mini">
                        <div class="bar"><div class="bar-fill" style="width:{{ min([((aliment.proteines / maxProt) * 100)|round, 100]) }}%;background:#8B5CF6"></div></div>
                        <span class="val">{{ aliment.proteines }}g</span>
                    </div>
                </td>
                <td>
                    <div class="macro-mini">
                        <div class="bar"><div class="bar-fill" style="width:{{ min([((aliment.lipides / maxProt) * 100)|round, 100]) }}%;background:#F59E0B"></div></div>
                        <span class="val">{{ aliment.lipides }}g</span>
                    </div>
                </td>
                <td>
                    <div class="macro-mini">
                        <div class="bar"><div class="bar-fill" style="width:{{ min([((aliment.glucides / maxProt) * 100)|round, 100]) }}%;background:#3B82F6"></div></div>
                        <span class="val">{{ aliment.glucides }}g</span>
                    </div>
                </td>
                <td>
                    <div class="act-row">
                        <button class="btn-sm-action btn-edit-act"
                            onclick="editFoodServer({{ aliment.id }}, {{ aliment.nomAliment|json_encode }}, {{ aliment.caloriesPour100g }}, {{ aliment.proteines }}, {{ aliment.lipides }}, {{ aliment.glucides }})">
                            ✏ Modifier
                        </button>
                        <button class="btn-sm-action btn-del-act"
