        <div class="n-stat-icon" style="background:#FEF3C7;">🔥</div>
        <div>
            <div class="n-stat-val" style="font-size:18px">{{ stats.calMin }}–{{ stats.calMax }}</div>
            <div class="n-stat-lbl">Cal. min/max (100g)</div>
        </div>
    </div>
    <div class="n-stat">
        <div class="n-stat-icon" style="background:#EDE9FE;">💪</div>
        <div>
            <div class="n-stat-val">{{ stats.protMax }}g</div>
            <div class="n-stat-lbl">Max protéines</div>
        </div>
    </div>
    <div class="n-stat">
        <div class="n-stat-icon" style="background:#DBEAFE;">📊</div>
        <div>
            <div class="n-stat-val">{{ totalFiltered }}</div>
            <div class="n-stat-lbl">Résultats filtrés</div>
