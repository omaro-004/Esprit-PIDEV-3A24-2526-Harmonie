        </span>
    {% endif %}
    {% if filters.prot_min or filters.prot_max %}
        <span class="n-chip">
            💪 Prot : {{ filters.prot_min ?: '…' }} → {{ filters.prot_max ?: '…' }} g
            <a href="{{ path('admin_nutrition_index', filters|merge({prot_min:'', prot_max:'', page:1})) }}">✕</a>
        </span>
    {% endif %}
    {% if filters.id_from or filters.id_to %}
        <span class="n-chip">
            🆔 ID : {{ filters.id_from ?: '…' }} → {{ filters.id_to ?: '…' }}
            <a href="{{ path('admin_nutrition_index', filters|merge({id_from:'', id_to:'', page:1})) }}">✕</a>
