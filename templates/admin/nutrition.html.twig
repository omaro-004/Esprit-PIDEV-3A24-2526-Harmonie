</div>

{# ── TABLE CARD ── #}
<div class="n-table-card">
    <div class="n-table-head">
        <div class="n-table-title">📋 Base de données alimentaire</div>
        <div class="n-table-head-right">
            <span class="n-count-badge">
                {{ (pagination.currentPageNumber - 1) * pagination.numItemsPerPage + 1 }}–{{ min(pagination.currentPageNumber * pagination.numItemsPerPage, pagination.totalItemCount) }}
                sur {{ totalFiltered }} aliment(s)
            </span>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600">Par page :</label>
            <select class="n-per-page" onchange="changeLimit(this.value)">
                {% for opt in [10, 20, 50, 100] %}
                    <option value="{{ opt }}" {% if limit == opt %}selected{% endif %}>{{ opt }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    {% if pagination.items|length > 0 %}
    <div style="overflow-x:auto">
        <table class="n-table">
            <thead>
            <tr>
                {# Macro helper pour les liens de tri — préserve TOUS les filtres actifs #}
                <th class="{% if filters.sort=='nomAliment' %}sorted{% endif %}">
