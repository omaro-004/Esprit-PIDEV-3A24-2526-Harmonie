        <div class="n-stat-icon" style="background:#D1FAE5;">🥗</div>
        <div>
            <div class="n-stat-val">{{ stats.idMax is not null ? (stats.idMax - stats.idMin + 1) : 0 }}</div>
            <div class="n-stat-lbl">Total aliments</div>
        </div>
    </div>
