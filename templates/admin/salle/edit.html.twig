{% extends 'admin/base.html.twig' %}

{% block title %}Modifier salle — Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('harmonie/css/harmony-forms.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="admin-harmony-form-shell">
    <div class="harmony-form-card">
        <h1>{{ salle.nom }}</h1>
        {{ form_start(form, { attr: { class: 'harmony-form' } }) }}
            {{ form_row(form.nom) }}
            {{ form_row(form.capacite) }}
            {{ form_row(form.disponible) }}
            {{ form_row(form.description) }}
            {{ form_row(form.equipements) }}
            {{ form_row(form.submit) }}
        {{ form_end(form) }}
        <a href="{{ path('admin_salle_index') }}" class="harmony-form-back">← Retour à la liste</a>
    </div>
</div>
{% endblock %}
