{% extends 'admin/base.html.twig' %}

{% block title %}{{ cat ? 'Modifier' : 'Nouvelle' }} catégorie — Back Harmony{% endblock %}
{% block page_title %}{{ cat ? 'Modifier la catégorie' : 'Créer une catégorie' }}{% endblock %}

{% block stylesheets %}
<style>
.form-wrap {
    max-width: 760px;
}
.form-card {
    background: white;
    border: 1px solid rgba(106,90,205,.12);
    border-radius: 16px;
    padding: 24px;
}
.form-grid {
    display: grid;
    gap: 16px;
}
.form-label {
    display: block;
    font-size: 13px;
    color: #4A4570;
    margin-bottom: 6px;
    font-weight: 600;
}
.form-input,
.form-textarea {
    width: 100%;
    border: 1.5px solid rgba(106,90,205,.15);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 14px;
    color: #1C1733;
    background: #fff;
}
.form-input:focus,
.form-textarea:focus {
    outline: none;
    border-color: #6A5ACD;
}
.form-textarea {
    resize: vertical;
    min-height: 120px;
}
.error-box {
    margin-top: 8px;
    background: #FEF2F2;
    border: 1px solid #FECACA;
    border-radius: 10px;
    padding: 8px 10px;
    color: #B91C1C;
    font-size: 12px;
}
.form-actions {
    display: flex;
    gap: 10px;
    margin-top: 18px;
}
.btn {
    border: none;
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
}
.btn-primary { background: #6A5ACD; color: #fff; }
.btn-primary:hover { background: #4B3B9E; }
.btn-secondary {
    background: #F7F5FD;
    color: #4A4570;
    border: 1px solid rgba(106,90,205,.12);
}
.btn-secondary:hover { border-color: #8B7FD4; }
</style>
{% endblock %}

{% block body %}
<div class="form-wrap">
    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-grid">
                <div>
                    <label class="form-label">Nom de la catégorie *</label>
                    {{ form_widget(form.nomCategorie) }}
                    {% for error in form.nomCategorie.vars.errors %}
                        <div class="error-box">{{ error.message }}</div>
                    {% endfor %}
                </div>

                <div>
                    <label class="form-label">Description</label>
                    {{ form_widget(form.description) }}
                    {% for error in form.description.vars.errors %}
                        <div class="error-box">{{ error.message }}</div>
                    {% endfor %}
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('back_categories') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    {{ cat ? 'Enregistrer les modifications' : 'Créer la catégorie' }}
                </button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
