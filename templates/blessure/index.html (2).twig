{# templates/blessure/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Blessures & Récupération – Modèle Corporel Interactif{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ═══════════════════════════════════════════════════════════════
   BLESSURE – MODÈLE CORPOREL INTERACTIF
   ═══════════════════════════════════════════════════════════════ */

:root {
  --color-primary:   #4f46e5;
  --color-primary-l: #6366f1;
  --color-danger:    #ef4444;
  --color-warning:   #f59e0b;
  --color-success:   #10b981;
  --color-bg:        #0f172a;
  --color-card:      #1e293b;
  --color-border:    #334155;
  --color-text:      #f1f5f9;
  --color-muted:     #94a3b8;
}

body { background: var(--color-bg); color: var(--color-text); }

/* ─── Layout ─── */
.blessure-wrapper {
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 2rem;
  max-width: 1300px;
  margin: 2rem auto;
  padding: 0 1rem;
}

@media (max-width: 900px) {
  .blessure-wrapper { grid-template-columns: 1fr; }
}

/* ─── Header ─── */
.blessure-header {
  grid-column: 1 / -1;
  text-align: center;
  padding: 1.5rem 1rem;
  background: linear-gradient(135deg, #1e293b, #0f172a);
  border-radius: 16px;
  border: 1px solid var(--color-border);
}
.blessure-header h1 {
  font-size: 2rem;
  font-weight: 700;
  background: linear-gradient(to right, #818cf8, #6ee7b7);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin: 0 0 .4rem;
}
.blessure-header p { color: var(--color-muted); margin: 0; font-size: .95rem; }

/* ─── Panel Gauche : Silhouette ─── */
.body-panel {
  background: var(--color-card);
  border-radius: 16px;
  border: 1px solid var(--color-border);
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.body-panel h2 { font-size: 1.1rem; color: var(--color-muted); margin: 0; letter-spacing: .05em; }

/* Contexte utilisateur */
.context-bar {
  display: flex;
  gap: .75rem;
  width: 100%;
  flex-wrap: wrap;
}
.context-bar select {
  flex: 1;
  min-width: 120px;
  background: #0f172a;
  border: 1px solid var(--color-border);
  color: var(--color-text);
  border-radius: 8px;
  padding: .45rem .75rem;
  font-size: .85rem;
}
.context-bar select:focus { outline: none; border-color: var(--color-primary); }

/* SVG silhouette wrapper */
.silhouette-container {
  position: relative;
  width: 100%;
  max-width: 320px;
  margin: 0 auto;
}
.silhouette-container svg { width: 100%; height: auto; display: block; }

/* Zones cliquables */
.body-zone {
  cursor: pointer;
  transition: opacity .2s, filter .2s;
}
.body-zone:hover { opacity: .8; filter: brightness(1.3); }
.body-zone.active { filter: drop-shadow(0 0 8px #f59e0b); }
.body-zone.selected { opacity: 1; filter: drop-shadow(0 0 10px #4f46e5); }

/* Légende */
.legend {
  display: flex;
  gap: 1rem;
  font-size: .78rem;
  color: var(--color-muted);
  flex-wrap: wrap;
  justify-content: center;
}
.legend-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  display: inline-block;
  margin-right: .3rem;
  vertical-align: middle;
}

/* Tooltip */
#zone-tooltip {
  position: absolute;
  background: rgba(15,23,42,.95);
  color: #fff;
  padding: .35rem .7rem;
  border-radius: 6px;
  font-size: .8rem;
  pointer-events: none;
  display: none;
  border: 1px solid var(--color-primary);
  white-space: nowrap;
  z-index: 100;
}

/* ─── Panel Droit : Conseils ─── */
.conseils-panel {
  background: var(--color-card);
  border-radius: 16px;
  border: 1px solid var(--color-border);
  padding: 1.5rem;
  overflow-y: auto;
  max-height: 780px;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400px;
  color: var(--color-muted);
  text-align: center;
  gap: 1rem;
}
.empty-state svg { opacity: .4; }
.empty-state p { font-size: .9rem; line-height: 1.6; max-width: 260px; }

/* Loader */
.loader {
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 200px;
  gap: 1rem;
  color: var(--color-muted);
}
.spinner {
  width: 48px; height: 48px;
  border: 4px solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Résultat */
.result-header {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.25rem;
  padding-bottom: .75rem;
  border-bottom: 1px solid var(--color-border);
}
.result-icon {
  width: 44px; height: 44px;
  background: rgba(79,70,229,.2);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.4rem;
  flex-shrink: 0;
}
.result-title { font-size: 1.15rem; font-weight: 700; margin: 0 0 .2rem; }
.result-subtitle { font-size: .8rem; color: var(--color-muted); margin: 0; }

/* Cartes de conseils */
.advice-section { margin-bottom: 1.25rem; }
.advice-section-title {
  display: flex;
  align-items: center;
  gap: .5rem;
  font-size: .85rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--color-muted);
  margin-bottom: .6rem;
}
.advice-section-title .icon { font-size: 1rem; }

.advice-list {
  list-style: none;
  padding: 0; margin: 0;
  display: flex;
  flex-direction: column;
  gap: .45rem;
}
.advice-list li {
  background: rgba(255,255,255,.04);
  border-left: 3px solid var(--color-primary);
  padding: .55rem .75rem;
  border-radius: 0 8px 8px 0;
  font-size: .875rem;
  line-height: 1.5;
}
.advice-list li:before { content: '→ '; color: var(--color-primary); font-weight: 700; }

.advice-list.danger li { border-left-color: var(--color-danger); }
.advice-list.danger li:before { color: var(--color-danger); }

.advice-list.success li { border-left-color: var(--color-success); }
.advice-list.success li:before { color: var(--color-success); }

.advice-list.warning li { border-left-color: var(--color-warning); }
.advice-list.warning li:before { color: var(--color-warning); }

/* Badge durée */
.duree-badge {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  background: rgba(245,158,11,.15);
  border: 1px solid rgba(245,158,11,.4);
  color: #fbbf24;
  padding: .5rem 1rem;
  border-radius: 999px;
  font-size: .85rem;
  font-weight: 600;
  margin-top: .5rem;
}

/* Alerte médicale */
.medical-alert {
  background: rgba(239,68,68,.08);
  border: 1px solid rgba(239,68,68,.3);
  border-radius: 10px;
  padding: .75rem 1rem;
  font-size: .85rem;
  line-height: 1.6;
  color: #fca5a5;
}

/* Bouton retour */
.btn-reset {
  width: 100%;
  margin-top: 1rem;
  padding: .6rem;
  background: transparent;
  border: 1px solid var(--color-border);
  color: var(--color-muted);
  border-radius: 8px;
  cursor: pointer;
  font-size: .85rem;
  transition: all .2s;
}
.btn-reset:hover { border-color: var(--color-primary); color: var(--color-text); }
</style>
{% endblock %}

{% block body %}
