          <span class="icon">🏃</span> Exercices de récupération
        </div>
        <ul class="advice-list success" id="res-exercices"></ul>
      </div>

      {# Nutrition #}
      <div class="advice-section">
        <div class="advice-section-title">
          <span class="icon">🥗</span> Nutrition anti-inflammatoire
        </div>
        <ul class="advice-list warning" id="res-nutrition"></ul>
      </div>

      {# Durée #}
      <div class="advice-section">
        <div class="advice-section-title">
          <span class="icon">⏱️</span> Durée estimée de récupération
        </div>
        <span class="duree-badge">⌚ <span id="res-duree">–</span></span>
      </div>

      {# Quand consulter #}
      <div class="advice-section">
        <div class="advice-section-title">
          <span class="icon">🚨</span> Quand consulter un médecin
        </div>
        <div class="medical-alert" id="res-consulter">–</div>
      </div>

      <button class="btn-reset" id="btn-reset">↩ Sélectionner une autre zone</button>
    </div>{# /result-container #}

  </div>{# /conseils-panel #}

</div>{# /blessure-wrapper #}
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', () => {

  /* ── Éléments DOM ── */
  const zones        = document.querySelectorAll('.body-zone');
  const tooltip      = document.getElementById('zone-tooltip');
  const emptyState   = document.getElementById('empty-state');
  const loader       = document.getElementById('loader');
  const resultCont   = document.getElementById('result-container');
  const selActivite  = document.getElementById('sel-activite');
  const selIntensite = document.getElementById('sel-intensite');
  const btnReset     = document.getElementById('btn-reset');

  // Champs résultat
  const resIcon      = document.getElementById('res-icon');
  const resTitle     = document.getElementById('res-title');
  const resSubtitle  = document.getElementById('res-subtitle');
  const resTrait     = document.getElementById('res-traitements');
  const resExos      = document.getElementById('res-exercices');
  const resNutr      = document.getElementById('res-nutrition');
  const resDuree     = document.getElementById('res-duree');
  const resConsulter = document.getElementById('res-consulter');

  // Mapping zone → emoji
  const icons = {
    tete: '🧠', cou: '🦴',
    epaule_gauche: '💪', epaule_droite: '💪',
    coude_gauche: '🦾', coude_droit: '🦾',
    poignet_gauche: '✋', poignet_droit: '✋',
    dos_haut: '🔙', dos_bas: '🔙', thorax: '🫀', abdomen: '🫃',
    hanche_gauche: '🦵', hanche_droite: '🦵',
    genou_gauche: '🦿', genou_droit: '🦿',
    cheville_gauche: '👟', cheville_droite: '👟',
    pied_gauche: '🦶', pied_droit: '🦶',
  };

  /* ── Tooltip sur hover ── */
  zones.forEach(zone => {
    zone.addEventListener('mouseenter', e => {
      const label = zone.dataset.label;
      tooltip.textContent = label;
      tooltip.style.display = 'block';
      positionTooltip(e);
    });
    zone.addEventListener('mousemove', positionTooltip);
    zone.addEventListener('mouseleave', () => {
      tooltip.style.display = 'none';
    });

    /* ── Clic sur une zone ── */
    zone.addEventListener('click', () => {
      // Désélection précédente
      zones.forEach(z => z.classList.remove('selected'));
      zone.classList.add('selected');

      fetchAdvice(zone.dataset.zone, zone.dataset.label);
    });
  });

  function positionTooltip(e) {
    const container = document.querySelector('.silhouette-container').getBoundingClientRect();
    const svgEl     = document.getElementById('body-svg');
    const svgRect   = svgEl.getBoundingClientRect();

    // Positionnement relatif au conteneur
    const x = e.clientX - container.left + 10;
    const y = e.clientY - container.top - 30;
    tooltip.style.left = x + 'px';
    tooltip.style.top  = y + 'px';
  }

  /* ── Appel AJAX vers le contrôleur Symfony ── */
  async function fetchAdvice(articulation, label) {
    // Afficher le loader
    emptyState.style.display   = 'none';
    resultCont.style.display   = 'none';
    loader.style.display       = 'flex';

    const typeActivite = selActivite.value;
    const intensite    = selIntensite.value;

    try {
      const response = await fetch('{{ path('blessure_conseil') }}', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ articulation, typeActivite, intensite }),
      });

      const json = await response.json();

      if (!json.success) {
        throw new Error(json.error || 'Erreur inconnue');
      }

      displayResult(json.data, label);

    } catch (err) {
      loader.style.display = 'none';
      emptyState.style.display = 'flex';
      showToast('⚠️ Erreur : ' + err.message, 'error');
    }
  }

  /* ── Affichage du résultat ── */
  function displayResult(data, label) {
    loader.style.display = 'none';

    // Icône et titre
    resIcon.textContent    = icons[data.articulation] || '🩹';
    resTitle.textContent   = data.label || label;
    resSubtitle.textContent = selActivite.value.charAt(0).toUpperCase()
                             + selActivite.value.slice(1)
                             + ' – intensité ' + selIntensite.value;

    // Listes
    fillList(resTrait, data.traitements);
    fillList(resExos,  data.exercices_recuperation);
    fillList(resNutr,  data.conseils_nutrition);

    resDuree.textContent     = data.duree_recuperation || '–';
    resConsulter.textContent = data.quand_consulter    || '–';

    resultCont.style.display = 'block';
    // Scroll doux vers le résultat
    resultCont.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function fillList(ulEl, items) {
    ulEl.innerHTML = '';
    if (!Array.isArray(items) || items.length === 0) {
      ulEl.innerHTML = '<li>Aucune donnée disponible.</li>';
      return;
    }
    items.forEach(item => {
      const li = document.createElement('li');
      li.textContent = item;
      ulEl.appendChild(li);
    });
  }

  /* ── Réinitialisation ── */
  btnReset.addEventListener('click', () => {
    zones.forEach(z => z.classList.remove('selected'));
    resultCont.style.display   = 'none';
    emptyState.style.display   = 'flex';
  });

  /* ── Toast notification ── */
  function showToast(msg, type = 'info') {
    const toast = document.createElement('div');
    toast.style.cssText = `
      position: fixed; bottom: 20px; right: 20px;
      background: ${type === 'error' ? '#ef4444' : '#4f46e5'};
      color: white; padding: .75rem 1.25rem; border-radius: 10px;
      font-size: .9rem; z-index: 9999; animation: fadeIn .3s ease;
      box-shadow: 0 4px 20px rgba(0,0,0,.4);
    `;
    toast.textContent = msg;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 4000);
  }
});
</script>
{% endblock %}
