        <text x="62" y="123" text-anchor="middle" fill="white" font-size="5.5" pointer-events="none">Ép. G</text>
        <text x="138" y="123" text-anchor="middle" fill="white" font-size="5.5" pointer-events="none">Ép. D</text>
        <text x="100" y="133" text-anchor="middle" fill="white" font-size="5.5" pointer-events="none">Thorax</text>
        <text x="100" y="172" text-anchor="middle" fill="white" font-size="5.5" pointer-events="none">Abdomen</text>
        <text x="100" y="201" text-anchor="middle" fill="white" font-size="5" pointer-events="none">Lombaires</text>
        <text x="49" y="190" text-anchor="middle" fill="white" font-size="5" pointer-events="none">Coude</text>
        <text x="151" y="190" text-anchor="middle" fill="white" font-size="5" pointer-events="none">Coude</text>
        <text x="49" y="240" text-anchor="middle" fill="white" font-size="5" pointer-events="none">Poignet</text>
        <text x="151" y="240" text-anchor="middle" fill="white" font-size="5" pointer-events="none">Poignet</text>
