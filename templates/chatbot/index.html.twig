{% extends "base.html.twig" %}

{% block title %}Harmonie Assistant{% endblock %}

{% block body %}
<style>
    .page-wrapper {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }
    .chatbot-container {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 560px;
        height: 85vh;
        max-height: 800px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,.3);
        overflow: hidden;
    }
    .chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .chat-header h1 { font-size: 20px; font-weight: 600; margin: 0; }
    .chat-header p { font-size: 12px; opacity: .85; margin: 0; }
    .header-logo { font-size: 28px; }
    .api-badge {
        margin-left: auto;
        background: rgba(255,255,255,.2);
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 12px;
    }
    .messages-container {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
        background: linear-gradient(180deg, #f8f9fb 0%, #f0f1f7 100%);
    }
    .messages-container::-webkit-scrollbar { width: 5px; }
    .messages-container::-webkit-scrollbar-thumb { background: #ddd; border-radius: 3px; }
    .message { display: flex; gap: 10px; animation: slideIn .3s ease; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .message.user { justify-content: flex-end; }
    .message-content {
        max-width: 85%;
        padding: 12px 16px;
        border-radius: 14px;
        font-size: 14px;
        line-height: 1.55;
        word-break: break-word;
    }
    .user .message-content {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 18px 18px 4px 18px;
    }
    .bot .message-content {
        background: #e8e9f3;
        color: #333;
        border-radius: 18px 18px 18px 4px;
    }
    .bot .message-content h1, .bot .message-content h2, .bot .message-content h3 {
        font-size: 14px; font-weight: 700; margin: 8px 0 4px;
    }
    .bot .message-content ul, .bot .message-content ol { padding-left: 18px; margin: 6px 0; }
    .bot .message-content li { margin: 3px 0; }
    .bot .message-content code {
        background: rgba(102,126,234,.12);
        padding: 1px 6px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 13px;
    }
    .bot .message-content strong { color: #5146b8; }
    .typing-indicator { display: flex; gap: 5px; padding: 12px 16px; background: #e8e9f3; border-radius: 18px 18px 18px 4px; width: fit-content; }
    .typing-dot { width: 8px; height: 8px; background: #667eea; border-radius: 50%; animation: bounce 1.4s infinite; }
    .typing-dot:nth-child(2) { animation-delay: .2s; }
    .typing-dot:nth-child(3) { animation-delay: .4s; }
    @keyframes bounce { 0%,60%,100% { opacity: .3; } 30% { opacity: 1; transform: translateY(-6px); } }
    .input-area {
        display: flex;
        gap: 10px;
        padding: 14px 16px;
        background: white;
        border-top: 1px solid #e0e0e0;
    }
    .input-area input {
        flex: 1;
        padding: 11px 16px;
        border: 1px solid #ddd;
        border-radius: 25px;
        font-size: 14px;
        outline: none;
        font-family: inherit;
        transition: border-color .2s;
    }
    .input-area input:focus { border-color: #667eea; }
    .input-area button {
        width: 44px; height: 44px;
        border: none;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        display: flex; align-items: center; justify-content: center;
        transition: transform .2s;
    }
    .input-area button:hover { transform: scale(1.05); }
    .input-area button:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .welcome-box { padding: 4px 0; }
    .welcome-box h2 { color: #667eea; font-size: 17px; margin: 0 0 8px; }
    .welcome-box p { font-size: 13px; color: #555; margin: 0 0 10px; }
    .cmd-list { font-size: 12px; background: white; padding: 12px; border-radius: 8px; border-left: 3px solid #667eea; }
    .cmd-list strong { color: #667eea; display: block; margin-bottom: 5px; }
    .cmd-item { color: #666; margin: 3px 0; padding-left: 8px; }
    .refresh-banner {
        font-size: 12px; color: #667eea; text-align: center;
        padding: 6px 0; cursor: pointer; user-select: none;
    }
    .refresh-banner:hover { text-decoration: underline; }
</style>

<div class="page-wrapper">
    <div class="chatbot-container">
        <div class="chat-header">
            <span class="header-logo">🎯</span>
            <div>
                <h1>Harmonie Assistant</h1>
                <p>Gérez événements &amp; tâches en langage naturel</p>
            </div>
            <span class="api-badge" id="apiBadge">⚡ Groq / Llama</span>
        </div>

        <div class="messages-container" id="messagesContainer">
            <div class="message bot">
                <div class="message-content">
                    <div class="welcome-box">
                        <h2>Bonjour ! 👋</h2>
                        <p>Je suis connecté à votre calendrier et vos tâches en temps réel. Essayez :</p>
                        <div class="cmd-list">
                            <strong>📅 Événements</strong>
                            <div class="cmd-item">• "Ajoute une réunion demain à 14h"</div>
                            <div class="cmd-item">• "Qu'est-ce que j'ai prévu cette semaine ?"</div>
                            <div class="cmd-item">• "Supprime mon cours de vendredi"</div>
                            <strong style="margin-top:10px;">✅ Tâches Kanban</strong>
                            <div class="cmd-item">• "Ajoute une tâche urgente : rendre le rapport"</div>
                            <div class="cmd-item">• "Quelles tâches sont en cours ?"</div>
                            <div class="cmd-item">• "Marque 'envoyer le mail' comme terminée"</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="input-area">
            <input type="text" id="userInput" placeholder="Écrivez votre demande..." autocomplete="off">
            <button id="sendBtn">➤</button>
        </div>
    </div>
</div>

<style>
    @keyframes slideIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
    .confirm-card {
        background: linear-gradient(135deg,#f8f7ff,#fff); border: 2px solid #667eea;
        border-radius: 16px; padding: 16px; margin: 4px 0; animation: slideIn .3s ease;
    }
    .confirm-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
    .confirm-icon { font-size:22px; }
    .confirm-title { font-weight:700; color:#5146b8; font-size:14px; }
    .confirm-subtitle { font-size:11px; color:#9590b8; margin-top:1px; }
    .confirm-rows { display:flex; flex-direction:column; gap:6px; margin-bottom:14px; }
    .confirm-row {
        display:flex; align-items:baseline; gap:10px;
        padding:7px 12px; background:white; border-radius:10px;
        border:1px solid rgba(102,126,234,.15);
    }
    .confirm-row-label { font-size:10px; font-weight:700; color:#9590b8; text-transform:uppercase; letter-spacing:.5px; min-width:60px; flex-shrink:0; }
    .confirm-row-val {
        font-size:13.5px; color:#1c1733; font-weight:500; flex:1;
        outline:none; border:none; background:transparent; font-family:inherit;
        cursor:text; padding:0; min-width:0;
    }
    .confirm-row-val:focus { color:#667eea; }
    .confirm-actions { display:flex; gap:10px; }
    .confirm-ok {
        flex:1; padding:11px; border:none; border-radius:11px;
        background:linear-gradient(135deg,#667eea,#764ba2); color:white;
        font-weight:700; font-size:14px; cursor:pointer; transition:opacity .15s;
    }
    .confirm-ok:hover { opacity:.88; }
    .confirm-cancel {
        padding:11px 16px; border:1.5px solid #ddd; border-radius:11px;
        background:white; color:#888; font-size:14px; cursor:pointer;
    }
    .confirm-cancel:hover { background:#f5f5f5; }
    .confirm-delete-warn {
        background:#fef2f2; border:1.5px solid #fca5a5; border-radius:10px;
        padding:10px 13px; color:#b91c1c; font-size:13.5px; margin-bottom:12px;
    }
</style>
<script>
(function () {
    const chatUrl = '{{ path('api_chat') }}';
    const container = document.getElementById('messagesContainer');
    const input = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const apiBadge = document.getElementById('apiBadge');

    let history = [];
    let waiting = false;

    input.addEventListener('keypress', function (e) { if (e.key === 'Enter' && !waiting) send(); });
    sendBtn.addEventListener('click', function () { if (!waiting) send(); });

    function send() {
        const msg = input.value.trim();
        if (!msg) return;
        addMessage(msg, 'user', false);
        input.value = '';
        setWaiting(true);
        showTyping();
        callApi({ userMessage: msg, history: history, model: 'gemini-2.5-flash-lite' }, msg);
    }

    function callApi(payload, originalMsg) {
        fetch(chatUrl, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            removeTyping();
            if (data.error) {
                addMessage('❌ ' + data.error, 'bot', false);
            } else if (data.pendingAction) {
                const reply = data.message || '';
                if (reply) addMessage(reply, 'bot', true);
                showConfirmCard(data.pendingAction, payload.userMessage, payload.history);
                if (originalMsg) {
                    history.push({ role: 'user',  parts: [{ text: originalMsg }] });
                    history.push({ role: 'model', parts: [{ text: reply }] });
                    if (history.length > 40) history = history.slice(-40);
                }
            } else {
                const replyText = data.message || '';
                addMessage(replyText, 'bot', true);
                if (originalMsg) {
                    history.push({ role: 'user',  parts: [{ text: originalMsg }] });
                    history.push({ role: 'model', parts: [{ text: replyText }] });
                    if (history.length > 40) history = history.slice(-40);
                }
                if (data.dataChanged) {
                    apiBadge.textContent = '🔄 Données mises à jour';
                    setTimeout(function () { location.reload(); }, 1500);
                }
            }
        })
        .catch(function (err) { removeTyping(); addMessage('❌ Erreur réseau: ' + err.message, 'bot', false); })
        .finally(function () { setWaiting(false); });
    }

    function row(label, name, value, opts) {
        var val = esc(value||'');
        if (opts) {
            var options = opts.map(function(o){ return '<option value="'+o[0]+'"'+(o[0]===(value||'')?'selected':'')+'>'+o[1]+'</option>'; }).join('');
            return '<div class="confirm-row"><span class="confirm-row-label">'+label+'</span><select class="confirm-row-val" name="'+name+'">'+options+'</select></div>';
        }
        return '<div class="confirm-row"><span class="confirm-row-label">'+label+'</span><input class="confirm-row-val" name="'+name+'" value="'+val+'" spellcheck="false"></div>';
    }
    function eventRows(d) {
        return row('Titre','title',d.title)+row('Début','startTime',d.startTime)+row('Fin','endTime',d.endTime)+row('Lieu','location',d.location)+row('Type','eventType',d.eventType||'autre',[['cours','Cours'],['reunion','Réunion'],['loisir','Loisir'],['autre','Autre']])+row('Mode','lieuType',d.lieuType||'en_ligne',[['en_ligne','En ligne'],['presentiel','Présentiel']]);
    }
    function taskRows(d) {
        return row('Titre','title',d.title||d.nom)+row('Échéance','dueDate',d.dueDate)+row('Priorité','priority',d.priority||'moyenne',[['haute','🔴 Haute'],['moyenne','🟡 Moyenne'],['basse','🟢 Basse']])+row('Statut','statut',d.statut||'A_FAIRE',[['A_FAIRE','À faire'],['EN_COURS','En cours'],['TERMINEE','Terminée']])+row('Notes','notes',d.notes);
    }
    function readRows(card, fields) {
        var result = {};
        fields.forEach(function(f){ var el = card.querySelector('[name="'+f+'"]'); result[f] = el ? el.value.trim() : ''; });
        return result;
    }

    function showConfirmCard(pendingAction, userMsg, hist) {
        var action   = pendingAction.action;
        var data     = pendingAction.data || {};
        var isDelete = action.indexOf('DELETE_') === 0;
        var isEvent  = action.indexOf('EVENT') !== -1;

        var icons  = { ADD_EVENT:'📅', UPDATE_EVENT:'✏️', DELETE_EVENT:'🗑️', ADD_TASK:'✅', UPDATE_TASK:'✏️', DELETE_TASK:'🗑️' };
        var titles = { ADD_EVENT:'Nouvel événement', UPDATE_EVENT:"Modifier l'événement", DELETE_EVENT:"Supprimer l'événement", ADD_TASK:'Nouvelle tâche', UPDATE_TASK:'Modifier la tâche', DELETE_TASK:'Supprimer la tâche' };

        var card = document.createElement('div');
        card.className = 'message bot';
        var inner = document.createElement('div');
        inner.className = 'message-content confirm-card';
        inner.innerHTML = '<div class="confirm-header"><span class="confirm-icon">'+(icons[action]||'📌')+'</span><div><div class="confirm-title">'+(titles[action]||action)+'</div><div class="confirm-subtitle">Vérifiez et modifiez si besoin, puis confirmez</div></div></div>';

        if (isDelete) {
            inner.innerHTML += '<div class="confirm-delete-warn">⚠️ <strong>'+esc(data.title||data.nom||'Cet élément')+'</strong> sera supprimé définitivement.</div>';
        } else {
            var rowsDiv = document.createElement('div');
            rowsDiv.className = 'confirm-rows';
            rowsDiv.innerHTML = isEvent ? eventRows(data) : taskRows(data);
            inner.appendChild(rowsDiv);
        }

        var acts = document.createElement('div');
        acts.className = 'confirm-actions';
        var okBtn = document.createElement('button');
        okBtn.className = 'confirm-ok';
        okBtn.textContent = isDelete ? '🗑️ Supprimer' : '✅ Confirmer';
        okBtn.addEventListener('click', function () {
            var confirmed = isDelete ? data : readRows(inner, isEvent ? ['title','startTime','endTime','location','description','eventType','lieuType'] : ['title','dueDate','priority','statut','notes']);
            card.remove();
            addMessage('✅ Confirmé !', 'user', false);
            setWaiting(true); showTyping();
            callApi({ userMessage: userMsg||'', history: hist||[], model:'gemini-2.5-flash-lite', confirmed:true, confirmedData:confirmed, pendingAction:pendingAction }, null);
        });
        var cancelBtn = document.createElement('button');
        cancelBtn.className = 'confirm-cancel';
        cancelBtn.textContent = 'Annuler';
        cancelBtn.addEventListener('click', function () { card.remove(); addMessage('ℹ️ Action annulée.', 'bot', false); });
        acts.appendChild(okBtn); acts.appendChild(cancelBtn);
        inner.appendChild(acts);
        card.appendChild(inner);
        container.appendChild(card);
        container.scrollTop = container.scrollHeight;
    }

    function addMessage(text, sender, isMarkdown) {
        const wrap = document.createElement('div');
        wrap.className = 'message ' + sender;
        const content = document.createElement('div');
        content.className = 'message-content';
        if (isMarkdown) { content.innerHTML = markdownToHtml(text); } else { content.textContent = text; }
        wrap.appendChild(content); container.appendChild(wrap); container.scrollTop = container.scrollHeight;
    }
    function showTyping() {
        const wrap = document.createElement('div'); wrap.className = 'message bot'; wrap.id = 'typing-indicator';
        wrap.innerHTML = '<div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>';
        container.appendChild(wrap); container.scrollTop = container.scrollHeight;
    }
    function removeTyping() { const el = document.getElementById('typing-indicator'); if (el) el.remove(); }
    function setWaiting(val) { waiting = val; sendBtn.disabled = val; input.disabled = val; }
    function esc(str) { return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
    function markdownToHtml(text) {
        return text
            .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
            .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\*(.*?)\*/g,'<em>$1</em>')
            .replace(/`([^`]+)`/g,'<code>$1</code>').replace(/^### (.+)$/gm,'<h3>$1</h3>')
            .replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>')
            .replace(/^- (.+)$/gm,'<li>$1</li>').replace(/(<li>.*<\/li>)/gs,'<ul>$1</ul>')
            .replace(/\n{2,}/g,'<br><br>').replace(/\n/g,'<br>');
    }
})();
</script>
{% endblock %}
