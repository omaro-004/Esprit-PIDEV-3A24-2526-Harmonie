{% extends 'base.html.twig' %}

{% block title %}Modifier l’événement — Harmony{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('harmonie/css/harmony-theme.css') }}" rel="stylesheet">
    <link href="{{ asset('harmonie/css/harmony-forms.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
{% include ‘_planning_topbar.html.twig’ %}
<main class="page">
<div class="harmony-form-page">
    <div class="harmony-form-card">
        <h1>Modifier l’événement</h1>
        {{ include(‘evenement/_form.html.twig’) }}
        <a href="{{ path(‘app_evenement_index’) }}" class="harmony-form-back">← Retour au calendrier</a>
    </div>
    <div class="harmony-form-delete-wrap">
        {{ include(‘evenement/_delete_form.html.twig’) }}
    </div>
</div>
</main>
{% endblock %}
