<script>
// ── LIKE AJAX ──
async function toggleLike(btn) {
    const postId = btn.dataset.postId;
    try {
        const res  = await fetch(`/forum/post/${postId}/like`, {method:'POST',headers:{'X-Requested-With':'XMLHttpRequest','Content-Type':'application/x-www-form-urlencoded'},body:'_token='});
        const data = await res.json();
        if (data.liked) { btn.classList.add('active'); btn.innerHTML = '❤️ <span class="like-count">'+data.count+'</span>'; }
        else { btn.classList.remove('active'); btn.innerHTML = '🤍 <span class="like-count">'+data.count+'</span>'; }
    } catch(e) { console.error(e); }
}

// ── TOGGLE COMMENTAIRES ──
function toggleComments(id, btn) {
    const s = document.getElementById(id);
    const isOpen = s.style.display === 'block';
    s.style.display = isOpen ? 'none' : 'block';
}

// ── VALIDATION COMMENTAIRE ──
function validateComment(form) {
    const ta = form.querySelector('textarea');
    const old = form.querySelector('.comment-error-msg');
    if (old) old.remove();
    if (ta.value.trim().length < 3) {
        ta.style.borderColor = '#E05252';
        const err = document.createElement('div');
        err.className = 'comment-error-msg';
        err.style.cssText = 'color:#E05252;font-size:12px;font-weight:600;margin-top:6px;';
        err.textContent = '⚠️ Le commentaire doit contenir au moins 3 caractères.';
        ta.insertAdjacentElement('afterend', err);
        return false;
    }
    ta.style.borderColor = '';
    return true;
}

// ── TRADUCTION ──
let pendingTrans = {};
function toggleTranslateMenu(postId) {
    const menu = document.getElementById('translate-menu-'+postId);
    const isOpen = menu.style.display === 'block';
    document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
    if (!isOpen) menu.style.display = 'block';
}
document.addEventListener('click', function(e) {
    if (!e.target.closest('[id^="translate-wrap-"]')) {
        document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
    }
});
async function translatePost(postId, langCode, langLabel) {
    document.getElementById('translate-menu-'+postId).style.display = 'none';
    const fd = new FormData();
    fd.append('lang', langCode);
    const res  = await fetch(`/forum/post/${postId}/translate`, {method:'POST',body:fd});
    const data = await res.json();
    if (data.error) return;
    document.getElementById('titre-'+postId).textContent   = data.titre;
    document.getElementById('contenu-'+postId).textContent = data.contenu;
    document.getElementById('lang-badge-'+postId).style.display = 'block';
    document.getElementById('lang-name-'+postId).textContent = langLabel;
}
function resetTranslation(postId, titre, contenu) {
    document.getElementById('titre-'+postId).textContent   = titre;
    document.getElementById('contenu-'+postId).textContent = contenu;
    document.getElementById('lang-badge-'+postId).style.display = 'none';
}

// ── MODALE SUPPRESSION ──
let pendingForm = null;
function openModal(btn, title, message) {
    pendingForm = btn.closest('form');
    document.getElementById('modalTitle').textContent   = title;
    document.getElementById('modalMessage').textContent = message;
    document.getElementById('confirmModal').style.display = 'flex';
}
function closeModal() {
    document.getElementById('confirmModal').style.display = 'none';
    pendingForm = null;
}
document.getElementById('modalConfirmBtn').addEventListener('click', function() {
    if (pendingForm) pendingForm.submit();
    closeModal();
});
document.getElementById('confirmModal').addEventListener('click', function(e) {
    if (e.target===this) closeModal();
});

// ── IMAGE IA ──
function openImageModal()  { document.getElementById('imageModal').style.display='flex'; }
function closeImageModal() { document.getElementById('imageModal').style.display='none'; }
document.getElementById('imageModal').addEventListener('click', function(e) { if(e.target===this) closeImageModal(); });
async function generateImage() {
    const prompt = document.getElementById('imagePrompt').value.trim();
    if (!prompt) { showImgError('Merci de décrire l\'image.'); return; }
    const btn = document.getElementById('generateBtn');
    btn.disabled=true; btn.textContent='⏳ Génération...';
    document.getElementById('imageLoading').style.display='block';
    document.getElementById('imageResult').style.display='none';
    document.getElementById('imageError').style.display='none';
    try {
        const fd=new FormData(); fd.append('prompt',prompt); fd.append('style','');
        const res=await fetch('{{ path("forum_generate_image") }}',{method:'POST',body:fd});
        const data=await res.json();
        document.getElementById('imageLoading').style.display='none';
        if(data.error){showImgError(data.error);resetImgBtn();return;}
        const src='data:image/png;base64,'+data.image;
        document.getElementById('generatedImg').src=src;
        document.getElementById('downloadBtn').href=src;
        document.getElementById('imageResult').style.display='block';
        resetImgBtn();
    } catch(e){document.getElementById('imageLoading').style.display='none';showImgError('Erreur réseau.');resetImgBtn();}
}
function showImgError(msg){const el=document.getElementById('imageError');el.textContent='❌ '+msg;el.style.display='block';}
function resetImgBtn(){const b=document.getElementById('generateBtn');b.disabled=false;b.textContent='🎨 Générer l\'image';}
function resetImageModal(){document.getElementById('imageResult').style.display='none';document.getElementById('imageError').style.display='none';document.getElementById('imagePrompt').value='';}

// ── AUTO-OUVRIR COMMENTAIRES APRÈS ERREUR ──
(function(){
    const params=new URLSearchParams(window.location.search);
    const openPost=params.get('open_post');
    if(openPost){
        const s=document.getElementById('comments-'+openPost);
        if(s) s.style.display='block';
    }
})();
</script>
{% endblock %}


