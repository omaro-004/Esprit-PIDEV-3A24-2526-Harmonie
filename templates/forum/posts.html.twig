<script>
// ── LIKE ──
async function toggleLike(btn) {
    const postId = btn.dataset.postId;
    try {
        const res = await fetch(`/forum/post/${postId}/like`, {
            method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','Content-Type':'application/x-www-form-urlencoded'}, body:'_token='
        });
        const data = await res.json();
        if (data.liked) { btn.classList.add('liked'); btn.innerHTML='❤️ <span class="like-count">'+data.count+'</span>'; }
        else { btn.classList.remove('liked'); btn.innerHTML='🤍 <span class="like-count">'+data.count+'</span>'; }
    } catch(e) { console.error(e); }
}


// ── AUTO OPEN ──
(function(){
    const params = new URLSearchParams(window.location.search);
    const openPost = params.get('open_post');
    if (openPost) {
        const section = document.getElementById('comments-' + openPost);
        const btn = document.querySelector(`[onclick*="comments-${openPost}"]`);
        if (section) { section.classList.add('open'); if(btn) btn.classList.add('open'); }
    }
})();


// ── TOGGLE COMMENTAIRES ──
function toggleComments(id, btn) {
    const section = document.getElementById(id);
    const isOpen = section.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
}


// ── VALIDATION ──
function validateComment(form) {
    const ta = form.querySelector('textarea');
    const oldError = form.querySelector('.comment-error-msg');
    if (oldError) oldError.remove();
    if (ta.value.trim().length < 3) {
        ta.classList.add('error'); ta.focus();
        const e = document.createElement('div');
        e.className='comment-error-msg';
        e.style.cssText='color:#FF6B6B;font-size:12px;font-weight:600;margin-top:5px;';
        e.textContent='⚠️ Minimum 3 caractères.';
        ta.insertAdjacentElement('afterend', e);
        return false;
    }
    ta.classList.remove('error'); return true;
}


// ── MODALE CONFIRM ──
let pendingForm = null;
function openModal(btn, title, message) {
    pendingForm = btn.closest('form');
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalMessage').textContent = message;
    document.getElementById('confirmModal').style.display = 'flex';
}
function closeModal() { document.getElementById('confirmModal').style.display='none'; pendingForm=null; }
document.getElementById('modalConfirmBtn').addEventListener('click', function() { if(pendingForm) pendingForm.submit(); closeModal(); });
document.getElementById('confirmModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });


// ── TRADUCTION ──
function toggleTranslateMenu(postId) {
    const menu = document.getElementById('translate-menu-' + postId);
    const isOpen = menu.style.display === 'block';
    document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
    if (!isOpen) menu.style.display = 'block';
}
document.addEventListener('click', function(e) {
    if (!e.target.closest('[id^="translate-wrap-"]'))
        document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
});
async function translatePost(postId, langCode, langLabel) {
    document.getElementById('translate-menu-' + postId).style.display = 'none';
    const btn = document.getElementById('translate-btn-' + postId);
    btn.innerHTML = '⏳ Traduction…'; btn.disabled = true;
    try {
        const fd = new FormData(); fd.append('lang', langCode);
        const res = await fetch(`/forum/post/${postId}/translate`, {method:'POST', body:fd});
        const data = await res.json();
        if (data.error) { btn.innerHTML='❌ Erreur'; btn.disabled=false; return; }
        document.getElementById('titre-' + postId).textContent   = data.titre;
        document.getElementById('contenu-' + postId).textContent = data.contenu;
        document.getElementById('lang-badge-' + postId).style.display = 'block';
        document.getElementById('lang-name-' + postId).textContent = langLabel;
        btn.innerHTML = '<div class="ia-badge-dot"></div> 🌍 Traduit ✓'; btn.disabled=false;
    } catch(e) { btn.innerHTML='❌ Erreur'; btn.disabled=false; }
}
function resetTranslation(postId, t, c) {
    document.getElementById('titre-' + postId).textContent = t;
    document.getElementById('contenu-' + postId).textContent = c;
    document.getElementById('lang-badge-' + postId).style.display = 'none';
    document.getElementById('translate-btn-' + postId).innerHTML = '<div class="ia-badge-dot"></div> 🌍 Traduire';
}


// ── RÉSUMÉ IA ──
function resumeDiscussion(postId) {
    document.getElementById('resumeModal-' + postId).style.display = 'flex';
    document.getElementById('resumeContent-' + postId).innerHTML =
        '<div style="text-align:center;padding:20px;color:#6C47FF;"><div style="font-size:28px;animation:spin 1.5s linear infinite;display:inline-block;">⚙️</div><div style="margin-top:8px;font-size:13px;font-weight:600;">Génération du résumé…</div><div style="font-size:11px;color:#8A8AA8;margin-top:4px;">Groq · LLaMA 3.3</div></div>';
    fetch('/forum/post/' + postId + '/summarize', {
        method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','Content-Type':'application/json'}
    })
    .then(r => r.json())
    .then(data => {
        document.getElementById('resumeContent-' + postId).innerHTML =
            data.error
            ? '<div style="color:#FF6B6B;">❌ ' + data.error + '</div>'
            : '<div style="line-height:1.75;">' + data.summary + '</div>';
    })
    .catch(err => {
        document.getElementById('resumeContent-' + postId).innerHTML = '<div style="color:#FF6B6B;">❌ Erreur réseau</div>';
    });
}
function closeResumeModal(postId) {
    document.getElementById('resumeModal-' + postId).style.display = 'none';
}


// ── ANALYSE SENTIMENT ──
async function analyzeSentiment(commentId, btn) {
    btn.innerHTML = '⏳'; btn.disabled = true;
    try {
        const res = await fetch(`/forum/comment/${commentId}/sentiment`, {
            method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}
        });
        const data = await res.json();
        const resultEl = document.getElementById('sentiment-result-' + commentId);
        if (data.error) { resultEl.innerHTML='❌'; btn.style.display='none'; return; }
        const palette = {
            'positif': {bg:'rgba(107,203,119,.15)',color:'#2d8c3e',border:'rgba(107,203,119,.4)'},
            'negatif': {bg:'rgba(255,107,107,.15)',color:'#c0392b',border:'rgba(255,107,107,.4)'},
            'neutre':  {bg:'rgba(255,217,61,.15)', color:'#B8860B',border:'rgba(255,217,61,.4)'}
        };
        const p = palette[data.sentiment] ?? {bg:'#EDE9FF',color:'#6C47FF',border:'rgba(108,71,255,.3)'};
        resultEl.innerHTML = `<span style="background:${p.bg};color:${p.color};border:1.5px solid ${p.border};
            padding:4px 12px;border-radius:20px;font-weight:700;font-size:11px;display:inline-flex;align-items:center;gap:4px;">
            ${data.emoji} ${data.sentiment} · ${data.score}%</span>`;
        btn.style.display = 'none';
    } catch(e) {
        document.getElementById('sentiment-result-' + commentId).textContent = '❌';
        btn.disabled = false; btn.innerHTML = '😊 Sentiment IA';
    }
}
// ── SUGGESTION DE RÉPONSE MISTRAL AI ──────────────────
async function suggestReply(postId) {
    const btn      = document.getElementById('suggest-btn-' + postId);
    const textarea = btn.closest('.add-comment-right').querySelector('textarea');

    // État chargement
    btn.innerHTML  = '⏳ Mistral génère...';
    btn.disabled   = true;

    try {
        const res  = await fetch(`/forum/post/${postId}/suggest-reply`, {
            method:  'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await res.json();

        if (data.error) {
            btn.innerHTML = '❌ Erreur';
            btn.disabled  = false;
            setTimeout(() => {
                btn.innerHTML = '<div style="width:6px;height:6px;background:currentColor;border-radius:50%;animation:pulse-dot 1.5s ease-in-out infinite;"></div> 🧠 Mistral — Suggérer une réponse';
            }, 2000);
            return;
        }

        // Injecte la suggestion dans le textarea
        textarea.value = data.suggestion;
        textarea.focus();

        // Anime le bouton en succès
        btn.innerHTML = '✅ Suggestion insérée !';
        btn.style.background = 'linear-gradient(135deg,rgba(107,203,119,.15),rgba(107,203,119,.25))';
        btn.style.color      = '#2d8c3e';
        btn.style.borderColor = 'rgba(107,203,119,.4)';

        setTimeout(() => {
            btn.innerHTML    = '<div style="width:6px;height:6px;background:currentColor;border-radius:50%;animation:pulse-dot 1.5s ease-in-out infinite;"></div> 🧠 Mistral — Suggérer une réponse';
            btn.style.background  = 'linear-gradient(135deg,rgba(14,165,233,.15),rgba(14,165,233,.25))';
            btn.style.color       = '#0369a1';
            btn.style.borderColor = 'rgba(14,165,233,.4)';
            btn.disabled          = false;
        }, 3000);

    } catch(e) {
        btn.innerHTML = '❌ Erreur réseau';
        btn.disabled  = false;
    }
}


</script>

{% endblock %}



