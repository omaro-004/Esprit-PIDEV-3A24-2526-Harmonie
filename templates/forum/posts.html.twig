{% extends 'base.html.twig' %}
{% block title %}{{ categorie.nomCategorie }} — Forum Harmony{% endblock %}


{% block stylesheets %}
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Clash+Display:wght@500;600;700&display=swap" rel="stylesheet">

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
    --purple:#6A5ACD;--purple-dark:#4B3B9E;--purple-soft:#8B7FD4;
    --purple-pale:#EDE8FA;--purple-ghost:#F7F5FD;
    --text:#1C1733;--text-mid:#4A4570;--text-muted:#9590B8;
    --border:rgba(106,90,205,.12);--white:#FFFFFF;
    --font-head:'Syne',sans-serif;--font-body:'Inter',sans-serif;
}
html,body{font-family:var(--font-body);background:var(--purple-ghost);color:var(--text);}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:200;background:var(--white);
    border-bottom:1px solid var(--border);height:62px;display:flex;
    align-items:center;padding:0 40px;gap:8px;}
.topbar-logo{display:flex;align-items:center;gap:10px;text-decoration:none;margin-right:32px;}
.logo-mark{width:34px;height:34px;border-radius:10px;object-fit:contain;}
.nav-links{display:flex;align-items:center;gap:2px;flex:1;}
.nav-link{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;
    border-radius:9px;font-size:13.5px;font-weight:500;color:var(--text-mid);
    text-decoration:none;transition:background .15s,color .15s;}
.nav-link:hover,.nav-link.active{background:var(--purple-pale);color:var(--purple);font-weight:600;}
.topbar-right{display:flex;align-items:center;gap:10px;margin-left:auto;}
.logout-btn{padding:7px 16px;border-radius:9px;border:1.5px solid rgba(239,68,68,.2);
    background:transparent;color:#E05252;font-size:13px;cursor:pointer;}
.avatar{width:36px;height:36px;border-radius:50%;background:var(--purple);
    color:white;font-family:var(--font-head);font-weight:700;font-size:14px;
    display:grid;place-items:center;}

/* ── PAGE ── */
.page-wrapper{max-width:1100px;margin:0 auto;padding:0 32px 80px;}

/* ── CAT HERO — pleine largeur ── */
.cat-hero{
    background:linear-gradient(135deg,#1a0a3e 0%,#3b1fa8 50%,#6C47FF 100%);
    padding:36px 40px;
    margin-bottom:0;
    display:flex;
    align-items:center;
    justify-content:space-between;
    position:relative;
    overflow:hidden;
    width:100%;
}
.cat-hero::before{
    content:'';position:absolute;right:-60px;top:-60px;
    width:220px;height:220px;border-radius:50%;
    background:rgba(255,255,255,.06);pointer-events:none;
}
.cat-hero::after{
    content:'';position:absolute;left:38%;bottom:-50px;
    width:140px;height:140px;border-radius:50%;
    background:rgba(255,255,255,.04);pointer-events:none;
}
.cat-hero-left{}
.cat-hero-badge{
    display:inline-flex;align-items:center;gap:6px;
    background:rgba(255,255,255,.12);
    border:1px solid rgba(255,255,255,.2);
    border-radius:20px;padding:4px 12px;
    font-size:11px;font-weight:600;
    color:rgba(255,255,255,.85);
    margin-bottom:12px;letter-spacing:.4px;
}
.cat-hero-title{
    font-family:var(--font-head);font-size:30px;font-weight:800;
    color:white;margin-bottom:6px;line-height:1.2;
}
.cat-hero-desc{font-size:13px;color:rgba(255,255,255,.55);margin-bottom:20px;}
.cat-hero-stats{display:flex;gap:12px;}
.cat-stat{
    background:rgba(255,255,255,.1);
    border:1px solid rgba(255,255,255,.15);
    border-radius:12px;padding:10px 18px;text-align:center;
}
.cat-stat-val{font-family:var(--font-head);font-size:22px;font-weight:800;color:white;line-height:1;}
.cat-stat-lbl{font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.6px;margin-top:3px;}
.cat-hero-right{
    display:flex;flex-direction:column;
    align-items:flex-end;gap:10px;
    position:relative;z-index:1;
}
.btn-hero-primary{
    display:inline-flex;align-items:center;gap:8px;
    background:white;color:#4B2FCC;border:none;
    border-radius:11px;padding:12px 22px;
    font-size:13px;font-weight:700;cursor:pointer;
    font-family:var(--font-body);white-space:nowrap;
    transition:opacity .15s;
}
.btn-hero-primary:hover{opacity:.9;}
.btn-hero-secondary{
    display:inline-flex;align-items:center;gap:8px;
    background:rgba(255,255,255,.12);
    color:rgba(255,255,255,.8);
    border:1px solid rgba(255,255,255,.2);
    border-radius:11px;padding:10px 18px;
    font-size:12px;font-weight:500;cursor:pointer;
    font-family:var(--font-body);text-decoration:none;
    transition:background .15s;
}
.btn-hero-secondary:hover{background:rgba(255,255,255,.2);}

/* ── BREADCRUMB ── */
.breadcrumb{
    display:flex;align-items:center;gap:8px;
    font-size:13px;color:var(--text-muted);
    padding:18px 0 20px;
}
.breadcrumb a{color:var(--purple);text-decoration:none;font-weight:500;}
.breadcrumb a:hover{text-decoration:underline;}

/* ── LAYOUT PRINCIPAL ── */
.main-layout{
    display:grid;
    grid-template-columns:1fr 260px;
    gap:24px;
    align-items:start;
}

/* ── TOOLBAR ── */
.toolbar{
    display:flex;align-items:center;gap:10px;
    margin-bottom:14px;flex-wrap:wrap;
}
.search-wrap{flex:1;min-width:200px;position:relative;display:flex;gap:8px;}
.search-input{
    flex:1;padding:10px 14px;
    border:1.5px solid var(--border);
    border-radius:10px;font-family:var(--font-body);
    font-size:13.5px;color:var(--text);
    background:var(--white);outline:none;
    transition:border-color .15s;
}
.search-input:focus{border-color:var(--purple);}
.search-btn{
    padding:10px 18px;background:var(--purple);color:white;
    border:none;border-radius:10px;font-size:13px;font-weight:600;
    cursor:pointer;font-family:var(--font-body);
}
.tri-group{display:flex;gap:6px;}
.btn-tri{
    padding:8px 14px;border:1.5px solid var(--border);
    border-radius:9px;background:var(--white);
    color:var(--text-mid);font-size:12px;font-weight:600;
    cursor:pointer;text-decoration:none;transition:all .15s;
}
.btn-tri:hover{border-color:var(--purple-soft);color:var(--purple);}
.btn-tri.active{background:var(--purple-pale);border-color:var(--purple);color:var(--purple);}

.results-info{font-size:12px;color:var(--text-muted);margin-bottom:14px;}

/* ── POST CARDS ── */
.posts-list{display:flex;flex-direction:column;gap:14px;}
.post-card{
    background:var(--white);border:1px solid var(--border);
    border-radius:16px;overflow:hidden;
    transition:border-color .18s,box-shadow .18s;
}
.post-card:hover{border-color:var(--purple-soft);box-shadow:0 8px 28px rgba(106,90,205,.1);}
.post-card-inner{padding:20px 24px;}
.post-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.post-author-left{display:flex;align-items:center;gap:10px;}
.post-avatar{
    width:36px;height:36px;border-radius:50%;
    background:var(--purple);color:white;
    font-size:13px;font-weight:700;
    display:grid;place-items:center;
    font-family:var(--font-head);flex-shrink:0;
}
.post-author-name{font-size:13px;font-weight:600;color:var(--text);}
.post-author-date{font-size:11px;color:var(--text-muted);}
.post-actions-top{display:flex;gap:6px;}
.btn-edit-sm{
    display:inline-flex;align-items:center;gap:4px;
    padding:5px 11px;background:var(--purple-pale);
    color:var(--purple);border:none;border-radius:8px;
    font-size:12px;font-weight:600;cursor:pointer;
    text-decoration:none;transition:background .15s;
}
.btn-edit-sm:hover{background:#ddd6f7;}
.btn-del-sm{
    display:inline-flex;align-items:center;gap:4px;
    padding:5px 11px;background:#FEF2F2;
    color:#E05252;border:none;border-radius:8px;
    font-size:12px;font-weight:600;cursor:pointer;
}
.btn-del-sm:hover{background:#fde8e8;}
.post-title{
    font-family:var(--font-head);font-size:17px;font-weight:700;
    color:var(--text);margin-bottom:7px;line-height:1.3;
}
.post-excerpt{font-size:13.5px;color:var(--text-mid);line-height:1.7;margin-bottom:14px;}
.post-image{width:100%;max-height:200px;object-fit:cover;border-radius:10px;margin-bottom:14px;}
.post-footer{
    display:flex;align-items:center;gap:8px;
    padding-top:14px;border-top:1px solid var(--purple-ghost);
    flex-wrap:wrap;
}
.pill{
    display:inline-flex;align-items:center;gap:5px;
    padding:6px 14px;border-radius:20px;
    font-size:12px;font-weight:600;cursor:pointer;
    transition:all .15s;border:1px solid;
}
.pill-like{background:#FEE2E2;color:#E05252;border-color:#fca5a5;}
.pill-like.active{background:#E05252;color:white;}
.pill-com{background:var(--purple-ghost);color:var(--text-muted);border-color:var(--border);}
.pill-trad{background:#ECFDF5;color:#059669;border-color:rgba(5,150,105,.2);}
.pill-ia{background:var(--purple-pale);color:var(--purple);border-color:rgba(106,90,205,.2);}

/* ── SIDEBAR DROITE ── */
.forum-sidebar{display:flex;flex-direction:column;gap:16px;position:sticky;top:80px;}

/* Carte Nouveau Post */
.side-card-post{
    background:#1a0a3e;
    border-radius:16px;padding:22px;
    border:1px solid rgba(108,71,255,.3);
    position:relative;overflow:hidden;
}
.side-card-post::before{
    content:'';position:absolute;top:-35px;right:-35px;
    width:110px;height:110px;border-radius:50%;
    background:rgba(108,71,255,.2);pointer-events:none;
}
.side-badge{
    display:inline-flex;align-items:center;gap:5px;
    background:rgba(108,71,255,.3);
    border:1px solid rgba(108,71,255,.4);
    border-radius:20px;padding:3px 10px;
    font-size:10px;font-weight:600;color:#c4b5fd;
    margin-bottom:12px;width:fit-content;
}
.side-title{
    font-family:var(--font-head);font-size:16px;font-weight:700;
    color:white;margin-bottom:7px;line-height:1.3;
}
.side-sub{font-size:12px;color:rgba(255,255,255,.5);line-height:1.6;margin-bottom:14px;}
.side-tips{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.side-tip{
    font-size:11px;color:rgba(255,255,255,.45);
    padding:6px 10px;
    background:rgba(255,255,255,.06);
    border-radius:7px;
    border:1px solid rgba(255,255,255,.08);
    display:flex;align-items:center;gap:7px;
}
.btn-side-primary{
    width:100%;padding:12px;border:none;border-radius:11px;
    font-size:13px;font-weight:700;cursor:pointer;
    display:flex;align-items:center;justify-content:center;gap:8px;
    font-family:var(--font-body);
    background:linear-gradient(135deg,#6C47FF,#4B2FCC);
    color:white;transition:opacity .15s;
}
.btn-side-primary:hover{opacity:.88;}
.btn-side-primary.is-link{text-decoration:none;}

/* Carte IA */
.side-card-ai{
    background:var(--white);
    border-radius:16px;padding:22px;
    border:1px solid var(--border);
}
.ai-icon-wrap{
    width:44px;height:44px;border-radius:12px;
    background:var(--purple-pale);
    display:grid;place-items:center;font-size:20px;
    margin-bottom:14px;
}
.ai-card-title{
    font-family:var(--font-head);font-size:15px;font-weight:700;
    color:var(--text);margin-bottom:6px;
}
.ai-card-sub{font-size:12px;color:var(--text-muted);line-height:1.6;margin-bottom:14px;}
.btn-side-secondary{
    width:100%;padding:11px;border-radius:11px;
    font-size:13px;font-weight:700;cursor:pointer;
    display:flex;align-items:center;justify-content:center;gap:8px;
    font-family:var(--font-body);
    background:var(--purple-pale);color:var(--purple);
    border:1.5px solid rgba(106,90,205,.2);
    transition:all .15s;
}
.btn-side-secondary:hover{background:var(--purple);color:white;}

/* ── PAGINATION ── */
.pagination{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:28px;}

/* ── MODALE CONFIRM ── */
#confirmModal{display:none;position:fixed;inset:0;z-index:1000;
    background:rgba(28,23,51,.45);backdrop-filter:blur(4px);
    align-items:center;justify-content:center;}

@keyframes fadeUp{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}
.fade{animation:fadeUp .4s ease both;}
</style>

{% endblock %}


{% block body %}
<header class="topbar">
    <a href="{{ path('homepage') }}" class="topbar-logo">
        <img src="{{ asset('images/logo.png') }}" class="logo-mark" alt="Harmony">
    </a>
    <nav class="nav-links">
        <a href="{{ path('activites') }}"  class="nav-link">🏋 Activités</a>
        <a href="{{ path('forum') }}"      class="nav-link active">💬 Forum</a>
        <a href="{{ path('taches') }}"     class="nav-link">📚 Tâches</a>
        <a href="{{ path('evenements') }}" class="nav-link">📅 Événements</a>
        <a href="{{ path('nutrition') }}"  class="nav-link">🥗 Nutrition</a>
        <a href="{{ path('meditation') }}" class="nav-link">🧘 Méditation</a>
        <a href="{{ path('journal') }}"    class="nav-link">📔 Journal</a>
        <a href="{{ path('library') }}"    class="nav-link">📖 Library</a>
    </nav>
    <div class="topbar-right">
        <button class="logout-btn">🚪 Déconnexion</button>
        <div class="avatar">{{ app.user ? app.user.getUserPrenom()|first|upper : 'U' }}</div>
    </div>
</header>


<main class="page">


    <div class="breadcrumb fade">
        <a href="{{ path('forum') }}">💬 Forum</a>
        <span>›</span>
        <span>{{ categorie.nomCategorie }}</span>
    </div>


    <div class="cat-header fade">
        <div>
            <h1>{{ categorie.nomCategorie }}</h1>
            {% if categorie.description %}<p>{{ categorie.description }}</p>{% endif %}
        </div>
        <a href="{{ path('forum_post_new', {idCat: categorie.idCategorie}) }}" class="btn-new-post">
            ✏️ Nouveau post
        </a>
    </div>


   


    {# ── TOOLBAR ── #}
    <form method="GET" action="{{ path('forum_posts', {id: categorie.idCategorie}) }}">
        <div class="toolbar fade" style="animation-delay:.1s;">
            <div class="search-wrap">
                <span class="search-icon">🔍</span>
                <input type="text" name="search" class="search-input"
                       placeholder="Rechercher dans les posts..."
                       value="{{ search }}">
            </div>
            <button type="submit" class="search-btn">Rechercher</button>
            <div class="tri-group">
                <a href="{{ path('forum_posts', {id: categorie.idCategorie, tri: 'date_desc', search: search}) }}"
                   class="btn-tri {{ tri == 'date_desc' ? 'active' }}">🕐 Récent</a>
                <a href="{{ path('forum_posts', {id: categorie.idCategorie, tri: 'date_asc', search: search}) }}"
                   class="btn-tri {{ tri == 'date_asc' ? 'active' }}">🕐 Ancien</a>
                <a href="{{ path('forum_posts', {id: categorie.idCategorie, tri: 'likes', search: search}) }}"
                   class="btn-tri {{ tri == 'likes' ? 'active' }}">🔥 Populaire</a>
            </div>
        </div>
    </form>


    <div class="results-info">
        {% if search %}
            <strong style="color:var(--v);">{{ pagination.getTotalItemCount() }}</strong> résultat(s) pour "<strong>{{ search }}</strong>"
        {% else %}
            <strong style="color:var(--v);">{{ pagination.getTotalItemCount() }}</strong> post(s) au total
        {% endif %}
    </div>


    {# ── LISTE POSTS ── #}
    <div class="posts-list">
    {% for post in posts %}
        {% set postComments = commentairesMap[post.idPost] ?? [] %}
        {% set liked = likedByMe[post.idPost] ?? false %}
        {% set nbLikes = likesMap[post.idPost] ?? 0 %}


        <div class="post-card fade" style="animation-delay:{{ loop.index * 0.06 }}s;">


            <div class="post-author-row">
                <div class="post-author-left">
                    <div class="post-avatar">{{ (usersMap[post.userId] ?? 'U')|first|upper }}</div>
                    <div>
                        <div class="post-author-name">{{ usersMap[post.userId] ?? 'Utilisateur #' ~ post.userId }}</div>
                        <div class="post-author-date">{{ post.dateCreation ? post.dateCreation|date('d/m/Y à H:i') : '' }}</div>
                    </div>
                </div>
                <div class="post-actions-top">
                    <a href="{{ path('forum_post_edit', {id: post.idPost}) }}" class="btn-edit-sm">✏️ Modifier</a>
                    <form method="POST" action="{{ path('forum_post_delete', {id: post.idPost}) }}"
                          onsubmit="return confirm('Supprimer ce post ?');" style="display:inline;">
                        <button type="submit" class="btn-del-sm">🗑</button>
                    </form>
                </div>
            </div>


            <div class="post-body">
                <div class="post-title" id="titre-{{ post.idPost }}">{{ post.titre }}</div>
                <div class="post-excerpt" id="contenu-{{ post.idPost }}">{{ post.contenu }}</div>


                {% if post.imagePath %}
                <div style="margin-top:12px;">
                    <img src="{{ asset('uploads/posts/' ~ post.imagePath) }}" alt="Image du post"
                         style="max-width:100%;max-height:280px;border-radius:12px;object-fit:cover;
                                border:1px solid var(--border);">
                </div>
                {% endif %}


                <div class="lang-badge" id="lang-badge-{{ post.idPost }}">
                    <span class="lang-badge-pill">🌍 Traduit en <span id="lang-name-{{ post.idPost }}"></span></span>
                    <button onclick="resetTranslation({{ post.idPost }}, '{{ post.titre|e('js') }}', '{{ post.contenu|e('js') }}')"
                            style="font-size:11px;background:none;border:none;color:var(--ink-muted);
                            cursor:pointer;text-decoration:underline;margin-left:6px;">Voir original</button>
                </div>
            </div>


            {# ── FOOTER AVEC BOUTONS IA TAPE-À-L'ŒIL ── #}
            <div class="post-footer">


                {# Like #}
                <button type="button" class="btn-like {{ liked ? 'liked' }}"
                    data-post-id="{{ post.idPost }}" onclick="toggleLike(this)">
                    {{ liked ? '❤️' : '🤍' }} <span class="like-count">{{ nbLikes }}</span>
                </button>


                {# Commentaires #}
                <button type="button" class="btn-comment-toggle"
                    onclick="toggleComments('comments-{{ post.idPost }}', this)">
                    💬 {{ postComments|length }} commentaire(s)
                </button>


                {# ─── TRADUCTION — BOUTON IA JAUNE ─── #}
                <div class="translate-dropdown" id="translate-wrap-{{ post.idPost }}">
                    <button type="button" class="btn-ia-translate"
                        onclick="toggleTranslateMenu({{ post.idPost }})"
                        id="translate-btn-{{ post.idPost }}">
                        <div class="ia-badge-dot"></div>
                        🌍 Traduire
                    </button>
                    <div class="lang-menu" id="translate-menu-{{ post.idPost }}">
                        <div style="font-size:10px;color:var(--ink-muted);padding:4px 8px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">Langue</div>
                        {% set langs = {'en':'🇬🇧 Anglais','ar':'🇸🇦 Arabe','es':'🇪🇸 Espagnol','de':'🇩🇪 Allemand','it':'🇮🇹 Italien'} %}
                        {% for code, label in langs %}
                        <button class="lang-btn" onclick="translatePost({{ post.idPost }}, '{{ code }}', '{{ label }}')">{{ label }}</button>
                        {% endfor %}
                    </div>
                </div>


                {# ─── RÉSUMÉ IA — BOUTON VERT ─── #}
                {% if postComments|length > 0 %}
                <button class="btn-ia-summary" onclick="resumeDiscussion({{ post.idPost }})">
                    <div class="ia-badge-dot"></div>
                    🤖 Résumé IA
                </button>
                {% endif %}


            </div>


            {# ── SECTION COMMENTAIRES ── #}
            <div class="comments-section" id="comments-{{ post.idPost }}">


                <form method="POST" action="{{ path('forum_comment_new', {idPost: post.idPost}) }}"
                      class="add-comment-form" onsubmit="return validateComment(this)">
                    <div class="add-comment-avatar">{{ app.user ? app.user.getUserPrenom()|first|upper : 'U' }}</div>
                    <div class="add-comment-right">
                        <textarea name="contenu" class="add-comment-input"
                            placeholder="Rejoindre la conversation…" rows="2"></textarea>
                        {# ── BOUTON SUGGESTION MISTRAL ── #}
                        <div class="add-comment-actions" style="display:flex;align-items:center;gap:8px;">
                            <button type="button"
                                    onclick="suggestReply({{ post.idPost }})"
                                    id="suggest-btn-{{ post.idPost }}"
                                    style="display:inline-flex;align-items:center;gap:6px;padding:6px 14px;
                                        background:linear-gradient(135deg,rgba(14,165,233,.15),rgba(14,165,233,.25));
                                        color:#0369a1;border:1.5px solid rgba(14,165,233,.4);
                                        border-radius:20px;font-size:12px;font-weight:700;cursor:pointer;
                                        transition:all .2s;font-family:var(--font-body);"
                                    title="Générer une réponse avec Mistral AI">
                                <div style="width:6px;height:6px;background:currentColor;border-radius:50%;
                                            animation:pulse-dot 1.5s ease-in-out infinite;"></div>
                                🧠 Mistral — Suggérer une réponse
                            </button>
                            <button type="submit" class="btn-send-comment">💬 Commenter</button>
                        </div>
                    </div>
                </form>


                <div class="comments-divider"></div>


                {% if postComments is empty %}
                    <div class="no-comments">Aucun commentaire — sois le premier ! 👋</div>
                {% else %}
                    {% for c in postComments %}
                    <div class="comment-row">
                        <div class="comment-thread-line"></div>
                        <div class="comment-main">
                            <div class="comment-header">
                                <div class="comment-avatar">{{ (usersMap[c.userId] ?? 'U')|first|upper }}</div>
                                <span class="comment-author">{{ usersMap[c.userId] ?? 'Utilisateur #' ~ c.userId }}</span>
                                <span class="comment-date">• {{ c.dateCommentaire ? c.dateCommentaire|date('d/m/Y à H:i') : '' }}</span>
                            </div>
                            <div class="comment-body">{{ c.contenu }}</div>


                            {# ─── ACTIONS : SENTIMENT VISIBLE + CRUD ─── #}
                            <div class="comment-actions">
                                <button class="btn-sentiment"
                                        onclick="analyzeSentiment({{ c.idCommentaire }}, this)"
                                        id="sentiment-btn-{{ c.idCommentaire }}"
                                        title="Analyser le sentiment avec l'IA">
                                    <div class="ia-badge-dot"></div>
                                    😊 Sentiment IA
                                </button>
                                <span id="sentiment-result-{{ c.idCommentaire }}"></span>
                                <a href="{{ path('forum_comment_edit', {id: c.idCommentaire}) }}" class="btn-comment-edit">✏️ Modifier</a>
                                <form method="POST" action="{{ path('forum_comment_delete', {id: c.idCommentaire}) }}"
                                      onsubmit="return confirm('Supprimer ?');" style="display:inline;">
                                    <button type="submit" class="btn-comment-delete">🗑</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    {% endfor %}


                    {# MODALE RÉSUMÉ dynamique #}
                    <div class="resume-modal" id="resumeModal-{{ post.idPost }}"
                         onclick="if(event.target===this) closeResumeModal({{ post.idPost }})">
                        <div class="resume-modal-box">
                            <div class="resume-modal-header">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <div style="width:36px;height:36px;background:rgba(255,255,255,.2);
                                        border-radius:10px;display:grid;place-items:center;font-size:18px;">🤖</div>
                                    <div>
                                        <div style="font-family:'Clash Display',sans-serif;font-size:15px;font-weight:600;">Résumé IA de la discussion</div>
                                        <div style="font-size:11px;opacity:.7;">Powered by Groq · LLaMA 3.3</div>
                                    </div>
                                </div>
                                <button onclick="closeResumeModal({{ post.idPost }})"
                                    style="background:rgba(255,255,255,.2);border:none;color:white;
                                    border-radius:50%;width:30px;height:30px;cursor:pointer;font-size:15px;">✕</button>
                            </div>
                            <div class="resume-modal-body" id="resumeContent-{{ post.idPost }}"></div>
                            <div class="resume-modal-footer">
                                <button onclick="closeResumeModal({{ post.idPost }})"
                                    style="padding:8px 20px;border-radius:20px;border:none;
                                    background:var(--v3);color:var(--v);font-weight:600;cursor:pointer;">
                                    Fermer
                                </button>
                            </div>
                        </div>
                    </div>
                {% endif %}
            </div>


        </div>
    {% else %}
        <div class="empty-state fade">
            <div style="font-size:48px;">{{ search ? '🔍' : '💬' }}</div>
            <p>{{ search ? 'Aucun post trouvé pour "' ~ search ~ '"' : 'Aucun post dans cette catégorie.' }}</p>
        </div>
    {% endfor %}
    </div>


    {{ knp_pagination_render(pagination) }}


    {# ── MODALE CONFIRMATION ── #}
    <div id="confirmModal" class="modal-overlay">
        <div class="modal-box">
            <div style="font-size:32px;text-align:center;margin-bottom:12px;">🗑️</div>
            <div style="font-family:'Clash Display',sans-serif;font-size:18px;font-weight:600;
                color:var(--ink);text-align:center;margin-bottom:8px;" id="modalTitle">Supprimer ?</div>
            <div style="font-size:13px;color:var(--ink-muted);text-align:center;margin-bottom:24px;" id="modalMessage">Cette action est irréversible.</div>
            <div style="display:flex;gap:10px;">
                <button onclick="closeModal()" style="flex:1;padding:10px;border-radius:10px;
                    border:1.5px solid var(--border);background:white;color:var(--ink-mid);
                    font-size:13px;font-weight:600;cursor:pointer;">Annuler</button>
                <button id="modalConfirmBtn" style="flex:1;padding:10px;border-radius:10px;border:none;
                    background:linear-gradient(135deg,var(--accent),#c0392b);color:white;
                    font-size:13px;font-weight:600;cursor:pointer;">🗑 Supprimer</button>
            </div>
        </div>
    </div>


</main>


<script>
// ── LIKE ──
async function toggleLike(btn) {
    const postId = btn.dataset.postId;
    try {
        const res = await fetch(`/forum/post/${postId}/like`, {
            method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','Content-Type':'application/x-www-form-urlencoded'}, body:'_token='
        });
        const data = await res.json();
        if (data.liked) { btn.classList.add('liked'); btn.innerHTML='❤️ <span class="like-count">'+data.count+'</span>'; }
        else { btn.classList.remove('liked'); btn.innerHTML='🤍 <span class="like-count">'+data.count+'</span>'; }
    } catch(e) { console.error(e); }
}


// ── AUTO OPEN ──
(function(){
    const params = new URLSearchParams(window.location.search);
    const openPost = params.get('open_post');
    if (openPost) {
        const section = document.getElementById('comments-' + openPost);
        const btn = document.querySelector(`[onclick*="comments-${openPost}"]`);
        if (section) { section.classList.add('open'); if(btn) btn.classList.add('open'); }
    }
})();


// ── TOGGLE COMMENTAIRES ──
function toggleComments(id, btn) {
    const section = document.getElementById(id);
    const isOpen = section.classList.toggle('open');
    btn.classList.toggle('open', isOpen);
}


// ── VALIDATION ──
function validateComment(form) {
    const ta = form.querySelector('textarea');
    const oldError = form.querySelector('.comment-error-msg');
    if (oldError) oldError.remove();
    if (ta.value.trim().length < 3) {
        ta.classList.add('error'); ta.focus();
        const e = document.createElement('div');
        e.className='comment-error-msg';
        e.style.cssText='color:#FF6B6B;font-size:12px;font-weight:600;margin-top:5px;';
        e.textContent='⚠️ Minimum 3 caractères.';
        ta.insertAdjacentElement('afterend', e);
        return false;
    }
    ta.classList.remove('error'); return true;
}


// ── MODALE CONFIRM ──
let pendingForm = null;
function openModal(btn, title, message) {
    pendingForm = btn.closest('form');
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalMessage').textContent = message;
    document.getElementById('confirmModal').style.display = 'flex';
}
function closeModal() { document.getElementById('confirmModal').style.display='none'; pendingForm=null; }
document.getElementById('modalConfirmBtn').addEventListener('click', function() { if(pendingForm) pendingForm.submit(); closeModal(); });
document.getElementById('confirmModal').addEventListener('click', function(e) { if(e.target===this) closeModal(); });


// ── TRADUCTION ──
function toggleTranslateMenu(postId) {
    const menu = document.getElementById('translate-menu-' + postId);
    const isOpen = menu.style.display === 'block';
    document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
    if (!isOpen) menu.style.display = 'block';
}
document.addEventListener('click', function(e) {
    if (!e.target.closest('[id^="translate-wrap-"]'))
        document.querySelectorAll('[id^="translate-menu-"]').forEach(m => m.style.display='none');
});
async function translatePost(postId, langCode, langLabel) {
    document.getElementById('translate-menu-' + postId).style.display = 'none';
    const btn = document.getElementById('translate-btn-' + postId);
    btn.innerHTML = '⏳ Traduction…'; btn.disabled = true;
    try {
        const fd = new FormData(); fd.append('lang', langCode);
        const res = await fetch(`/forum/post/${postId}/translate`, {method:'POST', body:fd});
        const data = await res.json();
        if (data.error) { btn.innerHTML='❌ Erreur'; btn.disabled=false; return; }
        document.getElementById('titre-' + postId).textContent   = data.titre;
        document.getElementById('contenu-' + postId).textContent = data.contenu;
        document.getElementById('lang-badge-' + postId).style.display = 'block';
        document.getElementById('lang-name-' + postId).textContent = langLabel;
        btn.innerHTML = '<div class="ia-badge-dot"></div> 🌍 Traduit ✓'; btn.disabled=false;
    } catch(e) { btn.innerHTML='❌ Erreur'; btn.disabled=false; }
}
function resetTranslation(postId, t, c) {
    document.getElementById('titre-' + postId).textContent = t;
    document.getElementById('contenu-' + postId).textContent = c;
    document.getElementById('lang-badge-' + postId).style.display = 'none';
    document.getElementById('translate-btn-' + postId).innerHTML = '<div class="ia-badge-dot"></div> 🌍 Traduire';
}


// ── RÉSUMÉ IA ──
function resumeDiscussion(postId) {
    document.getElementById('resumeModal-' + postId).style.display = 'flex';
    document.getElementById('resumeContent-' + postId).innerHTML =
        '<div style="text-align:center;padding:20px;color:#6C47FF;"><div style="font-size:28px;animation:spin 1.5s linear infinite;display:inline-block;">⚙️</div><div style="margin-top:8px;font-size:13px;font-weight:600;">Génération du résumé…</div><div style="font-size:11px;color:#8A8AA8;margin-top:4px;">Groq · LLaMA 3.3</div></div>';
    fetch('/forum/post/' + postId + '/summarize', {
        method:'POST', headers:{'X-Requested-With':'XMLHttpRequest','Content-Type':'application/json'}
    })
    .then(r => r.json())
    .then(data => {
        document.getElementById('resumeContent-' + postId).innerHTML =
            data.error
            ? '<div style="color:#FF6B6B;">❌ ' + data.error + '</div>'
            : '<div style="line-height:1.75;">' + data.summary + '</div>';
    })
    .catch(err => {
        document.getElementById('resumeContent-' + postId).innerHTML = '<div style="color:#FF6B6B;">❌ Erreur réseau</div>';
    });
}
function closeResumeModal(postId) {
    document.getElementById('resumeModal-' + postId).style.display = 'none';
}


// ── ANALYSE SENTIMENT ──
async function analyzeSentiment(commentId, btn) {
    btn.innerHTML = '⏳'; btn.disabled = true;
    try {
        const res = await fetch(`/forum/comment/${commentId}/sentiment`, {
            method:'POST', headers:{'X-Requested-With':'XMLHttpRequest'}
        });
        const data = await res.json();
        const resultEl = document.getElementById('sentiment-result-' + commentId);
        if (data.error) { resultEl.innerHTML='❌'; btn.style.display='none'; return; }
        const palette = {
            'positif': {bg:'rgba(107,203,119,.15)',color:'#2d8c3e',border:'rgba(107,203,119,.4)'},
            'negatif': {bg:'rgba(255,107,107,.15)',color:'#c0392b',border:'rgba(255,107,107,.4)'},
            'neutre':  {bg:'rgba(255,217,61,.15)', color:'#B8860B',border:'rgba(255,217,61,.4)'}
        };
        const p = palette[data.sentiment] ?? {bg:'#EDE9FF',color:'#6C47FF',border:'rgba(108,71,255,.3)'};
        resultEl.innerHTML = `<span style="background:${p.bg};color:${p.color};border:1.5px solid ${p.border};
            padding:4px 12px;border-radius:20px;font-weight:700;font-size:11px;display:inline-flex;align-items:center;gap:4px;">
            ${data.emoji} ${data.sentiment} · ${data.score}%</span>`;
        btn.style.display = 'none';
    } catch(e) {
        document.getElementById('sentiment-result-' + commentId).textContent = '❌';
        btn.disabled = false; btn.innerHTML = '😊 Sentiment IA';
    }
}
// ── SUGGESTION DE RÉPONSE MISTRAL AI ──────────────────
async function suggestReply(postId) {
    const btn      = document.getElementById('suggest-btn-' + postId);
    const textarea = btn.closest('.add-comment-right').querySelector('textarea');

    // État chargement
    btn.innerHTML  = '⏳ Mistral génère...';
    btn.disabled   = true;

    try {
        const res  = await fetch(`/forum/post/${postId}/suggest-reply`, {
            method:  'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        });
        const data = await res.json();

        if (data.error) {
            btn.innerHTML = '❌ Erreur';
            btn.disabled  = false;
            setTimeout(() => {
                btn.innerHTML = '<div style="width:6px;height:6px;background:currentColor;border-radius:50%;animation:pulse-dot 1.5s ease-in-out infinite;"></div> 🧠 Mistral — Suggérer une réponse';
            }, 2000);
            return;
        }

        // Injecte la suggestion dans le textarea
        textarea.value = data.suggestion;
        textarea.focus();

        // Anime le bouton en succès
        btn.innerHTML = '✅ Suggestion insérée !';
        btn.style.background = 'linear-gradient(135deg,rgba(107,203,119,.15),rgba(107,203,119,.25))';
        btn.style.color      = '#2d8c3e';
        btn.style.borderColor = 'rgba(107,203,119,.4)';

        setTimeout(() => {
            btn.innerHTML    = '<div style="width:6px;height:6px;background:currentColor;border-radius:50%;animation:pulse-dot 1.5s ease-in-out infinite;"></div> 🧠 Mistral — Suggérer une réponse';
            btn.style.background  = 'linear-gradient(135deg,rgba(14,165,233,.15),rgba(14,165,233,.25))';
            btn.style.color       = '#0369a1';
            btn.style.borderColor = 'rgba(14,165,233,.4)';
            btn.disabled          = false;
        }, 3000);

    } catch(e) {
        btn.innerHTML = '❌ Erreur réseau';
        btn.disabled  = false;
    }
}


</script>

{% endblock %}



