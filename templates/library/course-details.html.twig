    <div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>
    <input type="file" id="addFilesInput" multiple style="display:none;" aria-label="Add files"
           accept=".pdf,.doc,.docx,.ppt,.pptx,.xls,.xlsx,.txt,.md,.jpg,.jpeg,.png,.gif,.webp,.svg">

    <datalist id="subjectsList">
        {% for s in subjects|default([]) %}
        <option value="{{ s.name|e('html_attr') }}">
            {% endfor %}
    </datalist>

    <script>
        (function () {
            'use strict';

            const COURSE_ID = {{ course.id }};
            const IS_OWNER  = {{ (isOwner|default(false)) ? 'true' : 'false' }};

            // ── UTILITIES ────────────────────────────────────────────────────
            function toast(msg, type) {
                const t = document.createElement('div');
                t.className = 'toast toast-' + (type || 'success');
                t.textContent = msg;
                document.getElementById('toastContainer').appendChild(t);
                setTimeout(() => t.remove(), 3500);
            }
            async function post(url, body) {
                if (!(body instanceof FormData) && body) {
                    const f = new FormData();
                    Object.entries(body).forEach(([k, v]) => f.append(k, v));
                    return fetch(url, { method: 'POST', body: f, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                }
                return fetch(url, { method: 'POST', body, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            }

            // ── AVATAR DROPDOWN ──────────────────────────────────────────────
            const avatarBtn = document.getElementById('avatarBtn');
            const dropdown  = document.getElementById('profileDropdown');
            if (avatarBtn) {
                avatarBtn.addEventListener('click', e => { e.stopPropagation(); dropdown.classList.toggle('open'); });
                document.addEventListener('click', () => dropdown.classList.remove('open'));
            }

            // ── PUBLISH TOGGLE ───────────────────────────────────────────────
            const publishToggle = document.getElementById('publishToggle');
            if (publishToggle) {
                publishToggle.addEventListener('change', async () => {
                    const published = publishToggle.checked ? 1 : 0;
                    const res  = await post(`/courses/${COURSE_ID}/publish`, { published });
                    const data = await res.json();
                    if (!res.ok) { toast(data.message || 'Failed to update', 'error'); publishToggle.checked = !publishToggle.checked; }
                    else toast(published ? 'Course published to Library' : 'Course unpublished', 'success');
                });
            }

            // ── INLINE EDIT — TITLE ──────────────────────────────────────────
            const titleLabel = document.getElementById('courseTitleLabel');
            if (titleLabel) {
                titleLabel.addEventListener('dblclick', () => {
                    const inp = document.createElement('input');
                    inp.type = 'text'; inp.className = 'inline-input page-title';
                    inp.value = titleLabel.textContent.trim();
                    inp.style.minWidth = '200px';
                    titleLabel.replaceWith(inp); inp.focus(); inp.select();
                    async function commit() {
                        const v = inp.value.trim();
                        if (!v) { inp.replaceWith(titleLabel); return; }
                        const res  = await post(`/courses/${COURSE_ID}/rename`, { title: v });
                        const data = await res.json();
                        if (!res.ok) { toast(data.message || 'Rename failed', 'error'); inp.replaceWith(titleLabel); return; }
                        titleLabel.textContent = v; titleLabel.dataset.value = v;
                        inp.replaceWith(titleLabel);
                    }
                    inp.addEventListener('keydown', e => { if (e.key === 'Enter') commit(); if (e.key === 'Escape') inp.replaceWith(titleLabel); });
                    inp.addEventListener('blur', commit);
                });
            }

            // ── INLINE EDIT — SUBJECT ────────────────────────────────────────
            const subjectLabel = document.getElementById('courseSubjectLabel');
            if (subjectLabel) {
                subjectLabel.addEventListener('dblclick', () => {
                    const inp = document.createElement('input');
                    inp.type = 'text'; inp.className = 'inline-input';
                    inp.value = subjectLabel.textContent.trim();
                    inp.setAttribute('list', 'subjectsList');
                    inp.style.width = '180px';
                    subjectLabel.replaceWith(inp); inp.focus(); inp.select();
                    async function commit() {
                        const v = inp.value.trim();
                        if (!v) { inp.replaceWith(subjectLabel); return; }
                        const res  = await post(`/courses/${COURSE_ID}/subject`, { subject: v });
                        const data = await res.json();
                        if (!res.ok) { toast(data.message || 'Update failed', 'error'); inp.replaceWith(subjectLabel); return; }
                        subjectLabel.textContent = v; inp.replaceWith(subjectLabel);
                    }
                    inp.addEventListener('keydown', e => { if (e.key === 'Enter') commit(); if (e.key === 'Escape') inp.replaceWith(subjectLabel); });
                    inp.addEventListener('blur', commit);
                });
            }

            // ── FILE CARDS ───────────────────────────────────────────────────
            const filesGrid = document.getElementById('filesGrid');
            let pendingDeleteFileId = null;

            function bindDeleteButton(btn) {
                if (!btn) return;
                btn.addEventListener('click', e => {
                    e.stopPropagation();
                    pendingDeleteFileId = btn.dataset.id;
                    document.getElementById('confirmMsg').textContent = `Delete "${btn.dataset.name}"?`;
                    openModal('confirmModal');
                });
            }

            function bindFileCard(card) {
                if (!card || card.dataset.bound === '1') return;
                card.dataset.bound = '1';
                card.addEventListener('click', e => {
                    if (e.target.closest('[data-action="delete-file"]')) return;
                    if (card.dataset.isNote === '1') {
                        openNoteEditor({
                            id:         card.dataset.id,
                            name:       card.dataset.name,
                            contentUrl: card.dataset.contentUrl,
                            exportUrl:  card.dataset.exportUrl,
                            downloadUrl:card.dataset.downloadUrl,
                            isWord:     card.dataset.isWord === '1',
                        });
                    } else {
                        openFilePreview({
                            id:          card.dataset.id,
                            name:        card.dataset.name,
                            mime:        card.dataset.mime,
                            previewUrl:  card.dataset.previewUrl,
                            downloadUrl: card.dataset.downloadUrl,
                        });
                    }
                });
                card.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); card.click(); } });
            }

            function addNoteCardToGrid(fileId, fileName) {
                if (!filesGrid) return;

                const empty = filesGrid.querySelector('.files-empty');
                if (empty) empty.remove();

                const card = document.createElement('div');
                card.className = 'file-card';
                card.dataset.id = String(fileId);
                card.dataset.name = fileName;
                card.dataset.mime = 'application/json';
                card.dataset.isNote = '1';
                card.dataset.isWord = '0';
                card.dataset.previewUrl = `/courses/${COURSE_ID}/file/${fileId}/preview`;
                card.dataset.downloadUrl = `/courses/${COURSE_ID}/file/${fileId}/download`;
                card.dataset.contentUrl = `/courses/${COURSE_ID}/note/${fileId}/content`;
                card.dataset.exportUrl = `/courses/${COURSE_ID}/note/${fileId}/export-pdf`;
                card.tabIndex = 0;
                card.setAttribute('role', 'button');
                card.setAttribute('aria-label', `Open ${fileName}`);

                const thumb = document.createElement('div');
                thumb.className = 'file-card-thumb';
                thumb.id = `thumb-${fileId}`;
                thumb.textContent = '📝';

                const body = document.createElement('div');
                body.className = 'file-card-body';

                const nameEl = document.createElement('p');
                nameEl.className = 'file-card-name';
                nameEl.textContent = fileName.replace(/\.(rtfx|txt|md)$/i, '');

                const metaEl = document.createElement('p');
                metaEl.className = 'file-card-meta';
                metaEl.textContent = '0 KB';

                body.appendChild(nameEl);
                body.appendChild(metaEl);

                card.appendChild(thumb);
                card.appendChild(body);

                if (IS_OWNER) {
                    const del = document.createElement('button');
                    del.className = 'file-delete-btn';
                    del.dataset.action = 'delete-file';
                    del.dataset.id = String(fileId);
                    del.dataset.name = fileName;
                    del.type = 'button';
                    del.setAttribute('aria-label', `Delete ${fileName}`);
                    del.textContent = '✕';
                    card.appendChild(del);
                    bindDeleteButton(del);
                }

                filesGrid.prepend(card);
                bindFileCard(card);
            }

            document.querySelectorAll('.file-card').forEach(bindFileCard);

            // ── DELETE FILE ──────────────────────────────────────────────────
            document.querySelectorAll('[data-action="delete-file"]').forEach(bindDeleteButton);
            document.getElementById('confirmCancelBtn').addEventListener('click', () => closeModal('confirmModal'));
            document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
                if (!pendingDeleteFileId) return;
                closeModal('confirmModal');
                const res = await post(`/courses/${COURSE_ID}/file/${pendingDeleteFileId}/delete`);
                if (res.ok) {
                    document.querySelectorAll(`[data-id="${pendingDeleteFileId}"]`).forEach(el => el.closest('.file-card')?.remove() || el.remove());
                    toast('File deleted', 'success');
                } else { toast('Delete failed', 'error'); }
                pendingDeleteFileId = null;
            });

            // ── ADD FILES ────────────────────────────────────────────────────
            const addFilesBtn   = document.getElementById('addFilesBtn');
            const addFilesInput = document.getElementById('addFilesInput');
            if (addFilesBtn) {
                addFilesBtn.addEventListener('click', () => addFilesInput.click());
                addFilesInput.addEventListener('change', async () => {
                    if (!addFilesInput.files.length) return;
                    const fd = new FormData();
                    Array.from(addFilesInput.files).forEach(f => fd.append('files[]', f));
                    const res  = await post(`/courses/${COURSE_ID}/upload`, fd);
                    const data = await res.json();
                    if (res.ok) {
                        if (data.uploaded.length) toast(`${data.uploaded.length} file(s) uploaded`, 'success');
                        if (data.rejected && data.rejected.length) toast(`Skipped unsupported file(s): ${data.rejected.join(', ')}`, 'error');
                        if (data.uploaded.length) setTimeout(() => location.reload(), 800);
                    } else {
                        toast(data.message || 'Upload failed', 'error');
                    }
                });
            }

            // ── SAVE TO LIBRARY ──────────────────────────────────────────────
            const saveToLibraryBtn = document.getElementById('saveToLibraryBtn');
            if (saveToLibraryBtn) {
                saveToLibraryBtn.addEventListener('click', async () => {
                    const res  = await post(`/courses/${COURSE_ID}/save-to-library`);
                    const data = await res.json();
                    if (!res.ok) { toast(data.message || 'Failed', 'error'); return; }
                    const saved = data.saved;
                    saveToLibraryBtn.dataset.saved = saved ? '1' : '0';
                    saveToLibraryBtn.classList.toggle('saved', saved);
                    saveToLibraryBtn.innerHTML = saved
                        ? `<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Saved`
                        : `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg> Save to Library`;
                    toast(saved ? 'Saved to Library' : 'Removed from Library', 'success');
                });
            }

            // ── FILE PREVIEW ─────────────────────────────────────────────────
            const previewModal      = document.getElementById('previewModal');
            const previewTitle      = document.getElementById('previewTitle');
            const previewBody       = document.getElementById('previewBody');
            const previewDownload   = document.getElementById('previewDownloadLink');
            const previewRenameBtn  = document.getElementById('previewRenameBtn');
            const previewDeleteBtn  = document.getElementById('previewDeleteBtn');
            let previewFileId = null;

            function openFilePreview({ id, name, mime, previewUrl, downloadUrl }) {
                previewFileId = id;
                previewTitle.textContent = name;
                previewDownload.href = downloadUrl;
                previewDownload.download = name;
                previewBody.innerHTML = '';

                const isPdf  = mime === 'application/pdf';
                const isWord = name.match(/\.(docx?)\s*$/i);

                previewModal.classList.toggle('pdf-mode', isPdf || !!isWord);

                if (mime && mime.startsWith('image/')) {
                    const img = document.createElement('img');
                    img.src = previewUrl; img.alt = name;
                    img.style.cssText = 'max-width:100%;max-height:100%;object-fit:contain;';
                    previewBody.appendChild(img);
                } else if (isPdf || isWord) {
                    // PDFs and Word docs both render via iframe
                    // (Word docs: server returns converted HTML; PDFs: serve inline)
                    const iframe = document.createElement('iframe');
                    iframe.src = previewUrl;
                    iframe.style.cssText = 'width:100%;height:100%;border:none;';
                    previewBody.appendChild(iframe);
                } else {
                    previewBody.innerHTML = `<p style="color:var(--color-text-muted);text-align:center;padding:40px 20px;">Preview not available.<br>Use the Download button below.</p>`;
                }

                openModal2('previewModal');
            }

            if (previewRenameBtn) {
                previewRenameBtn.addEventListener('click', async () => {
                    const name = prompt('New name:', previewTitle.textContent.trim());
                    if (!name || !name.trim()) return;
                    const res = await post(`/courses/${COURSE_ID}/file/${previewFileId}/rename`, { name: name.trim() });
                    if (res.ok) { previewTitle.textContent = name.trim(); toast('Renamed', 'success'); }
                    else toast('Rename failed', 'error');
                });
            }
            if (previewDeleteBtn) {
                previewDeleteBtn.addEventListener('click', () => {
                    pendingDeleteFileId = previewFileId;
                    document.getElementById('confirmMsg').textContent = `Delete "${previewTitle.textContent}"?`;
                    closeModal2('previewModal');
                    openModal('confirmModal');
                });
            }
            document.getElementById('previewCloseBtn').addEventListener('click',  () => closeModal2('previewModal'));
            document.getElementById('previewCloseBtn2').addEventListener('click', () => closeModal2('previewModal'));

            // Fullscreen — uses the iframe element so the PDF fills the whole screen
            const previewFullscreenBtn = document.getElementById('previewFullscreenBtn');
            previewFullscreenBtn.addEventListener('click', () => {
                const iframe = previewBody.querySelector('iframe');
                const target = iframe || previewModal;
                if (target.requestFullscreen) target.requestFullscreen();
                else if (target.webkitRequestFullscreen) target.webkitRequestFullscreen();
            });
            document.addEventListener('fullscreenchange', () => {
                const isFs = !!document.fullscreenElement;
                previewFullscreenBtn.setAttribute('aria-label', isFs ? 'Exit fullscreen' : 'Fullscreen');
                previewFullscreenBtn.innerHTML = isFs
                    ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="10" y1="14" x2="3" y2="21"/><line x1="21" y1="3" x2="14" y2="10"/></svg>`
                    : `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
            });

            function openModal2(id) {
                const el = document.getElementById(id);
                el.classList.add('open');
                el._cb2 = e => { if (e.target === el) closeModal2(id); };
                el.addEventListener('click', el._cb2);
            }
            function closeModal2(id) {
                const el = document.getElementById(id);
                el.classList.remove('open');
                el.classList.remove('pdf-mode');
                if (el._cb2) { el.removeEventListener('click', el._cb2); el._cb2 = null; }
            }

            // ── NOTE EDITOR ──────────────────────────────────────────────────
            const noteModal      = document.getElementById('noteModal');
            const noteNameInp    = document.getElementById('noteNameInput');
            const noteArea       = document.getElementById('noteEditorArea');
            const noteFontSel    = document.getElementById('noteFontSelect');
            const noteSizeInp    = document.getElementById('noteSizeInput');
            const noteBoldBtn    = document.getElementById('noteBoldBtn');
            const noteItalicBtn  = document.getElementById('noteItalicBtn');
            const noteUnderBtn   = document.getElementById('noteUnderlineBtn');
            const noteAlignBtns  = document.querySelectorAll('[data-align]');
            const noteFindBtn    = document.getElementById('noteFindBtn');
            const saveBtn        = document.getElementById('noteSaveBtn');
            const saveAsNewBtn   = document.getElementById('noteSaveAsNewBtn');
            const noteCloseBtn   = document.getElementById('noteCloseBtn');
            const noteRenameBtn  = document.getElementById('noteRenameBtn');
            const noteDeleteBtn  = document.getElementById('noteDeleteBtn');
            const noteDownloadPdfBtn = document.getElementById('noteDownloadPdfBtn');

            let noteFileId = null;
            let noteDirty  = false;
            let noteBusy   = false;
            let findHighlights = [];

            function markDirty() { noteDirty = true; }

            function paragraphsToHtml(paragraphs) {
                return paragraphs.map(p => {
                    const text  = (p.text || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                    const font  = p.font  || 'Inter';
                    const size  = p.size  || 14;
                    const align = p.align || 'left';
                    return `<p style="font-family:${font};font-size:${size}px;text-align:${align};">${text || '<br>'}</p>`;
                }).join('');
            }

            function collectDoc() {
                const paragraphs = [];
                noteArea.querySelectorAll('p').forEach(p => {
                    const style = p.style;
                    paragraphs.push({
                        text:  p.innerText.replace(/\n$/, ''),
                        align: style.textAlign  || 'left',
                        font:  style.fontFamily ? style.fontFamily.replace(/['"]/g,'') : 'Inter',
                        size:  style.fontSize   ? parseInt(style.fontSize) : 14,
                    });
                });
                if (!paragraphs.length) paragraphs.push({ text:'', align:'left', font:'Inter', size:14 });
                return { paragraphs };
            }

            function updateFormatBtns() {
                if (noteBoldBtn)   noteBoldBtn.classList.toggle('active',   document.queryCommandState('bold'));
                if (noteItalicBtn) noteItalicBtn.classList.toggle('active', document.queryCommandState('italic'));
                if (noteUnderBtn)  noteUnderBtn.classList.toggle('active',  document.queryCommandState('underline'));
            }

            function openNoteEditor({ id, name, contentUrl, exportUrl, downloadUrl }) {
                noteFileId = id;
                noteNameInp.value = name.replace(/\.(rtfx|txt|md)$/i, '');
                noteArea.innerHTML = '<p><br></p>';
                noteDirty = false;

                if (noteDownloadPdfBtn) {
                    noteDownloadPdfBtn.href = exportUrl;
                    noteDownloadPdfBtn.download = name.replace(/\.(rtfx|txt|md)$/i, '') + '.pdf';
                    noteDownloadPdfBtn.style.display = '';
                }

                fetch(contentUrl).then(r => r.json()).then(doc => {
                    if (doc.paragraphs) noteArea.innerHTML = paragraphsToHtml(doc.paragraphs);
                    else noteArea.innerHTML = '<p><br></p>';
                }).catch(() => { noteArea.innerHTML = '<p><br></p>'; });

                noteModal.classList.add('open');
            }

            function closeNoteModal() {
                noteModal.classList.remove('open');
                noteFileId = null; noteDirty = false;
                clearFindHighlights();
            }

            function clearFindHighlights() {
                findHighlights.forEach(span => {
                    if (span.parentNode) span.parentNode.replaceChild(document.createTextNode(span.textContent), span);
                });
                findHighlights = [];
            }

            if (noteCloseBtn) noteCloseBtn.addEventListener('click', () => {
                if (noteDirty && !confirm('Unsaved changes — close anyway?')) return;
                closeNoteModal();
            });

            noteArea.addEventListener('input', markDirty);
            noteArea.addEventListener('keyup',  updateFormatBtns);
            noteArea.addEventListener('mouseup', updateFormatBtns);

            if (noteFontSel) noteFontSel.addEventListener('change', () => {
                document.execCommand('fontName', false, noteFontSel.value); markDirty();
            });
            if (noteSizeInp) noteSizeInp.addEventListener('change', () => {
                document.execCommand('fontSize', false, '7');
                noteArea.querySelectorAll('font[size="7"]').forEach(f => {
                    f.removeAttribute('size');
                    f.style.fontSize = noteSizeInp.value + 'px';
                });
                markDirty();
            });

            if (noteBoldBtn)   noteBoldBtn.addEventListener('click',   () => { document.execCommand('bold');      updateFormatBtns(); markDirty(); });
            if (noteItalicBtn) noteItalicBtn.addEventListener('click', () => { document.execCommand('italic');    updateFormatBtns(); markDirty(); });
            if (noteUnderBtn)  noteUnderBtn.addEventListener('click',  () => { document.execCommand('underline'); updateFormatBtns(); markDirty(); });

            noteAlignBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const align = btn.dataset.align;
                    const sel = window.getSelection();
                    let p = sel.anchorNode;
                    while (p && p.tagName !== 'P') p = p.parentNode;
                    if (p) p.style.textAlign = align;
                    noteAlignBtns.forEach(b => b.classList.toggle('active', b.dataset.align === align));
                    markDirty();
                });
            });

            if (noteFindBtn) {
                noteFindBtn.addEventListener('click', () => {
                    clearFindHighlights();
                    const q = prompt('Find:');
                    if (!q) return;

                    const walker = document.createTreeWalker(noteArea, NodeFilter.SHOW_TEXT);
                    const hits   = [];
                    let node;
                    while ((node = walker.nextNode())) {
                        let idx = node.nodeValue.indexOf(q);
                        while (idx !== -1) {
                            hits.push({ node, idx });
                            idx = node.nodeValue.indexOf(q, idx + 1);
                        }
                    }

                    if (!hits.length) { alert('Not found'); return; }

                    hits.reverse().forEach(({ node, idx }) => {
                        const after  = node.splitText(idx + q.length);
                        const match  = node.splitText(idx);
                        const span   = document.createElement('mark');
                        span.className = 'note-find-highlight';
                        span.textContent = q;
                        match.parentNode.replaceChild(span, match);
                        findHighlights.push(span);
                        after;
                    });

                    if (findHighlights.length) findHighlights[findHighlights.length - 1].scrollIntoView({ block: 'center' });
                    toast(`${hits.length} match(es) found`, 'success');
                });
            }

            if (saveBtn) {
                saveBtn.addEventListener('click', async () => {
                    if (noteBusy) return;
                    const name = noteNameInp.value.trim();
                    if (!name) { toast('Name required', 'error'); return; }
                    noteBusy = true; saveBtn.disabled = true;
                    const doc     = collectDoc();
                    const content = JSON.stringify(doc);
                    const finalName = name.replace(/\.(rtfx|txt|md)$/i, '') + '.rtfx';
                    const fd = new FormData();
                    fd.append('content', content);
                    fd.append('name',    finalName);
                    const res = await post(`/courses/${COURSE_ID}/note/${noteFileId}/save`, fd);
                    noteBusy = false; saveBtn.disabled = false;
                    if (res.ok) {
                        toast('Saved', 'success');
                        noteDirty = false;
                        setTimeout(() => location.reload(), 350);
                    }
                    else toast('Save failed', 'error');
                });
            }

            if (saveAsNewBtn) {
                saveAsNewBtn.addEventListener('click', async () => {
                    if (noteBusy) return;
                    const n = prompt('New note name:', noteNameInp.value.trim() + ' copy');
                    if (!n || !n.trim()) return;
                    noteBusy = true; saveAsNewBtn.disabled = true;
                    const finalName = n.trim().replace(/\.(rtfx|txt|md)$/i, '') + '.rtfx';
                    const doc       = collectDoc();
                    const content   = JSON.stringify(doc);
                    const fd = new FormData();
                    fd.append('name',    finalName);
                    fd.append('content', content);
                    const res  = await post(`/courses/${COURSE_ID}/note`, fd);
                    const data = await res.json();
                    noteBusy = false; saveAsNewBtn.disabled = false;
                    if (res.ok) { toast('Saved as new note', 'success'); }
                    else toast(data.message || 'Failed', 'error');
                });
            }

            if (noteRenameBtn) {
                noteRenameBtn.addEventListener('click', async () => {
                    const name = prompt('New name:', noteNameInp.value.trim());
                    if (!name || !name.trim()) return;
                    const finalName = name.trim().replace(/\.(rtfx|txt|md)$/i, '') + '.rtfx';
                    const res = await post(`/courses/${COURSE_ID}/file/${noteFileId}/rename`, { name: finalName });
                    if (res.ok) { noteNameInp.value = name.trim(); toast('Renamed', 'success'); }
                    else toast('Rename failed', 'error');
                });
            }

            if (noteDeleteBtn) {
                noteDeleteBtn.addEventListener('click', () => {
                    pendingDeleteFileId = noteFileId;
                    document.getElementById('confirmMsg').textContent = `Delete "${noteNameInp.value.trim()}"?`;
                    closeNoteModal();
                    openModal('confirmModal');
                });
            }

            const createNoteBtn = document.getElementById('createNoteBtn');
            if (createNoteBtn) {
                createNoteBtn.addEventListener('click', async () => {
                    const name = prompt('Note name:', 'note');
                    if (!name || !name.trim()) return;
                    const res  = await post(`/courses/${COURSE_ID}/note`, { name: name.trim() });
                    const data = await res.json();
                    if (!res.ok) { toast(data.message || 'Failed', 'error'); return; }
                    const contentUrl  = `/courses/${COURSE_ID}/note/${data.id}/content`;
                    const exportUrl   = `/courses/${COURSE_ID}/note/${data.id}/export-pdf`;
                    const downloadUrl = `/courses/${COURSE_ID}/file/${data.id}/download`;
                    addNoteCardToGrid(data.id, data.name);
                    openNoteEditor({ id: String(data.id), name: data.name, contentUrl, exportUrl, downloadUrl });
                });
            }

            noteArea.addEventListener('keydown', e => {
                if (!IS_OWNER) return;
                if (e.ctrlKey || e.metaKey) {
                    if (e.key === 'b') { e.preventDefault(); document.execCommand('bold');      updateFormatBtns(); }
                    if (e.key === 'i') { e.preventDefault(); document.execCommand('italic');    updateFormatBtns(); }
                    if (e.key === 'u') { e.preventDefault(); document.execCommand('underline'); updateFormatBtns(); }
                    if (e.key === 's') { e.preventDefault(); saveBtn?.click(); }
                }
                if (e.key === 'Enter') {
                    e.preventDefault();
                    const sel   = window.getSelection();
                    const range = sel.getRangeAt(0);
                    range.deleteContents();
                    let currentP = sel.anchorNode;
                    while (currentP && currentP.tagName !== 'P') currentP = currentP.parentNode;
                    const newP = document.createElement('p');
                    newP.style.cssText = currentP ? currentP.style.cssText : '';
                    newP.innerHTML     = '<br>';
                    range.collapse(false);
                    if (currentP && currentP.parentNode === noteArea) {
                        currentP.after(newP);
                    } else {
                        noteArea.appendChild(newP);
                    }
                    const newRange = document.createRange();
                    newRange.setStart(newP, 0);
                    newRange.collapse(true);
                    sel.removeAllRanges();
                    sel.addRange(newRange);
                    markDirty();
                }
            });

            // ── MODAL HELPERS ────────────────────────────────────────────────
            function openModal(id) {
                const el = document.getElementById(id);
                el.classList.add('open');
                el._cb = e => { if (e.target === el) closeModal(id); };
                el.addEventListener('click', el._cb);
            }
            function closeModal(id) {
                const el = document.getElementById(id);
                el.classList.remove('open');
                if (el._cb) { el.removeEventListener('click', el._cb); el._cb = null; }
            }

            // ── GLOBAL ESCAPE ────────────────────────────────────────────────
            document.addEventListener('keydown', e => {
                if (e.key !== 'Escape') return;
                closeModal('confirmModal');
                closeModal2('previewModal');
                closeReportModal();
                if (noteModal.classList.contains('open')) {
                    if (noteDirty && !confirm('Unsaved changes — close anyway?')) return;
                    closeNoteModal();
                }
            });

            // ── REPORT COURSE ─────────────────────────────────────────────────
            const reportCourseBtn    = document.getElementById('reportCourseBtn');
            const reportModal        = document.getElementById('reportModal');
            const reportModalClose   = document.getElementById('reportModalCloseBtn');
            const reportCancelBtn    = document.getElementById('reportCancelBtn');
            const reportSubmitBtn    = document.getElementById('reportSubmitBtn');
            const reportReasons      = document.getElementById('reportReasons');
            const reportDetailsArea  = document.getElementById('reportDetails');

            function openReportModal() {
                // Reset state
                reportReasons.querySelectorAll('.report-reason-option').forEach(opt => opt.classList.remove('selected'));
                reportDetailsArea.value = '';
                reportSubmitBtn.disabled = true;
                reportModal.classList.add('open');
            }
            function closeReportModal() {
                reportModal.classList.remove('open');
            }

            if (reportCourseBtn) reportCourseBtn.addEventListener('click', openReportModal);
            if (reportModalClose) reportModalClose.addEventListener('click', closeReportModal);
            if (reportCancelBtn)  reportCancelBtn.addEventListener('click', closeReportModal);

            // Reason selection
            if (reportReasons) {
                reportReasons.addEventListener('click', e => {
                    const option = e.target.closest('.report-reason-option');
                    if (!option) return;
                    reportReasons.querySelectorAll('.report-reason-option').forEach(o => o.classList.remove('selected'));
                    option.classList.add('selected');
                    option.querySelector('input[type=radio]').checked = true;
                    reportSubmitBtn.disabled = false;
                });
            }

            // Submit
            if (reportSubmitBtn) {
                reportSubmitBtn.addEventListener('click', async () => {
                    const selected = reportReasons.querySelector('.report-reason-option.selected');
                    if (!selected) { toast('Please select a reason.', 'error'); return; }
                    const reason  = selected.dataset.value;
                    const details = reportDetailsArea.value.trim();

                    reportSubmitBtn.disabled = true;
                    reportSubmitBtn.textContent = 'Submitting…';

                    const res  = await post(`/courses/${COURSE_ID}/report`, { reason, details });
                    const data = await res.json();

                    reportSubmitBtn.disabled = false;
                    reportSubmitBtn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg> Submit Report`;

                    if (res.ok) {
                        closeReportModal();
                        toast('Report submitted. Thank you!', 'success');
                        // Disable the report button so user can't re-report
                        if (reportCourseBtn) {
                            reportCourseBtn.disabled = true;
                            reportCourseBtn.title = 'You have already reported this course';
                        }
                    } else {
                        toast(data.message || 'Failed to submit report.', 'error');
                        if (res.status === 409 && reportCourseBtn) {
                            reportCourseBtn.disabled = true;
                            reportCourseBtn.title = 'You have already reported this course';
                            closeReportModal();
                        }
                    }
                });
            }

            // Close report modal on backdrop click or Escape
            if (reportModal) {
                reportModal.addEventListener('click', e => { if (e.target === reportModal) closeReportModal(); });
            }

            // ── SUGGESTIONS — Open Library + YouTube ─────────────────────────
            (function loadSuggestions() {
                fetch(`/courses/${COURSE_ID}/suggestions`)
                    .then(r => r.json())
                    .then(({ books, videos }) => {
                        const section = document.getElementById('suggestionsSection');

                        if (books && books.length) {
                            const container = document.getElementById('booksContainer');
                            books.forEach(b => container.appendChild(makeBookCard(b)));
                            document.getElementById('booksSection').style.display = '';
                            section.style.display = '';
                        }

                        if (videos && videos.length) {
                            const container = document.getElementById('videosContainer');
                            videos.forEach(v => container.appendChild(makeVideoCard(v)));
                            document.getElementById('videosSection').style.display = '';
                            section.style.display = '';
                        }
                    })
                    .catch(() => {}); // silently fail — suggestions are non-critical
            })();

            function makeBookCard(b) {
                const a = document.createElement('a');
                a.href = b.openLibUrl || 'https://openlibrary.org';
                a.target = '_blank'; a.rel = 'noopener noreferrer';
                a.className = 'suggestion-card';
                a.style.width = '160px';
                a.innerHTML = `
                    <div class="suggestion-card-thumb" style="width:160px;height:220px;">
                        ${b.coverUrl
                    ? `<img src="${esc(b.coverUrl)}" alt="${esc(b.title)}" loading="lazy">`
                    : '📖'}
                    </div>
                    <div class="suggestion-card-body" style="max-width:160px;">
                        <div class="suggestion-card-title">${esc(b.title)}</div>
                        ${b.author ? `<div class="suggestion-card-sub">${esc(b.author)}</div>` : ''}
                    </div>`;
                return a;
            }

            function makeVideoCard(v) {
                const a = document.createElement('a');
                a.href = v.videoUrl;
                a.target = '_blank'; a.rel = 'noopener noreferrer';
                a.className = 'suggestion-card';
                a.style.width = '240px';
                a.innerHTML = `
                    <div class="suggestion-card-thumb" style="width:240px;height:135px;">
                        ${v.thumbnailUrl
                    ? `<img src="${esc(v.thumbnailUrl)}" alt="${esc(v.title)}" loading="lazy">`
                    : '▶'}
                        <span class="suggestion-play-overlay">▶</span>
                    </div>
                    <div class="suggestion-card-body" style="max-width:240px;">
                        <div class="suggestion-card-title">${esc(v.title)}</div>
                        ${v.channelName ? `<div class="suggestion-card-sub">${esc(v.channelName)}</div>` : ''}
                    </div>`;
                return a;
            }

            function esc(str) {
                return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

        })();
    </script>
{% endblock %}
