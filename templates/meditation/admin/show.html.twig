{% extends 'admin/base.html.twig' %}

{% block title %}{{ session.theme }} - Admin{% endblock %}
{% block page_title %}🧘 {{ session.theme }}{% endblock %}

{% block stylesheets %}
    <style>
        .back-link { display:inline-flex; align-items:center; gap:6px; color:var(--text-muted); text-decoration:none; font-size:13px; margin-bottom:20px; }
        .back-link:hover { color:var(--purple); }
        .detail-card { background:var(--white); border:1px solid var(--border); border-radius:16px; padding:32px; margin-bottom:24px; }
        .detail-title { font-family:var(--font-head); font-size:24px; font-weight:700; color:var(--text); margin-bottom:16px; }
        .detail-row { display:flex; gap:8px; margin-bottom:10px; font-size:14px; align-items:center; }
        .detail-label { color:var(--text-muted); min-width:120px; }
        .detail-value { color:var(--text); font-weight:500; }
        .detail-value a { color:var(--purple); }
        .detail-actions { display:flex; gap:10px; margin-top:20px; flex-wrap:wrap; }
        .action-btn {
            padding:8px 18px; border-radius:10px; font-size:13px; font-weight:500;
            text-decoration:none; border:1px solid var(--border); background:var(--white);
            color:var(--text-mid); cursor:pointer; transition:.15s; font-family:var(--font-body);
            display:inline-flex; align-items:center; gap:6px;
        }
        .action-btn:hover { background:var(--purple-pale); color:var(--purple); }
        .btn-primary { background:var(--purple); color:white; border-color:var(--purple); }
        .btn-primary:hover { background:var(--purple-dark); color:white; }
        .btn-del { color:#E05252; border-color:rgba(224,82,82,.2); }
        .btn-del:hover { background:#FEF2F2; color:#E05252; }
        .btn-pdf { background:#E05252; color:white; border-color:#E05252; }
        .btn-pdf:hover { background:#c93c3c; color:white; }
        .btn-regen { background:#10B981; color:white; border-color:#10B981; }
        .btn-regen:hover { background:#059669; color:white; }
        .btn-regen:disabled { opacity:.6; cursor:not-allowed; }

        .section-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; flex-wrap:wrap; gap:10px; }
        .section-title { font-family:var(--font-head); font-size:18px; font-weight:700; color:var(--text); }
        .section-actions { display:flex; gap:8px; }

        .conseil-card {
            background:var(--white); border:1px solid var(--border); border-radius:12px;
            padding:16px 20px; margin-bottom:12px; display:flex; justify-content:space-between; align-items:flex-start; gap:16px;
        }
        .conseil-num { width:28px; height:28px; border-radius:50%; background:var(--purple-pale); color:var(--purple); font-weight:700; font-size:13px; display:grid; place-items:center; flex-shrink:0; }
        .conseil-text { flex:1; font-size:14px; color:var(--text); line-height:1.6; }
        .conseil-actions { display:flex; gap:6px; flex-shrink:0; flex-wrap:wrap; }
        .conseil-actions a, .conseil-actions button {
            padding:5px 12px; border-radius:8px; font-size:11px; font-weight:500;
            text-decoration:none; border:1px solid var(--border); background:var(--white);
            color:var(--text-muted); cursor:pointer; transition:.15s; font-family:var(--font-body);
        }
        .conseil-actions a:hover { background:var(--purple-pale); color:var(--purple); }
        .conseil-actions .btn-del:hover { background:#FEF2F2; color:#E05252; }
        .btn-tts { color:var(--purple) !important; border-color:rgba(106,90,205,.3) !important; }
        .btn-tts:hover { background:var(--purple-pale) !important; }
        .btn-tts.speaking { background:var(--purple) !important; color:white !important; border-color:var(--purple) !important; }
        .empty-conseils { text-align:center; padding:30px; color:var(--text-muted); font-size:14px; }

        .audio-embed { margin-top:12px; }
        .yt-thumb-link { display:block; position:relative; border-radius:12px; overflow:hidden; text-decoration:none; max-width:480px; }
        .yt-thumb { width:100%; height:auto; display:block; }
        .yt-play-overlay { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; background:rgba(0,0,0,.35); transition:background .2s; }
        .yt-thumb-link:hover .yt-play-overlay { background:rgba(0,0,0,.55); }
        .yt-play-btn { width:56px; height:56px; border-radius:50%; background:#FF0000; color:white; font-size:22px; display:flex; align-items:center; justify-content:center; margin-bottom:8px; padding-left:4px; }
        .yt-play-label { color:white; font-size:13px; font-weight:600; }

        .regen-status { font-size:12px; color:var(--text-muted); margin-top:8px; min-height:18px; }

        /* ── Custom modal ── */
        .modal-backdrop {
            display:none; position:fixed; inset:0; background:rgba(28,23,51,.45);
            backdrop-filter:blur(3px); z-index:1000; align-items:center; justify-content:center;
        }
        .modal-backdrop.open { display:flex; }
        .modal-box {
            background:var(--white); border-radius:20px; padding:32px 28px 24px;
            max-width:400px; width:90%; box-shadow:0 20px 60px rgba(0,0,0,.18);
            animation:modalIn .18s ease;
        }
        @keyframes modalIn { from { transform:scale(.93); opacity:0; } to { transform:scale(1); opacity:1; } }
        .modal-icon { font-size:36px; margin-bottom:12px; }
        .modal-title { font-family:var(--font-head); font-size:18px; font-weight:700; color:var(--text); margin-bottom:8px; }
        .modal-msg { font-size:13px; color:var(--text-muted); line-height:1.6; margin-bottom:24px; }
        .modal-actions { display:flex; gap:10px; justify-content:flex-end; }
        .modal-cancel {
            padding:9px 20px; border-radius:10px; border:1px solid var(--border);
            background:var(--white); color:var(--text-mid); font-size:13px; font-weight:500;
            cursor:pointer; font-family:var(--font-body);
        }
        .modal-cancel:hover { background:var(--purple-ghost); }
        .modal-confirm {
            padding:9px 20px; border-radius:10px; border:none;
            font-size:13px; font-weight:600; cursor:pointer; font-family:var(--font-body); color:white;
        }
        .modal-confirm.green  { background:#10B981; }
        .modal-confirm.green:hover  { background:#059669; }
        .modal-confirm.red    { background:#E05252; }
        .modal-confirm.red:hover    { background:#c93c3c; }
        .modal-confirm.purple { background:var(--purple); }
        .modal-confirm.purple:hover { background:var(--purple-dark); }
    </style>
{% endblock %}

{% block body %}
    <a href="{{ path('admin_meditation_index') }}" class="back-link">← Retour aux sessions</a>

    <div class="detail-card">
        <div class="detail-title" id="sessionTheme">{{ session.theme }}</div>
        <div class="detail-row">
            <span class="detail-label">👨‍⚕️ Auteur</span>
            <span class="detail-value" id="sessionAuteur">{{ session.auteur }}</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">⏱ Durée</span>
            <span class="detail-value" id="sessionDuree">{{ session.duree }} minutes</span>
        </div>
        {% if session.audioUrl %}
        <div class="detail-row">
            <span class="detail-label">🎵 Audio</span>
            <span class="detail-value"><a href="{{ session.audioUrl }}" target="_blank" id="sessionAudioLink">{{ session.audioUrl }}</a></span>
        </div>
        {% set ytId = '' %}
        {% if 'youtube.com/watch?v=' in session.audioUrl %}
            {% set ytId = session.audioUrl|split('v=')|last|split('&')|first %}
        {% elseif 'youtu.be/' in session.audioUrl %}
            {% set ytId = session.audioUrl|split('youtu.be/')|last|split('?')|first %}
        {% endif %}
        {% if ytId != '' %}
        <div class="audio-embed" id="ytThumbWrap">
            <a href="https://www.youtube.com/watch?v={{ ytId }}" target="_blank" class="yt-thumb-link">
                <img src="https://img.youtube.com/vi/{{ ytId }}/hqdefault.jpg" onerror="this.src='https://img.youtube.com/vi/{{ ytId }}/0.jpg'" alt="Aperçu YouTube" class="yt-thumb">
                <div class="yt-play-overlay">
                    <div class="yt-play-btn">▶</div>
                    <div class="yt-play-label">Regarder sur YouTube</div>
                </div>
            </a>
        </div>
        {% endif %}
        {% endif %}

        <div class="detail-actions">
            <a href="{{ path('admin_meditation_edit', {id: session.id}) }}" class="action-btn">✏️ Modifier</a>
            <a href="{{ path('admin_meditation_pdf_detail', {id: session.id}) }}" class="action-btn btn-pdf" target="_blank">📄 PDF</a>
            <button type="button" class="action-btn btn-regen" id="regenSessionBtn">🔄 Régénérer la session</button>
            <button type="button" class="action-btn btn-del" id="deleteSessionBtn">🗑 Supprimer</button>
            <form id="deleteSessionForm" method="post" action="{{ path('admin_meditation_delete', {id: session.id}) }}" style="display:none">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ session.id) }}">
            </form>
        </div>
        <div class="regen-status" id="regenSessionStatus"></div>
    </div>

    <div class="section-header">
        <div class="section-title">💡 Conseils (<span id="conseilsCount">{{ session.conseils|length }}</span>)</div>
        <div class="section-actions">
            <button type="button" class="action-btn btn-regen" id="regenConseilsBtn">🔄 Régénérer les conseils</button>
            <a href="{{ path('admin_conseil_new', {id: session.id}) }}" class="action-btn btn-primary">+ Ajouter</a>
        </div>
    </div>
    <div class="regen-status" id="regenConseilsStatus"></div>

    <div id="conseilsList">
    {% for conseil in session.conseils %}
        <div class="conseil-card" data-id="{{ conseil.id }}">
            <div class="conseil-num">{{ loop.index }}</div>
            <div class="conseil-text">{{ conseil.contenu }}</div>
            <div class="conseil-actions">
                <button type="button" class="btn-tts" data-text="{{ conseil.contenu|e('html_attr') }}">🔊 Lire</button>
                <a href="{{ path('admin_conseil_edit', {id: conseil.id}) }}">✏️ Modifier</a>
                <button type="button" class="btn-del btn-del-conseil" data-id="{{ conseil.id }}" data-token="{{ csrf_token('delete' ~ conseil.id) }}">🗑</button>
            </div>
        </div>
    {% else %}
        <div class="empty-conseils" id="emptyConseils">Aucun conseil pour cette session.</div>
    {% endfor %}
    </div>

    <!-- Custom modal -->
    <div class="modal-backdrop" id="modal">
        <div class="modal-box">
            <div class="modal-icon" id="modalIcon"></div>
            <div class="modal-title" id="modalTitle"></div>
            <div class="modal-msg" id="modalMsg"></div>
            <div class="modal-actions">
                <button class="modal-cancel" id="modalCancel">Annuler</button>
                <button class="modal-confirm" id="modalConfirm"></button>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
<script>
(function(){

    const modal        = document.getElementById('modal');
    const modalIcon    = document.getElementById('modalIcon');
    const modalTitle   = document.getElementById('modalTitle');
    const modalMsg     = document.getElementById('modalMsg');
    const modalConfirm = document.getElementById('modalConfirm');
    const modalCancel  = document.getElementById('modalCancel');
    let   modalResolve = null;

    function openModal({ icon, title, msg, label, color }) {
        modalIcon.textContent    = icon;
        modalTitle.textContent   = title;
        modalMsg.textContent     = msg;
        modalConfirm.textContent = label;
        modalConfirm.className   = 'modal-confirm ' + color;
        modal.classList.add('open');
        return new Promise(resolve => { modalResolve = resolve; });
    }

    function closeModal(result) {
        modal.classList.remove('open');
        if (modalResolve) modalResolve(result);
        modalResolve = null;
    }

    modalCancel.addEventListener('click',  () => closeModal(false));
    modalConfirm.addEventListener('click', () => closeModal(true));
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(false); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(false); });

    // ── TTS ──────────────────────────────────────────────────────────
    let currentBtn = null;
    let voices     = [];

    function loadVoices() { voices = speechSynthesis.getVoices(); }
    loadVoices();
    if (speechSynthesis.onvoiceschanged !== undefined) {
        speechSynthesis.onvoiceschanged = loadVoices;
    }

    function speak(text, btn) {
        speechSynthesis.cancel();
        if (currentBtn && currentBtn !== btn) resetBtn(currentBtn);
        if (currentBtn === btn) { currentBtn = null; return; }

        const utt   = new SpeechSynthesisUtterance(text);
        utt.lang    = 'fr-FR';
        utt.rate    = 0.92;
        utt.volume  = 1;
        const fr    = voices.find(v => v.lang.startsWith('fr'));
        if (fr) utt.voice = fr;

        utt.onstart = () => { btn.textContent = '⏹ Arrêter'; btn.classList.add('speaking'); currentBtn = btn; };

        const keepAlive = setInterval(() => {
            if (!speechSynthesis.speaking) { clearInterval(keepAlive); return; }
            speechSynthesis.pause(); speechSynthesis.resume();
        }, 10000);

        utt.onend = utt.onerror = (e) => {
            clearInterval(keepAlive);
            if (!e.error || e.error === 'interrupted') { resetBtn(btn); currentBtn = null; }
        };

        speechSynthesis.speak(utt);
    }

    function resetBtn(btn) { btn.textContent = '🔊 Lire'; btn.classList.remove('speaking'); }

    function attachTts(container) {
        container.querySelectorAll('.btn-tts').forEach(btn => {
            btn.addEventListener('click', () => speak(btn.dataset.text, btn));
        });
    }

    attachTts(document.getElementById('conseilsList'));

    // ── Delete session ────────────────────────────────────────────────
    document.getElementById('deleteSessionBtn').addEventListener('click', async () => {
        const ok = await openModal({
            icon:  '🗑',
            title: 'Supprimer cette session ?',
            msg:   'Cette session et tous ses conseils seront supprimés définitivement.',
            label: 'Supprimer',
            color: 'red',
        });
        if (ok) document.getElementById('deleteSessionForm').submit();
    });

    // ── Delete conseil ────────────────────────────────────────────────
    document.getElementById('conseilsList').addEventListener('click', async e => {
        const btn = e.target.closest('.btn-del-conseil');
        if (!btn) return;

        const ok = await openModal({
            icon:  '🗑',
            title: 'Supprimer ce conseil ?',
            msg:   'Ce conseil sera supprimé définitivement.',
            label: 'Supprimer',
            color: 'red',
        });
        if (!ok) return;

        const form = document.createElement('form');
        form.method = 'post';
        form.action = '/admin/meditation/conseil/' + btn.dataset.id + '/delete';
        form.innerHTML = '<input type="hidden" name="_token" value="' + btn.dataset.token + '">';
        document.body.appendChild(form);
        form.submit();
    });

    // ── Regenerate conseils ───────────────────────────────────────────
    document.getElementById('regenConseilsBtn').addEventListener('click', async () => {
        const ok = await openModal({
            icon:  '🔄',
            title: 'Régénérer les conseils ?',
            msg:   'L\'IA va créer 3 nouveaux conseils. Les conseils actuels seront supprimés.',
            label: 'Régénérer',
            color: 'green',
        });
        if (!ok) return;

        const btn    = document.getElementById('regenConseilsBtn');
        const status = document.getElementById('regenConseilsStatus');
        btn.disabled = true; btn.textContent = '⏳ Génération...'; status.textContent = '';

        try {
            const res  = await fetch('{{ path("admin_meditation_regenerate_conseils", {id: session.id}) }}', { method: 'POST' });
            const data = await res.json();

            if (data.error) { status.textContent = '❌ ' + data.error; return; }

            const list = document.getElementById('conseilsList');
            list.innerHTML = data.conseils.map((c, i) => `
                <div class="conseil-card" data-id="${c.id}">
                    <div class="conseil-num">${i + 1}</div>
                    <div class="conseil-text">${esc(c.contenu)}</div>
                    <div class="conseil-actions">
                        <button type="button" class="btn-tts" data-text="${escAttr(c.contenu)}">🔊 Lire</button>
                        <a href="/admin/meditation/conseil/${c.id}/edit">✏️ Modifier</a>
                        <button type="button" class="btn-del btn-del-conseil" data-id="${c.id}" data-token="">🗑</button>
                    </div>
                </div>
            `).join('');

            document.getElementById('conseilsCount').textContent = data.conseils.length;
            status.textContent = '✅ Nouveaux conseils générés !';
            attachTts(list);
        } catch(err) {
            status.textContent = '❌ Erreur : ' + err.message;
        } finally {
            btn.disabled = false; btn.textContent = '🔄 Régénérer les conseils';
        }
    });

    // ── Regenerate session ────────────────────────────────────────────
    document.getElementById('regenSessionBtn').addEventListener('click', async () => {
        const ok = await openModal({
            icon:  '🔄',
            title: 'Régénérer la session ?',
            msg:   'L\'IA va générer un nouvel auteur, une nouvelle durée et une suggestion de recherche YouTube.',
            label: 'Régénérer',
            color: 'green',
        });
        if (!ok) return;

        const btn    = document.getElementById('regenSessionBtn');
        const status = document.getElementById('regenSessionStatus');
        btn.disabled = true; btn.textContent = '⏳ Génération...'; status.textContent = '';

        try {
            const res  = await fetch('{{ path("admin_meditation_regenerate_session", {id: session.id}) }}', { method: 'POST' });
            const data = await res.json();

            if (data.error) { status.textContent = '❌ ' + data.error; return; }

            document.getElementById('sessionAuteur').textContent = data.auteur;
            document.getElementById('sessionDuree').textContent  = data.duree + ' minutes';

            let ytWrap = document.getElementById('ytThumbWrap');
            if (!ytWrap) {
                ytWrap = document.createElement('div');
                ytWrap.id = 'ytThumbWrap';
                ytWrap.className = 'audio-embed';
                document.querySelector('.detail-actions').before(ytWrap);
            }

            if (data.audioUrl) {
                const audioLink = document.getElementById('sessionAudioLink');
                if (audioLink) { audioLink.textContent = data.audioUrl; audioLink.href = data.audioUrl; }

                const ytMatch = data.audioUrl.match(/[?&]v=([^&]+)/) || data.audioUrl.match(/youtu\.be\/([^?]+)/);
                const ytId    = ytMatch ? ytMatch[1] : null;
                if (ytId) {
                    ytWrap.innerHTML = `<a href="https://www.youtube.com/watch?v=${ytId}" target="_blank" class="yt-thumb-link">
                        <img src="https://img.youtube.com/vi/${ytId}/hqdefault.jpg" alt="Aperçu YouTube" class="yt-thumb">
                        <div class="yt-play-overlay"><div class="yt-play-btn">▶</div><div class="yt-play-label">Regarder sur YouTube</div></div>
                    </a>`;
                }
            } else if (data.searchQuery) {
                const searchUrl = 'https://www.youtube.com/results?search_query=' + encodeURIComponent(data.searchQuery);
                ytWrap.innerHTML = `<a href="${searchUrl}" target="_blank" style="display:inline-flex;align-items:center;gap:8px;padding:10px 16px;background:#FF0000;color:white;border-radius:10px;text-decoration:none;font-size:13px;font-weight:600;">▶ Recherche YouTube : <em>${esc(data.searchQuery)}</em></a><br><small style="color:var(--text-muted);font-size:11px;margin-top:6px;display:block;">Réseau lent — ouvrez ce lien et modifiez la session avec la vraie URL.</small>`;
            }

            status.textContent = '✅ Session mise à jour !';
        } catch(err) {
            status.textContent = '❌ Erreur : ' + err.message;
        } finally {
            btn.disabled = false; btn.textContent = '🔄 Régénérer la session';
        }
    });

    function esc(str)     { const d = document.createElement('div'); d.textContent = str || ''; return d.innerHTML; }
    function escAttr(str) { return (str || '').replace(/"/g, '&quot;').replace(/'/g, '&#39;'); }

})();
</script>
{% endblock %}
