{% extends 'base.html.twig' %}

{% block title %}Salle{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('harmonie/css/harmony-theme.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
{% include '_planning_topbar.html.twig' %}
<main class="page">
    <h1>Salle</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ salle.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ salle.nom }}</td>
            </tr>
            <tr>
                <th>Capacite</th>
                <td>{{ salle.capacite }}</td>
            </tr>
            <tr>
                <th>Equipements</th>
                <td>{{ salle.equipements }}</td>
            </tr>
            <tr>
                <th>Disponible</th>
                <td>{{ salle.disponible ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ salle.description }}</td>
            </tr>
            <tr>
                <th>DateCreation</th>
                <td>{{ salle.dateCreation ? salle.dateCreation|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_salle_index') }}">back to list</a>

    <a href="{{ path('app_salle_edit', {'id': salle.id}) }}">edit</a>

    {{ include('salle/_delete_form.html.twig') }}
</main>
{% endblock %}
