{% extends 'base.html.twig' %}
{% block title %}Mot de passe oublié — Harmony{% endblock %}

{% block stylesheets %}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --purple:       #6A5ACD;
            --purple-dark:  #4B3B9E;
            --purple-mid:   #7C6DD8;
            --purple-soft:  #8B7FD4;
            --purple-pale:  #EDE8FA;
            --purple-ghost: #F0EEF8;
            --purple-deep:  #2D2260;
            --text:         #1C1733;
            --text-mid:     #4A4570;
            --text-muted:   #9590B8;
            --border:       rgba(106,90,205,.15);
            --white:        #FFFFFF;
            --green:        #10B981;
            --red:          #E05252;
            --font-display: 'Cormorant Garamond', Georgia, serif;
            --font-body:    'DM Sans', sans-serif;
        }

        html, body {
            min-height: 100vh;
            font-family: var(--font-body);
            background: #E8E4F3;
            overflow-x: hidden;
        }

        /* ── BACKGROUND ── */
        .scene {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            background-image: url("{{ asset('images/backgLIGHT.png') }}");
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .scene::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,
                rgba(106,90,205,.18) 0%,
                rgba(237,232,250,.55) 50%,
                rgba(75,59,158,.12) 100%);
            backdrop-filter: blur(1px);
        }

        /* ── WRAPPER ── */
        .forgot-wrapper {
            position: relative;
            z-index: 10;
            display: flex;
            gap: 0;
            max-width: 820px;
            width: 100%;
            border-radius: 28px;
            overflow: hidden;
            box-shadow:
                0 32px 80px rgba(45,34,96,.22),
                0 0 0 1px rgba(106,90,205,.15),
                inset 0 1px 0 rgba(255,255,255,.6);
            animation: wrapperIn .7s cubic-bezier(.22,1,.36,1) both;
        }

        @keyframes wrapperIn {
            from { opacity:0; transform: translateY(28px) scale(.97); }
            to   { opacity:1; transform: translateY(0) scale(1); }
        }

        /* ── LEFT PANEL ── */
        .panel-left {
            width: 280px;
            flex-shrink: 0;
            background: linear-gradient(160deg, var(--purple-deep) 0%, var(--purple) 60%, var(--purple-mid) 100%);
            padding: 52px 36px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .panel-left::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 220px; height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,.06);
            pointer-events: none;
        }

        .panel-left::after {
            content: '';
            position: absolute;
            bottom: -40px; left: -40px;
            width: 180px; height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
            pointer-events: none;
        }

        .brand {
            display: flex;
            flex-direction: column;
            gap: 14px;
            animation: fadeSlide .6s .15s ease both;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-logo img {
            width: 38px; height: 38px;
            border-radius: 11px;
            object-fit: contain;
            border: 2px solid rgba(255,255,255,.2);
        }

        .brand-name {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 600;
            color: white;
            letter-spacing: .5px;
        }

        .brand-tagline {
            font-family: var(--font-display);
            font-size: 28px;
            font-weight: 300;
            font-style: italic;
            color: rgba(255,255,255,.9);
            line-height: 1.3;
            letter-spacing: -.3px;
        }

        .brand-tagline strong {
            font-weight: 600;
            font-style: normal;
            color: white;
        }

        .brand-sub {
            font-size: 12.5px;
            font-weight: 300;
            color: rgba(255,255,255,.6);
            line-height: 1.6;
            margin-top: 4px;
        }

        /* ── STEPS SIDEBAR ── */
        .steps-sidebar {
            display: flex;
            flex-direction: column;
            gap: 0;
            animation: fadeSlide .6s .3s ease both;
        }

        .step-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            position: relative;
        }

        .step-item:not(:last-child)::after {
            content: '';
            position: absolute;
            left: 14px;
            top: 30px;
            width: 2px;
            height: calc(100% - 6px);
            background: rgba(255,255,255,.15);
        }

        .step-item.s-done::after { background: rgba(255,255,255,.35); }

        .step-bubble {
            width: 28px; height: 28px;
            border-radius: 50%;
            flex-shrink: 0;
            display: grid;
            place-items: center;
            font-size: 11px;
            font-weight: 700;
            font-family: var(--font-body);
            transition: .3s;
            position: relative;
            z-index: 1;
        }

        .step-bubble.s-active {
            background: white;
            color: var(--purple-deep);
            box-shadow: 0 4px 14px rgba(0,0,0,.25);
        }

        .step-bubble.s-done {
            background: rgba(255,255,255,.25);
            color: white;
            border: 1.5px solid rgba(255,255,255,.5);
        }

        .step-bubble.s-idle {
            background: rgba(255,255,255,.1);
            color: rgba(255,255,255,.35);
            border: 1.5px solid rgba(255,255,255,.12);
        }

        .step-text {
            padding-top: 4px;
            padding-bottom: 22px;
        }

        .step-text .s-label {
            font-size: 12px;
            font-weight: 600;
            color: white;
            display: block;
            margin-bottom: 2px;
        }

        .step-text .s-sub {
            font-size: 11px;
            color: rgba(255,255,255,.5);
            font-weight: 300;
        }

        .step-item.s-idle .step-text .s-label { color: rgba(255,255,255,.4); }
        .step-item.s-idle .step-text .s-sub   { color: rgba(255,255,255,.22); }

        .decorative-dots {
            display: flex;
            gap: 6px;
            animation: fadeSlide .6s .45s ease both;
        }

        .decorative-dots span {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: rgba(255,255,255,.3);
        }

        .decorative-dots span:first-child { background: rgba(255,255,255,.8); }
        .decorative-dots span:nth-child(2) { background: rgba(255,255,255,.5); }

        /* ── RIGHT PANEL ── */
        .panel-right {
            flex: 1;
            background: rgba(255,255,255,.92);
            backdrop-filter: blur(20px);
            padding: 48px 44px 44px;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .panel-title {
            font-family: var(--font-display);
            font-size: 26px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 4px;
            animation: fadeSlide .5s .1s ease both;
        }

        .panel-sub {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 28px;
            font-weight: 300;
            line-height: 1.6;
            animation: fadeSlide .5s .15s ease both;
        }

        .panel-sub strong { color: var(--purple); font-weight: 600; }

        /* ── ALERTS ── */
        .alert {
            padding: 10px 14px;
            border-radius: 10px;
            font-size: 12.5px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            animation: fadeSlide .4s ease both;
        }

        .alert-error   { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }
        .alert-success { background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7; }

        /* ── CHAMPS ── */
        .field-group {
            margin-bottom: 16px;
            animation: fadeSlide .5s ease both;
        }

        .field-label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: var(--text-mid);
            margin-bottom: 8px;
        }

        .field-input-wrap { position: relative; }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 15px;
            pointer-events: none;
            opacity: .5;
            transition: opacity .2s;
        }

        .field-input {
            width: 100%;
            padding: 11px 14px 11px 42px;
            border: 1.5px solid var(--border);
            border-radius: 11px;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--text);
            background: var(--purple-ghost);
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        .field-input:focus {
            border-color: var(--purple);
            background: white;
            box-shadow: 0 0 0 3px rgba(106,90,205,.1);
        }

        .field-input-wrap:has(.field-input:focus) .field-icon { opacity: .8; }

        /* ── BLOC QR CODE ── */
        .qr-block {
            background: linear-gradient(135deg, var(--purple-pale), rgba(237,232,250,.5));
            border: 1.5px solid rgba(106,90,205,.2);
            border-radius: 16px;
            padding: 22px;
            text-align: center;
            margin-bottom: 22px;
            animation: fadeSlide .5s .2s ease both;
        }

        .qr-block h3 {
            font-family: var(--font-display);
            font-size: 18px;
            font-weight: 600;
            color: var(--purple-dark);
            margin-bottom: 6px;
        }

        .qr-block p { font-size: 12.5px; color: var(--text-muted); line-height: 1.6; margin-bottom: 14px; }

        .qr-canvas-wrap {
            display: inline-flex;
            background: white;
            border-radius: 12px;
            padding: 10px;
            margin-bottom: 14px;
            box-shadow: 0 4px 16px rgba(106,90,205,.15);
        }

        .qr-steps { list-style: none; text-align: left; margin-top: 12px; }

        .qr-steps li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 6px 0;
            border-bottom: 1px solid rgba(106,90,205,.08);
            font-size: 12.5px;
            color: var(--text-muted);
        }

        .qr-steps li:last-child { border: none; }

        .step-num {
            width: 20px; height: 20px;
            border-radius: 50%;
            background: var(--purple-pale);
            color: var(--purple);
            font-size: 10px;
            font-weight: 700;
            display: grid;
            place-items: center;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .qr-steps strong { color: var(--text-mid); font-weight: 600; }

        /* ── SAISIE TOTP ── */
        .totp-wrap {
            margin-bottom: 20px;
            animation: fadeSlide .5s .2s ease both;
        }

        .totp-wrap label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: var(--text-mid);
            margin-bottom: 8px;
        }

        .totp-input {
            width: 100%;
            padding: 14px;
            border: 1.5px solid var(--border);
            border-radius: 11px;
            font-family: var(--font-display);
            font-size: 30px;
            font-weight: 600;
            color: var(--purple-dark);
            text-align: center;
            letter-spacing: 14px;
            background: var(--purple-ghost);
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        .totp-input::placeholder {
            color: rgba(106,90,205,.25);
            font-size: 22px;
            letter-spacing: 8px;
        }

        .totp-input:focus {
            border-color: var(--purple);
            background: white;
            box-shadow: 0 0 0 3px rgba(106,90,205,.1);
        }

        .totp-timer {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 8px;
            font-size: 12px;
            color: var(--text-muted);
        }

        .timer-svg  { transform: rotate(-90deg); }
        .timer-bg   { fill: none; stroke: rgba(106,90,205,.12); stroke-width: 2.5; }
        .timer-prog { fill: none; stroke: var(--purple); stroke-width: 2.5; stroke-linecap: round; stroke-dasharray: 50.27; transition: stroke-dashoffset 1s linear; }

        /* ── FORCE MOT DE PASSE ── */
        .pwd-strength { margin-top: 10px; }
        .pwd-bars { display: flex; gap: 4px; margin-bottom: 6px; }
        .pwd-bar { height: 4px; flex: 1; border-radius: 4px; background: var(--border); transition: background .3s; }
        .strength-lbl { font-size: 12px; font-weight: 600; min-height: 16px; margin-bottom: 6px; transition: color .2s; }
        .pwd-rules { display: grid; grid-template-columns: 1fr 1fr; gap: 3px; }
        .pwd-rule { font-size: 11px; color: var(--text-muted); display: flex; align-items: center; gap: 5px; transition: color .2s; }
        .pwd-rule.ok { color: var(--green); }
        .pwd-rule::before { content: '○'; font-size: 9px; }
        .pwd-rule.ok::before { content: '✓'; }

        .match-error { color: var(--red); font-size: 12px; margin-top: 6px; display: none; }

        /* ── BOUTON ── */
        .btn-submit {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, var(--purple) 0%, var(--purple-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: .3px;
            box-shadow: 0 4px 20px rgba(106,90,205,.4), 0 1px 0 rgba(255,255,255,.1) inset;
            transition: transform .15s, box-shadow .15s;
            margin-top: 4px;
            animation: fadeSlide .5s .4s ease both;
            position: relative;
            overflow: hidden;
        }

        .btn-submit::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 50%);
            pointer-events: none;
        }

        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(106,90,205,.45); }
        .btn-submit:active { transform: translateY(0); }

        /* ── LIEN RETOUR ── */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 12.5px;
            color: var(--text-muted);
            text-decoration: none;
            margin-top: 20px;
            font-weight: 500;
            transition: color .15s;
            animation: fadeSlide .5s .45s ease both;
        }

        .back-link:hover { color: var(--purple); }

        /* ── ANIMATIONS ── */
        @keyframes fadeSlide {
            from { opacity:0; transform: translateY(12px); }
            to   { opacity:1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 680px) {
            .forgot-wrapper { flex-direction: column; max-width: 420px; border-radius: 22px; }
            .panel-left { width: 100%; padding: 36px 32px; }
            .brand-tagline { font-size: 22px; }
            .steps-sidebar { flex-direction: row; gap: 16px; flex-wrap: wrap; }
            .step-item::after { display: none; }
            .step-text { padding-bottom: 0; }
            .panel-right { padding: 36px 28px 32px; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="scene">
    <div class="forgot-wrapper">

        <!-- ══ LEFT PANEL ══ -->
        <div class="panel-left">
            <div class="brand">
                <div class="brand-logo">
                    <img src="{{ asset('images/logo.png') }}" alt="Harmony">
                    <span class="brand-name">Harmony</span>
                </div>
                <p class="brand-tagline">
                    Récupérez<br>
                    votre <strong>accès</strong><br>
                    en sécurité
                </p>
                <p class="brand-sub">
                    Vérification en 3 étapes via votre application Authenticator.
                </p>
            </div>

            <!-- Indicateur d'étapes dans le panel gauche -->
            <div class="steps-sidebar">

                <div class="step-item {% if step == 'email' %}s-active{% elseif step in ['verify','reset'] %}s-done{% else %}s-idle{% endif %}">
                    <div class="step-bubble {% if step == 'email' %}s-active{% elseif step in ['verify','reset'] %}s-done{% else %}s-idle{% endif %}">
                        {% if step in ['verify','reset'] %}✓{% else %}1{% endif %}
                    </div>
                    <div class="step-text">
                        <span class="s-label">Email</span>
                        <span class="s-sub">Saisie de votre adresse</span>
                    </div>
                </div>

                <div class="step-item {% if step == 'verify' %}s-active{% elseif step == 'reset' %}s-done{% else %}s-idle{% endif %}">
                    <div class="step-bubble {% if step == 'verify' %}s-active{% elseif step == 'reset' %}s-done{% else %}s-idle{% endif %}">
                        {% if step == 'reset' %}✓{% else %}2{% endif %}
                    </div>
                    <div class="step-text">
                        <span class="s-label">Authenticator</span>
                        <span class="s-sub">Code à 6 chiffres</span>
                    </div>
                </div>

                <div class="step-item {% if step == 'reset' %}s-active{% else %}s-idle{% endif %}">
                    <div class="step-bubble {% if step == 'reset' %}s-active{% else %}s-idle{% endif %}">3</div>
                    <div class="step-text">
                        <span class="s-label">Nouveau mot de passe</span>
                        <span class="s-sub">Saisie sécurisée</span>
                    </div>
                </div>

            </div>

            <div class="decorative-dots">
                <span></span><span></span><span></span>
            </div>
        </div>

        <!-- ══ RIGHT PANEL ══ -->
        <div class="panel-right">

            {# ════════════════════════════════════════
               ÉTAPE 1 — Email
            ════════════════════════════════════════ #}
            {% if step == 'email' %}

            <div class="panel-title">Mot de passe oublié 🔑</div>
            <p class="panel-sub">Entrez votre adresse email pour commencer la récupération via votre application Authenticator.</p>

            <form method="post" action="{{ path('app_forgot_password') }}">
                <div class="field-group">
                    <label class="field-label" for="email">Adresse email du compte</label>
                    <div class="field-input-wrap">
                        <span class="field-icon">✉</span>
                        <input class="field-input" type="email" id="email" name="email" required autofocus
                               placeholder="votre@email.com" autocomplete="email">
                    </div>
                </div>
                <button type="submit" class="btn-submit">Continuer →</button>
            </form>

            {# ════════════════════════════════════════
               ÉTAPE 2 — QR Code + Code TOTP
            ════════════════════════════════════════ #}
            {% elseif step == 'verify' %}

            {% if error is defined and error %}
                <div class="alert alert-error">⚠ {{ error }}</div>
            {% endif %}

            {% if isNew and qrUri is defined and qrUri %}
                {# ── Première configuration : afficher le QR à scanner ── #}
                <div class="panel-title">Configurer l'Authenticator 📲</div>
                <p class="panel-sub">Scannez ce QR code avec <strong>Google Authenticator</strong> ou <strong>Authy</strong>, puis entrez le code à 6 chiffres.</p>

                <div class="qr-block">
                    <h3>📲 Scanner ce QR code</h3>
                    <p>Ouvrez votre application Authenticator et scannez le code ci-dessous.</p>
                    <div class="qr-canvas-wrap">
                        <div id="qrcode"></div>
                    </div>
                    <ul class="qr-steps">
                        <li>
                            <span class="step-num">1</span>
                            <span>Ouvrez <strong>Google Authenticator</strong> ou <strong>Authy</strong></span>
                        </li>
                        <li>
                            <span class="step-num">2</span>
                            <span>Appuyez sur <strong>+</strong> → <strong>Scanner un QR code</strong></span>
                        </li>
                        <li>
                            <span class="step-num">3</span>
                            <span>Scannez — une entrée <strong>Harmony</strong> apparaîtra</span>
                        </li>
                        <li>
                            <span class="step-num">4</span>
                            <span>Entrez ci-dessous le <strong>code à 6 chiffres</strong> affiché</span>
                        </li>
                    </ul>
                </div>

            {% else %}
                {# ── Secret déjà configuré : demander directement le code ── #}
                <div class="panel-title">Vérification Authenticator 🔐</div>
                <p class="panel-sub">Ouvrez votre application Authenticator et entrez le code à 6 chiffres affiché pour <strong>{{ email }}</strong>.</p>
            {% endif %}

            <form method="post" action="{{ path('app_forgot_password_verify') }}">
                <div class="totp-wrap">
                    <label>Code à 6 chiffres</label>
                    <input type="text" name="totp_code" class="totp-input"
                           id="totpInput"
                           required autofocus
                           placeholder="000000"
                           maxlength="6"
                           inputmode="numeric"
                           pattern="\d{6}"
                           autocomplete="one-time-code">
                    <div class="totp-timer">
                        <svg class="timer-svg" width="20" height="20" viewBox="0 0 20 20">
                            <circle class="timer-bg" cx="10" cy="10" r="8"/>
                            <circle class="timer-prog" id="timerCircle" cx="10" cy="10" r="8" stroke-dashoffset="0"/>
                        </svg>
                        <span id="timerLabel">Calcul en cours…</span>
                    </div>
                </div>
                <button type="submit" class="btn-submit">Vérifier le code →</button>
            </form>

            {# ════════════════════════════════════════
               ÉTAPE 3 — Nouveau mot de passe
            ════════════════════════════════════════ #}
            {% elseif step == 'reset' %}

            <div class="panel-title">Nouveau mot de passe ✨</div>
            <p class="panel-sub">Choisissez un mot de passe fort pour votre compte <strong>{{ email }}</strong>.</p>

            {% if errors is defined and errors %}
                {% for err in errors %}
                    <div class="alert alert-error">⚠ {{ err }}</div>
                {% endfor %}
            {% endif %}

            <form method="post" action="{{ path('app_forgot_password_reset') }}" id="resetForm">

                <div class="field-group">
                    <label class="field-label" for="new_password">Nouveau mot de passe</label>
                    <div class="field-input-wrap">
                        <span class="field-icon">🔑</span>
                        <input class="field-input" type="password" id="new_password" name="new_password"
                               required placeholder="••••••••" autocomplete="new-password">
                    </div>
                    <div class="pwd-strength">
                        <div class="pwd-bars">
                            <div class="pwd-bar" id="bar1"></div>
                            <div class="pwd-bar" id="bar2"></div>
                            <div class="pwd-bar" id="bar3"></div>
                            <div class="pwd-bar" id="bar4"></div>
                        </div>
                        <div class="strength-lbl" id="strengthLabel"></div>
                        <div class="pwd-rules">
                            <div class="pwd-rule" id="r-len">8 caractères min</div>
                            <div class="pwd-rule" id="r-maj">1 majuscule</div>
                            <div class="pwd-rule" id="r-num">1 chiffre</div>
                            <div class="pwd-rule" id="r-sym">1 caractère spécial</div>
                        </div>
                    </div>
                </div>

                <div class="field-group">
                    <label class="field-label" for="confirm_password">Confirmer le mot de passe</label>
                    <div class="field-input-wrap">
                        <span class="field-icon">🔒</span>
                        <input class="field-input" type="password" id="confirm_password" name="confirm_password"
                               required placeholder="••••••••" autocomplete="new-password">
                    </div>
                    <div class="match-error" id="matchError">⚠ Les mots de passe ne correspondent pas.</div>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    Enregistrer le nouveau mot de passe ✓
                </button>
            </form>

            {% endif %}

            <a href="{{ path('app_login') }}" class="back-link">← Retour à la connexion</a>

        </div>
        <!-- /panel-right -->

    </div>
</div>
{% endblock %}

{% block body_javascripts %}
{# Librairie QR code JS - chargée via CDN, aucune installation requise #}
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>

<script>
// ═══════════════════════════════════════════════════════════
// QR CODE — généré côté client via qrcodejs
// ═══════════════════════════════════════════════════════════
(function() {
    const container = document.getElementById('qrcode');
    {% if step == 'verify' and isNew is defined and isNew and qrUri is defined and qrUri %}
    if (container && typeof QRCode !== 'undefined') {
        new QRCode(container, {
            text: {{ qrUri|json_encode|raw }},
            width:  160,
            height: 160,
            colorDark:  '#000000',
            colorLight: '#ffffff',
            correctLevel: QRCode.CorrectLevel.M
        });
    }
    {% endif %}
})();

// ═══════════════════════════════════════════════════════════
// TIMER TOTP — tourne en temps réel
// ═══════════════════════════════════════════════════════════
(function() {
    const circle = document.getElementById('timerCircle');
    const label  = document.getElementById('timerLabel');
    if (!circle) return;

    const circumference = 2 * Math.PI * 8; // ≈ 50.27

    function tick() {
        const elapsed = Math.floor(Date.now() / 1000) % 30;
        const left    = 30 - elapsed;
        const offset  = circumference * (elapsed / 30);
        circle.style.strokeDashoffset = offset;
        circle.style.stroke = left <= 5 ? '#e07070' : 'var(--purple)';
        if (label) label.textContent = 'Code valide encore ' + left + ' secondes';
    }
    tick();
    setInterval(tick, 1000);
})();

// ═══════════════════════════════════════════════════════════
// TOTP INPUT — chiffres uniquement, 6 max
// ═══════════════════════════════════════════════════════════
(function() {
    const input = document.getElementById('totpInput');
    if (!input) return;
    input.addEventListener('input', function() {
        this.value = this.value.replace(/\D/g, '').slice(0, 6);
    });
})();

// ═══════════════════════════════════════════════════════════
// INDICATEUR DE FORCE DU MOT DE PASSE
// ═══════════════════════════════════════════════════════════
(function() {
    const pwd  = document.getElementById('new_password');
    const conf = document.getElementById('confirm_password');
    if (!pwd) return;

    const rules = {
        len: v => v.length >= 8,
        maj: v => /[A-Z]/.test(v),
        num: v => /\d/.test(v),
        sym: v => /[\W_]/.test(v),
    };
    const colors = ['#e07070', '#f59e0b', '#10B981', '#6A5ACD'];
    const labels = ['', '🔴 Faible', '🟠 Moyen', '🟢 Fort', '💪 Très fort'];

    pwd.addEventListener('input', function() {
        const v     = this.value;
        const score = Object.values(rules).filter(fn => fn(v)).length;

        // Barres de force
        ['bar1','bar2','bar3','bar4'].forEach(function(id, i) {
            const bar = document.getElementById(id);
            if (bar) bar.style.background = i < score ? colors[score - 1] : 'rgba(106,90,205,.12)';
        });

        // Label textuel
        const lbl = document.getElementById('strengthLabel');
        if (lbl) {
            lbl.textContent = v.length ? (labels[score] || labels[1]) : '';
            lbl.style.color = v.length ? colors[Math.max(0, score - 1)] : '';
        }

        // Règles individuelles
        Object.entries(rules).forEach(function(entry) {
            const el = document.getElementById('r-' + entry[0]);
            if (el) el.classList.toggle('ok', entry[1](v));
        });
    });

    // Vérification correspondance
    if (conf) {
        conf.addEventListener('input', checkMatch);
        conf.addEventListener('blur',  checkMatch);
    }

    function checkMatch() {
        const err = document.getElementById('matchError');
        if (err) {
            const mismatch = conf.value.length > 0 && conf.value !== pwd.value;
            err.style.display = mismatch ? 'block' : 'none';
        }
    }

    // Bloquer la soumission si les mots de passe ne correspondent pas
    const form = document.getElementById('resetForm');
    if (form) {
        form.addEventListener('submit', function(e) {
            if (pwd.value !== conf.value) {
                e.preventDefault();
                const err = document.getElementById('matchError');
                if (err) err.style.display = 'block';
                conf.focus();
            }
        });
    }
})();
</script>
{% endblock %}
