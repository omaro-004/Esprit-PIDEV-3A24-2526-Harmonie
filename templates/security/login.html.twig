{% extends 'base.html.twig' %}
{% block title %}Connexion — Harmony{% endblock %}

{% block stylesheets %}
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --purple:       #6A5ACD;
            --purple-dark:  #4B3B9E;
            --purple-mid:   #7C6DD8;
            --purple-soft:  #8B7FD4;
            --purple-pale:  #EDE8FA;
            --purple-ghost: #F0EEF8;
            --purple-deep:  #2D2260;
            --text:         #1C1733;
            --text-mid:     #4A4570;
            --text-muted:   #9590B8;
            --border:       rgba(106,90,205,.15);
            --white:        #FFFFFF;
            --font-display: 'Cormorant Garamond', Georgia, serif;
            --font-body:    'DM Sans', sans-serif;
        }

        html, body {
            min-height: 100vh;
            font-family: var(--font-body);
            background: #E8E4F3;
            overflow-x: hidden;
        }

        /* ── BACKGROUND ── */
        .scene {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            background-image: url("{{ asset('images/backgLIGHT.png') }}");
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        .scene::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,
                rgba(106,90,205,.18) 0%,
                rgba(237,232,250,.55) 50%,
                rgba(75,59,158,.12) 100%);
            backdrop-filter: blur(1px);
        }

        /* ── WRAPPER ── */
        .login-wrapper {
            position: relative;
            z-index: 10;
            display: flex;
            gap: 0;
            max-width: 820px;
            width: 100%;
            border-radius: 28px;
            overflow: hidden;
            box-shadow:
                0 32px 80px rgba(45,34,96,.22),
                0 0 0 1px rgba(106,90,205,.15),
                inset 0 1px 0 rgba(255,255,255,.6);
            animation: wrapperIn .7s cubic-bezier(.22,1,.36,1) both;
        }

        @keyframes wrapperIn {
            from { opacity:0; transform: translateY(28px) scale(.97); }
            to   { opacity:1; transform: translateY(0) scale(1); }
        }

        /* ── LEFT PANEL ── */
        .panel-left {
            width: 280px;
            flex-shrink: 0;
            background: linear-gradient(160deg, var(--purple-deep) 0%, var(--purple) 60%, var(--purple-mid) 100%);
            padding: 52px 36px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .panel-left::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 220px; height: 220px;
            border-radius: 50%;
            background: rgba(255,255,255,.06);
            pointer-events: none;
        }

        .panel-left::after {
            content: '';
            position: absolute;
            bottom: -40px; left: -40px;
            width: 180px; height: 180px;
            border-radius: 50%;
            background: rgba(255,255,255,.04);
            pointer-events: none;
        }

        .brand {
            display: flex;
            flex-direction: column;
            gap: 14px;
            animation: fadeSlide .6s .15s ease both;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .brand-logo img {
            width: 38px; height: 38px;
            border-radius: 11px;
            object-fit: contain;
            border: 2px solid rgba(255,255,255,.2);
        }

        .brand-name {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 600;
            color: white;
            letter-spacing: .5px;
        }

        .brand-tagline {
            font-family: var(--font-display);
            font-size: 32px;
            font-weight: 300;
            font-style: italic;
            color: rgba(255,255,255,.9);
            line-height: 1.3;
            letter-spacing: -.3px;
        }

        .brand-tagline strong {
            font-weight: 600;
            font-style: normal;
            color: white;
        }

        .brand-sub {
            font-size: 12.5px;
            font-weight: 300;
            color: rgba(255,255,255,.6);
            line-height: 1.6;
            margin-top: 4px;
        }

        .decorative-dots {
            display: flex;
            gap: 6px;
            animation: fadeSlide .6s .35s ease both;
        }

        .decorative-dots span {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: rgba(255,255,255,.3);
        }

        .decorative-dots span:first-child { background: rgba(255,255,255,.8); }
        .decorative-dots span:nth-child(2) { background: rgba(255,255,255,.5); }

        /* ── RIGHT PANEL ── */
        .panel-right {
            flex: 1;
            background: rgba(255,255,255,.92);
            backdrop-filter: blur(20px);
            padding: 48px 44px 44px;
            display: flex;
            flex-direction: column;
        }

        .panel-right-title {
            font-family: var(--font-display);
            font-size: 28px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 4px;
            animation: fadeSlide .5s .1s ease both;
        }

        .panel-right-sub {
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 30px;
            font-weight: 300;
            animation: fadeSlide .5s .15s ease both;
        }

        /* ── ALERTS ── */
        .alert {
            padding: 10px 14px;
            border-radius: 10px;
            font-size: 12.5px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            animation: fadeSlide .4s ease both;
        }

        .alert-error {
            background: #FEE2E2;
            color: #991B1B;
            border: 1px solid #FECACA;
        }

        .alert-captcha {
            background: #FFF7ED;
            color: #92400E;
            border: 1px solid #FCD34D;
        }

        .alert-success {
            background: #D1FAE5;
            color: #065F46;
            border: 1px solid #6EE7B7;
        }

        /* ── FORM FIELDS ── */
        .field-group {
            margin-bottom: 16px;
            animation: fadeSlide .5s ease both;
        }

        .field-group:nth-child(1) { animation-delay: .2s; }
        .field-group:nth-child(2) { animation-delay: .25s; }
        .field-group:nth-child(3) { animation-delay: .3s; }

        .field-label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: var(--text-mid);
            margin-bottom: 8px;
        }

        .field-input-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 15px;
            pointer-events: none;
            opacity: .5;
            transition: opacity .2s;
        }

        .field-input {
            width: 100%;
            padding: 11px 14px 11px 42px;
            border: 1.5px solid var(--border);
            border-radius: 11px;
            font-family: var(--font-body);
            font-size: 14px;
            color: var(--text);
            background: var(--purple-ghost);
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        .field-input:focus {
            border-color: var(--purple);
            background: white;
            box-shadow: 0 0 0 3px rgba(106,90,205,.1);
        }

        .field-input:focus ~ .field-icon,
        .field-input-wrap:has(.field-input:focus) .field-icon {
            opacity: .8;
        }

        /* ── CAPTCHA ── */
        .captcha-section {
            margin-bottom: 20px;
            animation: fadeSlide .5s .35s ease both;
        }

        .captcha-label {
            display: block;
            font-size: 11.5px;
            font-weight: 600;
            letter-spacing: .6px;
            text-transform: uppercase;
            color: var(--text-mid);
            margin-bottom: 8px;
        }

        .captcha-row {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .captcha-question-box {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            background: linear-gradient(135deg, var(--purple-pale), rgba(237,232,250,.6));
            border: 1.5px solid rgba(106,90,205,.2);
            border-radius: 11px;
            padding: 10px 20px;
            flex-shrink: 0;
        }

        .captcha-math {
            font-family: var(--font-display);
            font-size: 22px;
            font-weight: 600;
            color: var(--purple-dark);
            letter-spacing: 3px;
        }

        .captcha-eq {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
        }

        .captcha-input {
            flex: 1;
            padding: 11px 14px;
            border: 1.5px solid var(--border);
            border-radius: 11px;
            font-family: var(--font-display);
            font-size: 18px;
            font-weight: 600;
            color: var(--purple-dark);
            background: var(--purple-ghost);
            outline: none;
            text-align: center;
            letter-spacing: 3px;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        .captcha-input:focus {
            border-color: var(--purple);
            background: white;
            box-shadow: 0 0 0 3px rgba(106,90,205,.1);
        }

        .captcha-hint {
            font-size: 10.5px;
            color: var(--text-muted);
            text-align: center;
            margin-top: 5px;
        }

        /* ── SUBMIT ── */
        .btn-submit {
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, var(--purple) 0%, var(--purple-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: var(--font-body);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            letter-spacing: .3px;
            box-shadow: 0 4px 20px rgba(106,90,205,.4), 0 1px 0 rgba(255,255,255,.1) inset;
            transition: transform .15s, box-shadow .15s, background .2s;
            margin-top: 4px;
            animation: fadeSlide .5s .4s ease both;
            position: relative;
            overflow: hidden;
        }

        .btn-submit::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 50%);
            pointer-events: none;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(106,90,205,.45);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        /* ════════════════════════════════════════════
           ── OAUTH BUTTONS (NOUVEAU) ──
        ════════════════════════════════════════════ */

        /* Séparateur "ou continuez avec" */
        .divider-line {
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 18px 0 16px;
            animation: fadeSlide .5s .42s ease both;
        }

        .divider-line::before,
        .divider-line::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .divider-line span {
            font-size: 11px;
            color: var(--text-muted);
            letter-spacing: .5px;
            white-space: nowrap;
        }

        /* Grille des 2 boutons OAuth */
        .oauth-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 18px;
            animation: fadeSlide .5s .47s ease both;
        }

        /* Bouton OAuth générique */
        .btn-oauth {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 11px 16px;
            border-radius: 12px;
            font-family: var(--font-body);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: transform .15s, box-shadow .15s, background .15s, border-color .15s;
            position: relative;
            overflow: hidden;
            border: 1.5px solid transparent;
            white-space: nowrap;
        }

        .btn-oauth::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,.1) 0%, transparent 60%);
            pointer-events: none;
        }

        .btn-oauth:hover {
            transform: translateY(-2px);
        }

        .btn-oauth:active {
            transform: translateY(0);
        }

        /* Icône SVG dans le bouton */
        .btn-oauth .oauth-icon {
            width: 20px;
            height: 20px;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-oauth .oauth-icon svg {
            width: 20px;
            height: 20px;
        }

        /* ── Variante Google ── */
        .btn-oauth-google {
            background: #ffffff;
            border-color: rgba(0, 0, 0, .14);
            color: #3c4043;
            box-shadow: 0 1px 4px rgba(0,0,0,.12), 0 2px 8px rgba(0,0,0,.06);
        }

        .btn-oauth-google:hover {
            border-color: rgba(0,0,0,.22);
            box-shadow: 0 4px 14px rgba(0,0,0,.14);
            background: #f8f8f8;
        }

        /* ── Variante Facebook ── */
        .btn-oauth-facebook {
            background: #1877F2;
            border-color: #1877F2;
            color: #ffffff;
            box-shadow: 0 2px 8px rgba(24,119,242,.35);
        }

        .btn-oauth-facebook:hover {
            background: #1568d3;
            border-color: #1568d3;
            box-shadow: 0 4px 16px rgba(24,119,242,.45);
        }

        /* Texte du bouton */
        .btn-oauth .oauth-label {
            line-height: 1;
        }

        /* ── Pied de page : inscription ── */
        .form-footer {
            text-align: center;
            font-size: 12.5px;
            color: var(--text-muted);
            animation: fadeSlide .5s .52s ease both;
        }

        .form-footer a {
            color: var(--purple);
            text-decoration: none;
            font-weight: 500;
            position: relative;
        }

        .form-footer a::after {
            content: '';
            position: absolute;
            bottom: -1px; left: 0; right: 0;
            height: 1px;
            background: var(--purple);
            transform: scaleX(0);
            transition: transform .2s;
        }

        .form-footer a:hover::after { transform: scaleX(1); }

        /* Note session */
        .session-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            font-size: 10.5px;
            color: var(--text-muted);
            margin-top: 10px;
            margin-bottom: 0;
            animation: fadeSlide .5s .5s ease both;
        }

        /* ── ANIMATIONS ── */
        @keyframes fadeSlide {
            from { opacity:0; transform: translateY(12px); }
            to   { opacity:1; transform: translateY(0); }
        }

        /* ── RESPONSIVE ── */
        @media (max-width: 680px) {
            .login-wrapper { flex-direction: column; max-width: 420px; border-radius: 22px; }
            .panel-left { width: 100%; padding: 36px 32px; }
            .brand-tagline { font-size: 26px; }
            .panel-right { padding: 36px 28px 32px; }
            .captcha-row { flex-direction: column; }
            .captcha-question-box { width: 100%; }
            .captcha-input { width: 100%; }
            .oauth-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="scene">
    <div class="login-wrapper">

        <!-- ── LEFT PANEL ── -->
        <div class="panel-left">
            <div class="brand">
                <div class="brand-logo">
                    <img src="{{ asset('images/logo.png') }}" alt="Harmony">
                    <span class="brand-name">Harmony</span>
                </div>
                <p class="brand-tagline">
                    Votre espace<br>
                    <strong>étudiant</strong><br>
                    centralisé
                </p>
                <p class="brand-sub">
                    Gérez vos activités, suivez votre bien-être et restez connecté avec votre communauté.
                </p>
            </div>
            <div class="decorative-dots">
                <span></span><span></span><span></span>
            </div>
        </div>

        <!-- ── RIGHT PANEL ── -->
        <div class="panel-right">
            <div class="panel-right-title">Bon retour 👋</div>
            <div class="panel-right-sub">Connectez-vous à votre espace</div>

            {# ── Alertes ── #}
            {% if error %}
                <div class="alert alert-error">⚠ {{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% for msg in app.flashes('captcha_error') %}
                <div class="alert alert-captcha">🔒 {{ msg }}</div>
            {% endfor %}

            {% for msg in app.flashes('success') %}
                <div class="alert alert-success">✅ {{ msg }}</div>
            {% endfor %}

            {# ── Alertes OAuth (erreurs Google / Facebook) ── #}
            {% for msg in app.flashes('error') %}
                <div class="alert alert-error">⚠ {{ msg }}</div>
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">

                {# ── Email ── #}
                <div class="field-group">
                    <label class="field-label" for="email">Adresse email</label>
                    <div class="field-input-wrap">
                        <span class="field-icon">✉</span>
                        <input class="field-input" type="email" id="email" name="email"
                               value="{{ last_username }}" required autofocus
                               placeholder="votre@email.com">
                    </div>
                </div>

                {# ── Mot de passe ── #}
                <div class="field-group">
                    <label class="field-label" for="password">Mot de passe</label>
                    <div class="field-input-wrap">
                        <span class="field-icon">🔑</span>
                        <input class="field-input" type="password" id="password" name="password"
                               required placeholder="••••••••">
                    </div>
                </div>

                {# ── Mot de passe oublié ── #}
                <div style="display:flex;justify-content:flex-end;margin-top:-8px;margin-bottom:18px;">
                    <a href="{{ path('app_forgot_password') }}"
                       style="font-size:12px;color:var(--purple);text-decoration:none;opacity:.75;font-weight:500;transition:opacity .15s;"
                       onmouseover="this.style.opacity='1';this.style.textDecoration='underline';"
                       onmouseout="this.style.opacity='.75';this.style.textDecoration='none';">
                        Mot de passe oublié ?
                    </a>
                </div>

                {# ── CAPTCHA ── #}
                <div class="captcha-section">
                    <label class="captcha-label">🔐 Vérification de sécurité</label>
                    <div class="captcha-row">
                        <div class="captcha-question-box">
                            <span class="captcha-math">{{ captcha_question }}</span>
                            <span class="captcha-eq">= ?</span>
                        </div>
                        <input type="text"
                               id="captcha"
                               name="captcha"
                               class="captcha-input"
                               required
                               autocomplete="off"
                               inputmode="numeric"
                               placeholder="?"
                               maxlength="3">
                    </div>
                    <p class="captcha-hint">Entrez le résultat du calcul</p>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button class="btn-submit" type="submit">
                    Se connecter →
                </button>
            </form>

            <p class="session-note">🕐 Session maintenue 3 h après connexion</p>

            {# ══════════════════════════════════════════════════════
               SÉPARATEUR + BOUTONS OAUTH  (NOUVEAU)
            ══════════════════════════════════════════════════════ #}
            <div class="divider-line">
                <span>ou continuez avec</span>
            </div>

            <div class="oauth-grid">

                {# ── Bouton Google ── #}
                <a href="{{ path('connect_google') }}" class="btn-oauth btn-oauth-google">
                    <span class="oauth-icon">
                        {# Logo Google officiel SVG — couleurs d'origine #}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                    </span>
                    <span class="oauth-label">Google</span>
                </a>

                {# ── Bouton Facebook ── #}
                <a href="{{ path('connect_facebook') }}" class="btn-oauth btn-oauth-facebook">
                    <span class="oauth-icon">
                        {# Logo Facebook officiel SVG — blanc sur bleu #}
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="#ffffff">
                            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.791-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.267h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
                        </svg>
                    </span>
                    <span class="oauth-label">Facebook</span>
                </a>

            </div>
            {# ══════════════════════════════════════════════════════ #}

            <div class="form-footer">
                Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a>
            </div>

        </div>
        {# /panel-right #}

    </div>
</div>
{% endblock %}